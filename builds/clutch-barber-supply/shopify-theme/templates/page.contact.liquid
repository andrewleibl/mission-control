{% comment %} Template: page.contact {% endcomment %}
<div class="page-with-glow">
<div class="page-header">
  <h1>Contact Us</h1>
  <p>We're here to help. Reach out however works best for you.</p>
</div>

<div class="contact-layout">
  <div class="contact-info">
    <h2>Get in Touch</h2>
    
    <div class="contact-method">
      <div class="contact-method__icon">✉</div>
      <div class="contact-method__content">
        <h3>Email Us</h3>
        <p><a href="mailto:viceliatinde20@gmail.com">viceliatinde20@gmail.com</a><br>We reply within 24 hours</p>
      </div>
    </div>

    <div class="contact-method">
      <div class="contact-method__icon">☎</div>
      <div class="contact-method__content">
        <h3>Call Us</h3>
        <p><a href="tel:+12146771059">(214) 677-1059</a><br>Mon–Fri 9am–6pm, Sat 9am–12pm CST</p>
      </div>
    </div>

    <div class="contact-method">
      <div class="contact-method__icon">📍</div>
      <div class="contact-method__content">
        <h3>Visit Our Store</h3>
        <p>113 South Center<br>Grand Prairie, TX 75050</p>
      </div>
    </div>
  </div>
  
  {% form 'contact' %}
    <div class="contact-form">
      <h2>Send a Message</h2>
      {% if form.posted_successfully? %}
        <div class="form-success">
          <p>Thanks for reaching out! We'll get back to you within 24 hours.</p>
        </div>
      {% endif %}
      <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="contact[name]" placeholder="Full Name" required>
      </div>
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="contact[email]" placeholder="youremail@example.com" required>
      </div>
      <div class="form-group">
        <label for="phone">Phone (Optional)</label>
        <input type="tel" id="phone" name="contact[phone]" placeholder="(555) 123-4567">
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="contact[body]" placeholder="How can we help you?" required></textarea>
      </div>
      <button type="submit" class="submit-btn">Send Message</button>
    </div>
  {% endform %}
</div>

<section class="map-section">
  <div class="map-section__inner">
    <h2>Find Us in Grand Prairie</h2>
    <div class="map-container">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3355.1234567890123!2d-97.0176!3d32.7459!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x864e1234567890ab%3A0x1234567890abcdef!2s113%20S%20Center%20St%2C%20Grand%20Prairie%2C%20TX%2075050!5e0!3m2!1sen!2sus!4v1234567890123" width="100%" height="400" style="border:0; border-radius: 16px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>

<style>
.contact-layout {
  max-width: 1200px;
  margin: 0 auto;
  padding: 4rem 1.5rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
}

@media (max-width: 900px) {
  .contact-layout {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
}

.contact-info h2 {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 1.5rem;
}

.contact-method {
  display: flex;
  gap: 1rem;
  margin-bottom: 1.5rem;
  padding: 1.25rem;
  background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  transition: all 0.2s;
}

.contact-method:hover {
  border-color: var(--clutch-accent);
}

.contact-method__icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 137, 75, 0.1);
  border-radius: 10px;
  color: var(--clutch-accent);
  font-size: 1.25rem;
  flex-shrink: 0;
}

.contact-method__content h3 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
}

.contact-method__content p {
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
}

.contact-method__content a {
  color: var(--clutch-accent);
  text-decoration: none;
}

.contact-method__content a:hover {
  text-decoration: underline;
}

.contact-form {
  background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 20px;
  padding: 2rem;
  position: relative;
}

.contact-form::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -20%;
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.15) 0%, transparent 60%);
  filter: blur(60px);
  pointer-events: none;
}

.contact-form h2 {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 1.5rem;
  position: relative;
  z-index: 1;
}

.form-success {
  padding: 1rem 1.25rem;
  background: rgba(34, 197, 94, 0.1);
  border: 1px solid rgba(34, 197, 94, 0.3);
  border-radius: 10px;
  margin-bottom: 1.5rem;
}

.form-success p {
  color: #22c55e;
  font-weight: 500;
  margin: 0;
}

.form-group {
  margin-bottom: 1.25rem;
  position: relative;
  z-index: 1;
}

.form-group label {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.form-group input,
.form-group textarea {
  width: 100%;
  padding: 0.875rem 1rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 10px;
  color: var(--clutch-text);
  font-size: 1rem;
  font-family: inherit;
  transition: all 0.2s;
}

.form-group input:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--clutch-accent);
  background: rgba(255,255,255,0.08);
}

.form-group textarea {
  min-height: 120px;
  resize: vertical;
}

.submit-btn {
  width: 100%;
  padding: 1rem;
  background: linear-gradient(135deg, var(--clutch-accent) 0%, #b87a3e 100%);
  color: var(--clutch-bg);
  border: none;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
  position: relative;
  z-index: 1;
}

.submit-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 28px rgba(201, 137, 75, 0.4);
}

.map-section {
  padding: 4rem 1.5rem;
  border-top: 1px solid var(--clutch-border);
}

.map-section__inner {
  max-width: 1200px;
  margin: 0 auto;
}

.map-section h2 {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 1.5rem;
  text-align: center;
}

.map-container {
  aspect-ratio: 21/9;
  background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 16px;
  overflow: hidden;
}

.map-container iframe {
  width: 100%;
  height: 100%;
  border: 0;
  display: block;
}

@media (max-width: 768px) {
  .map-container {
    aspect-ratio: 4/3;
  }
}
</style>
</div>