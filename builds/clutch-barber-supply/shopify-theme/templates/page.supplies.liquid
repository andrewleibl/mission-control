<style>
.page-header { 
  padding: 4rem 1.5rem; 
  text-align: center; 
  background: linear-gradient(180deg, var(--clutch-bg-lighter, #091018) 0%, var(--clutch-bg, #05070c) 100%); 
  position: relative; 
  overflow: hidden; 
}
.page-header::before { 
  content: ''; 
  position: absolute; 
  top: -30%; 
  left: 50%; 
  transform: translateX(-50%); 
  width: 600px; 
  height: 400px; 
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.2) 0%, transparent 60%); 
  filter: blur(80px); 
  pointer-events: none; 
}
.page-header h1 { 
  font-size: clamp(2rem, 5vw, 3rem); 
  font-weight: 700; 
  letter-spacing: -0.03em; 
  margin-bottom: 0.5rem; 
  position: relative; 
  z-index: 1; 
}
.page-header p { 
  color: var(--clutch-text-muted, #d1c7b3); 
  position: relative; 
  z-index: 1; 
}

/* Price Tier Marquee */
.featured-marquee {
  max-width: 1400px;
  margin: 0 auto;
  padding: 2rem 1.5rem 4rem;
  overflow: hidden;
}
.featured-marquee__track {
  display: flex;
  gap: 1.5rem;
  animation: marquee-scroll 35s linear infinite;
  width: max-content;
}
.featured-marquee:hover .featured-marquee__track {
  animation-play-state: paused;
}
@keyframes marquee-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.featured-marquee__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 2rem 2.5rem;
  background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
  border: 1px solid var(--clutch-border, #253242);
  border-radius: 16px;
  min-width: 240px;
  transition: all 0.3s ease;
  text-decoration: none;
  color: inherit;
}
.featured-marquee__item:hover {
  border-color: rgba(201, 137, 75, 0.5);
  box-shadow: 0 16px 32px rgba(0,0,0,0.3);
  transform: translateY(-4px);
}
.featured-marquee__label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--clutch-accent, #c9894b);
  margin-bottom: 0.5rem;
}
.featured-marquee__brand {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}
.featured-marquee__desc {
  font-size: 0.875rem;
  color: var(--clutch-text-muted, #d1c7b3);
}

/* Categories Grid */
.categories-grid { 
  max-width: 1400px; 
  margin: 0 auto; 
  padding: 4rem 1.5rem; 
  display: grid; 
  grid-template-columns: repeat(2, 1fr); 
  gap: 1.5rem; 
}
@media (min-width: 768px) { 
  .categories-grid { 
    grid-template-columns: repeat(2, 1fr); 
  } 
}
@media (min-width: 1024px) { 
  .categories-grid { 
    grid-template-columns: repeat(4, 1fr); 
  } 
}

.category-card { 
  position: relative; 
  padding: 3rem 2rem; 
  background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%); 
  border: 1px solid var(--clutch-border, #253242); 
  border-radius: 20px; 
  text-align: center; 
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1); 
  overflow: hidden; 
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.category-card::before { 
  content: ''; 
  position: absolute; 
  top: 0; 
  left: 0; 
  right: 0; 
  height: 3px; 
  background: linear-gradient(90deg, transparent, var(--clutch-accent, #c9894b), transparent); 
  opacity: 0; 
  transition: opacity 0.3s; 
}
.category-card:hover { 
  transform: translateY(-6px); 
  border-color: rgba(201, 137, 75, 0.4); 
  box-shadow: 0 24px 48px rgba(0,0,0,0.4); 
}
.category-card:hover::before { 
  opacity: 1; 
}
.category-card__icon { 
  width: 60px; 
  height: 60px; 
  margin: 0 auto 1.5rem; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  background: rgba(201, 137, 75, 0.1); 
  border: 1px solid rgba(201, 137, 75, 0.3); 
  border-radius: 16px; 
}
.category-card__icon svg { 
  width: 32px; 
  height: 32px; 
  stroke: var(--clutch-accent, #c9894b); 
  stroke-width: 1.5; 
  fill: none; 
}
.category-card__name { 
  font-size: 1.5rem; 
  font-weight: 700; 
  margin-bottom: 0.75rem; 
}
.category-card__desc { 
  font-size: 0.875rem; 
  color: var(--clutch-text-muted, #d1c7b3); 
  margin-bottom: 1.5rem; 
  flex-grow: 1;
}
.category-card__count { 
  display: inline-block; 
  padding: 0.375rem 1rem; 
  background: rgba(201, 137, 75, 0.1); 
  border: 1px solid rgba(201, 137, 75, 0.3); 
  border-radius: 50px; 
  font-size: 0.8125rem; 
  color: var(--clutch-accent, #c9894b); 
  margin-bottom: 1rem; 
}
.category-card__link { 
  display: inline-flex; 
  align-items: center; 
  gap: 0.5rem; 
  color: var(--clutch-accent, #c9894b); 
  font-weight: 600; 
  font-size: 0.875rem; 
  transition: gap 0.2s; 
}
.category-card:hover .category-card__link { 
  gap: 0.75rem; 
}
</style>
</div>