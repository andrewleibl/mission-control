<div class="page-header">
  <h1>Shopping Cart</h1>
  <div class="breadcrumbs">
    <a href="{{ routes.root_url }}">Home</a>
  </div>
</div>

{% if cart.item_count > 0 %}
  <div class="cart-layout">
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="cart-item__image">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.image.alt | escape }}" loading="lazy">
              {% else %}
                <span>{{ item.product.title }}</span>
              {% endif %}
            </div>
            <div class="cart-item__details">
              <h3>{{ item.product.title }}</h3>
              <div class="cart-item__brand">{{ item.vendor }}</div>
              {% if item.variant.title != 'Default Title' %}
                <div class="cart-item__variant">{{ item.variant.title }}</div>
              {% endif %}
            </div>
            <div class="cart-item__actions">
              <div class="cart-item__price">{{ item.final_line_price | money }}</div>
              <div class="quantity-control">
                <button type="button" onclick="updateCartItem('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" data-key="{{ item.key }}">
                <button type="button" onclick="updateCartItem('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
              </div>
              <a href="{{ item.url_to_remove }}" class="remove-btn">Remove</a>
            </div>
          </div>
        {% endfor %}
      </div>
      
      <div class="cart-actions">
        <button type="submit" name="update" class="update-btn">Update Cart</button>
        <button type="submit" name="checkout" class="checkout-btn">Proceed to Checkout</button>
      </div>
    </form>
    
    <div class="cart-summary">
      <h2>Order Summary</h2>
      <div class="summary-row">
        <span>Subtotal</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
      {% if cart.taxes_included %}
        <div class="summary-row">
          <span>Taxes included</span>
        </div>
      {% endif %}
      <div class="summary-row total">
        <span>Total</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
    </div>
  </div>
{% else %}
  <div class="empty-cart">
    <h2>Your cart is empty</h2>
    <p>Add some items to get started.</p>
    <a href="{{ routes.all_products_collection_url }}" class="continue-shopping">Continue Shopping</a>
  </div>
{% endif %}

<style>
.cart-layout { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }
@media (max-width: 900px) { .cart-layout { grid-template-columns: 1fr; } }

.cart-items { background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%); border: 1px solid var(--clutch-border); border-radius: 20px; padding: 1.5rem; }
.cart-item { display: grid; grid-template-columns: 100px 1fr auto; gap: 1.5rem; padding: 1.5rem 0; border-bottom: 1px solid var(--clutch-border); }
.cart-item:last-child { border-bottom: none; }
.cart-item__image { width: 100px; height: 100px; background: rgba(255,255,255,0.05); border-radius: 12px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.cart-item__image img { max-width: 100%; max-height: 100%; object-fit: contain; }
.cart-item__details h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
.cart-item__brand { font-size: 0.75rem; color: var(--clutch-accent); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
.cart-item__variant { font-size: 0.875rem; color: var(--clutch-text-muted); }
.cart-item__actions { display: flex; flex-direction: column; align-items: flex-end; gap: 1rem; }
.cart-item__price { font-size: 1.125rem; font-weight: 700; }

.cart-actions { display: flex; gap: 1rem; margin-top: 2rem; }
.update-btn { padding: 1rem 2rem; background: transparent; border: 1px solid var(--clutch-border); border-radius: 12px; color: var(--clutch-text); cursor: pointer; transition: all 0.2s; }
.update-btn:hover { border-color: var(--clutch-accent); color: var(--clutch-accent); }
.checkout-btn { padding: 1rem 2rem; background: var(--clutch-accent); border: none; border-radius: 12px; color: var(--clutch-bg); font-weight: 600; cursor: pointer; transition: all 0.3s; }
.checkout-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(201, 137, 75, 0.4); }

.cart-summary { background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%); border: 1px solid var(--clutch-border); border-radius: 20px; padding: 1.5rem; height: fit-content; position: sticky; top: 100px; }
.cart-summary h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--clutch-border); }
.summary-row { display: flex; justify-content: space-between; margin-bottom: 1rem; font-size: 0.9375rem; }
.summary-row.total { font-size: 1.125rem; font-weight: 700; padding-top: 1rem; border-top: 1px solid var(--clutch-border); margin-top: 1rem; }

.empty-cart { text-align: center; padding: 4rem 1.5rem; }
.empty-cart h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; }
.empty-cart p { color: var(--clutch-text-muted); margin-bottom: 1.5rem; }
.continue-shopping { display: inline-block; padding: 1rem 2rem; background: var(--clutch-accent); color: var(--clutch-bg); border-radius: 12px; font-weight: 600; transition: all 0.3s; }
.continue-shopping:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(201, 137, 75, 0.4); }
</style>

<script>
async function updateCartItem(key, quantity) {
  if (quantity < 0) quantity = 0;
  
  try {
    const response = await fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ updates: { [key]: quantity } })
    });
    
    if (response.ok) {
      window.location.reload();
    }
  } catch (error) {
    console.error('Error updating cart:', error);
  }
}
</script>

{% schema %}
{
  "name": "Cart Template",
  "settings": []
}
{% endschema %}
