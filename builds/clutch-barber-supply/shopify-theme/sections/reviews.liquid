<section class="clutch-home-section clutch-home-reviews" id="reviews">
  <div class="clutch-home-section__inner">
    <header class="clutch-home-section__header">
      <p class="clutch-home-section__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="clutch-home-section__title">{{ section.settings.title }}</h2>
      <p class="clutch-home-section__subtitle">{{ section.settings.subtitle }}</p>
    </header>
    
    <div class="clutch-home-reviews__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.review_link }}" target="_blank" rel="noopener noreferrer" class="clutch-home-reviews__card-link" {{ block.shopify_attributes }}>
          <article class="clutch-home-reviews__card">
            <div class="clutch-home-reviews__stars">{{ block.settings.stars }}</div>
            <h3 class="clutch-home-reviews__name">{{ block.settings.author }}</h3>
            <p class="clutch-home-reviews__quote">"{{ block.settings.quote }}"</p>
          </article>
        </a>
      {% endfor %}
    </div>
    
    <p class="clutch-home-section__hint">{{ section.settings.hint_text }}</p>
  </div>
</section>

<style>
.clutch-home-reviews {
  background: linear-gradient(180deg, var(--clutch-bg) 0%, var(--clutch-bg-lighter) 50%, var(--clutch-bg) 100%);
  position: relative;
  overflow: hidden;
}
.clutch-home-reviews__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
}
@media (min-width: 640px) { .clutch-home-reviews__grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .clutch-home-reviews__grid { grid-template-columns: repeat(3, 1fr); } }
.clutch-home-reviews__card-link { text-decoration: none; }
.clutch-home-reviews__card {
  padding: 1.75rem;
  background: linear-gradient(145deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 20px;
  transition: all 0.3s ease;
  height: 100%;
}
.clutch-home-reviews__card:hover {
  transform: translateY(-4px);
  border-color: rgba(201, 137, 75, 0.4);
  box-shadow: 0 16px 32px rgba(0,0,0,0.3);
}
.clutch-home-reviews__stars {
  color: var(--clutch-accent);
  font-size: 1.25rem;
  margin-bottom: 1rem;
  letter-spacing: 0.1em;
}
.clutch-home-reviews__name {
  font-size: 1.125rem;
  font-weight: 700;
  margin-bottom: 0.75rem;
}
.clutch-home-reviews__quote {
  color: var(--clutch-text-muted);
  font-size: 0.9375rem;
  line-height: 1.6;
}
.clutch-home-section__hint {
  text-align: center;
  margin-top: 2rem;
  font-size: 0.875rem;
  color: var(--clutch-text-dim);
}
</style>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Google reviews",
      "label": "Eyebrow Text"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Perfection Every Time",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "default": "Fast shipping from Texas + 30-day returns on any damaged product. No hassle, no runaround.",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "hint_text",
      "default": "👆 Click any review to read the full story on Google Reviews",
      "label": "Hint Text"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "stars",
          "default": "★★★★★",
          "label": "Stars"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review Quote"
        },
        {
          "type": "url",
          "id": "review_link",
          "label": "Google Review Link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Reviews"
    }
  ]
}
{% endschema %}
