{% schema %}
{
  "name": "Social Proof",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Google reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Perfection Every Time"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fast shipping from Texas + 30-day returns on any damaged product. No hassle, no runaround."
    }
  ],
  "presets": [
    {
      "name": "Social Proof"
    }
  ]
}
{% endschema %}
