<header class="clutch-home-header" data-section-id="{{ section.id }}" data-section-type="header">
  <div class="clutch-home-header__inner">
    <div class="clutch-home-header__left">
      <button class="clutch-home-header__menu" aria-label="Open menu" onclick="document.getElementById('mobileNav').classList.add('active'); document.getElementById('mobileNavOverlay').classList.add('active');">
        <span></span><span></span><span></span>
      </button>
      <div class="clutch-home-header__search">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input type="search" name="q" placeholder="Search" value="{{ search.terms | escape }}" aria-label="Search">
        </form>
      </div>
    </div>
    
    <a href="{{ routes.root_url }}" class="clutch-home-header__logo">
      <img src="{{ 'clutch-logo.png' | asset_url }}" alt="{{ shop.name }}" width="150" height="60" loading="eager">
    </a>
    
    <div class="clutch-home-header__right">
      <nav class="clutch-home-header__desktop-nav">
        <a href="{{ routes.all_products_collection_url }}">Shop</a>
        
        <div class="clutch-home-header__dropdown">
          <a href="/pages/brands">Brands</a>
          <div class="clutch-home-header__dropdown-menu">
            <a href="/collections/all?vendor=Andis" class="clutch-home-header__dropdown-item">Andis</a>
            <a href="/collections/all?vendor=Babyliss+Pro" class="clutch-home-header__dropdown-item">Babyliss Pro</a>
            <a href="/collections/all?vendor=JRL" class="clutch-home-header__dropdown-item">JRL</a>
            <a href="/collections/all?vendor=Wahl" class="clutch-home-header__dropdown-item">Wahl</a>
            <a href="/collections/all?vendor=Gamma+%7C+Style+Craft" class="clutch-home-header__dropdown-item">Gamma | Style Craft</a>
            <a href="/collections/all?vendor=Supreme+Trimmers" class="clutch-home-header__dropdown-item">Supreme Trimmers</a>
            <a href="/collections/all?vendor=Level+3" class="clutch-home-header__dropdown-item">Level 3</a>
            <a href="/collections/all?vendor=Cocco+Hair+Pro" class="clutch-home-header__dropdown-item">Cocco Hair Pro</a>
            <a href="/collections/all?vendor=Oster" class="clutch-home-header__dropdown-item">Oster</a>
            <a href="/collections/all?vendor=Tomb45" class="clutch-home-header__dropdown-item">Tomb45</a>
            <a href="/collections/all?vendor=Vincent" class="clutch-home-header__dropdown-item">Vincent</a>
            <a href="/collections/all?vendor=OG+Walker" class="clutch-home-header__dropdown-item">OG Walker</a>
            <a href="/collections/all?vendor=Smash" class="clutch-home-header__dropdown-item">Smash</a>
            <a href="/collections/all?vendor=Rolda" class="clutch-home-header__dropdown-item">Rolda</a>
          </div>
        </div>
        
        <div class="clutch-home-header__dropdown">
          <a href="/pages/supplies">Supplies</a>
          <div class="clutch-home-header__dropdown-menu">
            <a href="/collections/all?category=clippers" class="clutch-home-header__dropdown-item">Clippers</a>
            <a href="/collections/all?category=trimmers" class="clutch-home-header__dropdown-item">Trimmers</a>
            <a href="/collections/all?category=shavers" class="clutch-home-header__dropdown-item">Shavers</a>
            <a href="/collections/all?category=barber-bags-cases" class="clutch-home-header__dropdown-item">Barber Bags | Cases</a>
            <a href="/collections/all?category=lights" class="clutch-home-header__dropdown-item">Lights</a>
            <a href="/collections/all?category=accessories" class="clutch-home-header__dropdown-item">Accessories</a>
            <a href="/collections/all?category=capes" class="clutch-home-header__dropdown-item">Capes</a>
            <a href="/collections/all?category=barber-chairs" class="clutch-home-header__dropdown-item">Barber Chairs</a>
            <a href="/collections/all?category=barber-clothing" class="clutch-home-header__dropdown-item">Barber Clothing</a>
            <a href="/collections/all?category=barber-poles" class="clutch-home-header__dropdown-item">Barber Poles</a>
          </div>
        </div>
        
        <a href="/pages/classes">Classes</a>
        <a href="/pages/contact">Contact</a>
        <a href="/pages/faq">FAQ</a>
        <a href="/pages/reviews">Reviews</a>
      </nav>
      
      <a href="{{ routes.cart_url }}" class="clutch-home-header__cart" aria-label="Cart">
        <svg viewBox="0 0 24 24"><path d="M3 5h2l2.1 9.2a1 1 0 0 0 1 .8H18a1 1 0 0 0 1-.8L21 8H7"></path><circle cx="9" cy="19" r="1.5"></circle><circle cx="17" cy="19" r="1.5"></circle></svg>
      </a>
    </div>
  </div>
</header>

<!-- MOBILE NAVIGATION DRAWER -->
<div class="clutch-mobile-nav" id="mobileNav">
  <div class="clutch-mobile-nav__header">
    <span class="clutch-mobile-nav__title">Menu</span>
    <button class="clutch-mobile-nav__close" onclick="document.getElementById('mobileNav').classList.remove('active'); document.getElementById('mobileNavOverlay').classList.remove('active');" aria-label="Close menu">
      <svg viewBox="0 0 24 24" width="24" height="24"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" fill="none"/></svg>
    </button>
  </div>
  <nav class="clutch-mobile-nav__links">
    <a href="{{ routes.all_products_collection_url }}">Shop</a>
    <a href="/pages/brands">Brands</a>
    <a href="/pages/supplies">Supplies</a>
    <a href="/pages/classes">Classes</a>
    <a href="/pages/contact">Contact</a>
    <a href="/pages/faq">FAQ</a>
    <a href="/pages/reviews">Reviews</a>
  </nav>
  <div class="clutch-mobile-nav__footer">
    <a href="{{ routes.cart_url }}" class="clutch-mobile-nav__cart">
      <svg viewBox="0 0 24 24" width="20" height="20"><path d="M3 5h2l2.1 9.2a1 1 0 0 0 1 .8H18a1 1 0 0 0 1-.8L21 8H7"></path><circle cx="9" cy="19" r="1.5"></circle><circle cx="17" cy="19" r="1.5"></circle></svg>
      Cart
    </a>
  </div>
</div>
<div class="clutch-mobile-nav__overlay" id="mobileNavOverlay" onclick="document.getElementById('mobileNav').classList.remove('active'); document.getElementById('mobileNavOverlay').classList.remove('active');"></div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu (Note: Hardcoded nav shown above)"
    }
  ]
}
{% endschema %}