<div
  class="clutch-home-hero-section"
  style="
    --clutch-hero-overlay-start: {{ section.settings.overlay_start }};
    --clutch-hero-overlay-end: {{ section.settings.overlay_end }};
    --clutch-hero-accent: {{ section.settings.accent_color }};
    --clutch-hero-text: {{ section.settings.text_color }};
    --clutch-hero-muted: {{ section.settings.muted_text_color }};
  "
>
  <section class="clutch-home-hero" aria-label="Homepage hero">
    <div class="clutch-home-hero__media">
      {%- if section.settings.background_image != blank -%}
        {{ section.settings.background_image | image_url: width: 2200 | image_tag: class: 'clutch-home-hero__image', loading: 'eager', widths: '768, 1200, 1800, 2200', sizes: '100vw', alt: section.settings.heading }}
      {%- else -%}
        <div class="clutch-home-hero__image clutch-home-hero__image--fallback" aria-hidden="true"></div>
      {%- endif -%}
      <div class="clutch-home-hero__overlay" aria-hidden="true"></div>
    </div>

    <div class="clutch-home-hero__content">
      <div class="clutch-home-hero__social-proof" aria-label="Five star rating trusted by barbers">
        <span class="clutch-home-hero__stars" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false"><path d="m12 2.6 2.9 5.88 6.49.95-4.69 4.57 1.11 6.46L12 17.42 6.19 20.46l1.11-6.46L2.61 9.43l6.49-.95Z"></path></svg>
          <svg viewBox="0 0 24 24" focusable="false"><path d="m12 2.6 2.9 5.88 6.49.95-4.69 4.57 1.11 6.46L12 17.42 6.19 20.46l1.11-6.46L2.61 9.43l6.49-.95Z"></path></svg>
          <svg viewBox="0 0 24 24" focusable="false"><path d="m12 2.6 2.9 5.88 6.49.95-4.69 4.57 1.11 6.46L12 17.42 6.19 20.46l1.11-6.46L2.61 9.43l6.49-.95Z"></path></svg>
          <svg viewBox="0 0 24 24" focusable="false"><path d="m12 2.6 2.9 5.88 6.49.95-4.69 4.57 1.11 6.46L12 17.42 6.19 20.46l1.11-6.46L2.61 9.43l6.49-.95Z"></path></svg>
          <svg viewBox="0 0 24 24" focusable="false"><path d="m12 2.6 2.9 5.88 6.49.95-4.69 4.57 1.11 6.46L12 17.42 6.19 20.46l1.11-6.46L2.61 9.43l6.49-.95Z"></path></svg>
        </span>
        <span class="clutch-home-hero__social-text">{{ section.settings.social_proof_text | escape }}</span>
      </div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="clutch-home-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1>{{ section.settings.heading | escape }}</h1>
      <p class="clutch-home-hero__subheading">{{ section.settings.subheading | escape }}</p>

      <div class="clutch-home-hero__actions">
        <a href="{{ section.settings.primary_button_url | default: '/collections/all' }}" class="clutch-button clutch-button--primary">
          {{ section.settings.primary_button_label | escape }}
        </a>
        <a href="{{ section.settings.secondary_button_url | default: '/pages/contact' }}" class="clutch-button clutch-button--ghost">
          {{ section.settings.secondary_button_label | escape }}
        </a>
      </div>

      <div class="clutch-home-hero__trust" aria-label="Trust highlights">
        <div class="clutch-home-hero__trust-item">
          <span class="clutch-home-hero__trust-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M3 7h11v8H3z"></path>
              <path d="M14 10h3l4 3v2h-7z"></path>
              <path d="M7 18a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm10 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"></path>
            </svg>
          </span>
          <span>{{ section.settings.trust_one | escape }}</span>
        </div>
        <div class="clutch-home-hero__trust-item">
          <span class="clutch-home-hero__trust-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 3 5 6v5c0 4.4 2.9 7.5 7 8 4.1-.5 7-3.6 7-8V6l-7-3Z"></path>
              <path d="m9.5 12 1.8 1.8L15 10.5"></path>
            </svg>
          </span>
          <span>{{ section.settings.trust_two | escape }}</span>
        </div>
        <div class="clutch-home-hero__trust-item">
          <span class="clutch-home-hero__trust-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 21s-6-4.35-6-10a6 6 0 1 1 12 0c0 5.65-6 10-6 10Z"></path>
              <path d="M12 13.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"></path>
            </svg>
          </span>
          <span>{{ section.settings.trust_three | escape }}</span>
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Social proof text",
      "default": "4.8 Stars, Trusted By Hundreds Of Barbers Worldwide"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Built for Dallas barbers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Barber Supplies, When And Where You Need Them"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Clippers, trimmers, and essentials. Everything you need to stay sharp — available online or in-store."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button",
      "default": "Shop By Brand"
    },
    {
      "type": "url",
      "id": "primary_button_url",
      "label": "Primary URL"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button",
      "default": "What Customers Say"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Secondary URL"
    },
    {
      "type": "text",
      "id": "trust_one",
      "label": "Trust 1",
      "default": "Fast Shipping Across the U.S."
    },
    {
      "type": "text",
      "id": "trust_two",
      "label": "Trust 2",
      "default": "Top Brands In Stock & Ready"
    },
    {
      "type": "text",
      "id": "trust_three",
      "label": "Trust 3",
      "default": "Local Pickup Available in Dallas"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
