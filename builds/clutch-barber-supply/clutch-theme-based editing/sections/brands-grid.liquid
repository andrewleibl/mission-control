<section class="clutch-home-section clutch-home-brands" id="brands">
  <!-- Copper Glow Effects -->
  <div class="clutch-home-brands__glow clutch-home-brands__glow--top" aria-hidden="true"></div>
  <div class="clutch-home-brands__glow clutch-home-brands__glow--bottom" aria-hidden="true"></div>
  <div class="clutch-home-section__inner">
    <header class="clutch-home-section__header">
      <p class="clutch-home-section__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="clutch-home-section__title">{{ section.settings.title }}</h2>
      <p class="clutch-home-section__subtitle">{{ section.settings.subtitle }}</p>
    </header>

    <div class="clutch-home-brands__grid">
      <a href="/collections/all?vendor=Gamma%20%7C%20Style%20Craft" class="clutch-home-brands__item" data-brand-filter>
        <img src="{{ 'gamma-logo.png' | asset_url }}" alt="Gamma+" class="clutch-home-brands__logo-img" loading="lazy">
      </a>
      <a href="/collections/all?vendor=TPOB" class="clutch-home-brands__item" data-brand-filter>
        <span class="clutch-home-brands__text-logo clutch-home-brands__text-logo--tpob">TPOB</span>
      </a>
      <a href="/collections/all?vendor=JRL" class="clutch-home-brands__item" data-brand-filter>
        <img src="{{ 'jrl-logo.png' | asset_url }}" alt="JRL" class="clutch-home-brands__logo-img" loading="lazy">
      </a>
      <a href="/collections/all?vendor=Wahl" class="clutch-home-brands__item" data-brand-filter>
        <img src="{{ 'wahl-logo.png' | asset_url }}" alt="Wahl" class="clutch-home-brands__logo-img" loading="lazy">
      </a>
      <a href="/collections/all?vendor=Level%203" class="clutch-home-brands__item" data-brand-filter>
        <img src="{{ 'level3-logo.png' | asset_url }}" alt="Level 3" class="clutch-home-brands__logo-img clutch-home-brands__logo-img--large" loading="lazy">
      </a>
      <a href="/collections/all?vendor=Babyliss%20Pro" class="clutch-home-brands__item" data-brand-filter>
        <img src="{{ 'brand-logo.png' | asset_url }}" alt="BaByliss Pro" class="clutch-home-brands__logo-img clutch-home-brands__logo-img--small" loading="lazy">
      </a>
      <a href="/collections/all?vendor=Andis" class="clutch-home-brands__item" data-brand-filter>
        <img src="{{ 'andis-logo.png' | asset_url }}" alt="Andis" class="clutch-home-brands__logo-img clutch-home-brands__logo-img--medium" loading="lazy">
      </a>
      <a href="/collections/all?vendor=Cocco%20Hair%20Pro" class="clutch-home-brands__item" data-brand-filter>
        <img src="{{ 'cocco-logo.png' | asset_url }}" alt="Cocco" class="clutch-home-brands__logo-img" loading="lazy">
      </a>

      <a href="/collections/all?vendor=Supreme" class="clutch-home-brands__item" data-brand-filter>
        <img src="{{ 'supreme-logo.png' | asset_url }}" alt="Supreme" class="clutch-home-brands__logo-img" loading="lazy">
      </a>
    </div>
  </div>
</section>

<style>
.clutch-home-brands {
  background: linear-gradient(180deg, var(--clutch-bg-light) 0%, var(--clutch-bg) 100%);
}

.clutch-home-brands__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}

@media (min-width: 768px) {
  .clutch-home-brands__grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
}

.clutch-home-brands__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  aspect-ratio: 16/10;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 20px;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  padding: 1.5rem;
}

.clutch-home-brands__item:hover {
  border-color: var(--clutch-accent);
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(201, 137, 75, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.clutch-home-brands__item::after {
  content: 'Shop Now →';
  position: absolute;
  bottom: 1.25rem;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--clutch-accent);
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.35s ease;
}

.clutch-home-brands__item:hover::after {
  opacity: 1;
  transform: translateY(0);
}

.clutch-home-brands__logo-img {
  max-width: 90%;
  max-height: 65px;
  width: auto;
  height: auto;
  object-fit: contain;
  transition: transform 0.35s ease;
  display: block;
  margin: auto;
}

.clutch-home-brands__item:hover .clutch-home-brands__logo-img {
  transform: scale(1.05);
}

/* Brand-specific sizing matching original */
.clutch-home-brands__logo-img--small {
  max-height: 50px;
}

.clutch-home-brands__logo-img--medium {
  max-height: 110px;
}

.clutch-home-brands__logo-img--large {
  max-height: 150px;
}

.clutch-home-brands__text-logo {
  font-size: 2rem;
  font-weight: 700;
  color: var(--clutch-text);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  transition: transform 0.35s ease;
}

.clutch-home-brands__text-logo--tpob {
  font-size: 1.6rem;
}
</style>

{% schema %}
{
  "name": "Brands Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Shop by brand",
      "label": "Eyebrow Text"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Shop the Big Brands",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "default": "The brands barbers swear by, ready for pickup today",
      "label": "Subtitle"
    }
  ],
  "presets": [
    {
      "name": "Brands Grid"
    }
  ]
}
{% endschema %}
