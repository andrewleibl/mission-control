{% comment %} Classes Section - Simplified {% endcomment %}
<div class="page-header">
  <h1>Classes</h1>
  <p>Learn from the best. Hands-on training with industry professionals.</p>
</div>

<section class="classes-section">
  <div class="classes-container">
    {% for block in section.blocks %}
      <div class="class-card" {{ block.shopify_attributes }}>
        {% if block.settings.date_badge != blank %}
          <span class="class-date-badge">{{ block.settings.date_badge }}</span>
        {% endif %}
        
        <div class="class-image">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" loading="lazy">
          {% else %}
            <div class="class-image-placeholder">Class Image</div>
          {% endif %}
        </div>
        
        <div class="class-content">
          <div class="class-meta">
            <span class="class-type">{{ block.settings.class_type }}</span>
            <span class="class-separator">•</span>
            <span class="class-time">{{ block.settings.time }}</span>
          </div>
          
          <h2 class="class-title">{{ block.settings.title }}</h2>
          <p class="class-description">{{ block.settings.description }}</p>
          
          <div class="class-footer">
            <span class="class-price">{{ block.settings.price }}</span>
            <a href="{{ block.settings.product_link }}" class="class-link">Product Page →</a>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<style>
.classes-section {
  padding: 2rem 0 6rem;
  background: var(--clutch-bg);
}

.classes-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

@media (min-width: 900px) {
  .classes-container {
    grid-template-columns: repeat(2, 1fr);
  }
}

.class-card {
  position: relative;
  background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.35s ease;
}

.class-card:hover {
  transform: translateY(-6px);
  border-color: rgba(201, 137, 75, 0.4);
  box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}

.class-date-badge {
  position: absolute;
  top: 1rem;
  left: 1rem;
  z-index: 10;
  padding: 0.5rem 1rem;
  background: var(--clutch-accent);
  color: var(--clutch-bg);
  border-radius: 50px;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.class-image {
  aspect-ratio: 1/1.1;
  background: var(--clutch-bg-lighter);
  overflow: hidden;
}

.class-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.class-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--clutch-text-dim);
  font-size: 0.9375rem;
}

.class-content {
  padding: 1.5rem;
}

.class-meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
  font-size: 0.8125rem;
}

.class-type {
  color: var(--clutch-accent);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.class-separator {
  color: var(--clutch-text-dim);
}

.class-time {
  color: var(--clutch-text-muted);
}

.class-title {
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 0.75rem;
  line-height: 1.3;
}

.class-description {
  color: var(--clutch-text-muted);
  font-size: 0.9375rem;
  line-height: 1.6;
  margin-bottom: 1.25rem;
}

.class-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 1rem;
  border-top: 1px solid var(--clutch-border);
}

.class-price {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--clutch-accent);
}

.class-link {
  color: var(--clutch-text-muted);
  font-size: 0.875rem;
  text-decoration: none;
  transition: color 0.2s;
}

.class-link:hover {
  color: var(--clutch-accent);
}
</style>

{% schema %}
{
  "name": "Classes Section",
  "tag": "section",
  "class": "section",
  "max_blocks": 2,
  "settings": [],
  "blocks": [
    {
      "type": "class",
      "name": "Class",
      "settings": [
        {
          "type": "text",
          "id": "date_badge",
          "default": "APRIL 12",
          "label": "Date Badge"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Class Image"
        },
        {
          "type": "text",
          "id": "class_type",
          "default": "IN-PERSON",
          "label": "Class Type"
        },
        {
          "type": "text",
          "id": "time",
          "default": "9AM - 3PM",
          "label": "Time"
        },
        {
          "type": "text",
          "id": "title",
          "default": "TDLR CE Shear Class",
          "label": "Class Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "default": "Master the art of seamless fades and blends with professional instruction. Perfect for barbers looking to elevate their craft with precision cutting and clipper control techniques.",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "price",
          "default": "$299",
          "label": "Price"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Product Page Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Classes Section"
    }
  ]
}
{% endschema %}