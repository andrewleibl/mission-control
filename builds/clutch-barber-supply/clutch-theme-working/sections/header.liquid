<header class="clutch-home-header" data-section-id="{{ section.id }}" data-section-type="header">
  <div class="clutch-home-header__inner">
    <div class="clutch-home-header__left">
      {% comment %} Mobile cart (shown only on mobile) {% endcomment %}
      <a href="{{ routes.cart_url }}" class="clutch-home-header__cart mobile-cart" aria-label="Cart">
        <svg viewBox="0 0 24 24"><path d="M3 5h2l2.1 9.2a1 1 0 0 0 1 .8H18a1 1 0 0 0 1-.8L21 8H7"></path><circle cx="9" cy="19" r="1.5"></circle><circle cx="17" cy="19" r="1.5"></circle></svg>
        {% if cart.item_count > 0 %}
          <span class="cart-badge">{{ cart.item_count }}</span>
        {% else %}
          <span class="cart-badge" style="display: none;">0</span>
        {% endif %}
      </a>
      
      <button class="clutch-home-header__menu" aria-label="Open menu" onclick="document.getElementById('mobileNav').classList.add('active'); document.getElementById('mobileNavOverlay').classList.add('active');">
        <span></span><span></span><span></span>
      </button>
      <div class="clutch-home-header__search">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input type="search" name="q" placeholder="Search" value="{{ search.terms | escape }}" aria-label="Search">
        </form>
      </div>
    </div>
    
    <a href="{{ routes.root_url }}" class="clutch-home-header__logo">
      <img src="{{ 'clutch-logo.png' | asset_url }}" alt="{{ shop.name }}" width="150" height="60" loading="eager">
    </a>
    
    <div class="clutch-home-header__right">
      {% comment %} Mobile-only elements {% endcomment %}
      <a href="{{ routes.search_url }}" class="mobile-search-icon" aria-label="Search">
        <svg viewBox="0 0 24 24" width="20" height="20"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2" fill="none"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2"/></svg>
      </a>
      <button class="mobile-menu-btn" aria-label="Open menu" onclick="document.getElementById('mobileNav').classList.add('active'); document.getElementById('mobileNavOverlay').classList.add('active');">
        <span></span><span></span><span></span>
      </button>
      
      <nav class="clutch-home-header__desktop-nav">
        <a href="{{ routes.all_products_collection_url }}">Shop</a>
        
        <div class="clutch-home-header__dropdown">
          <a href="/pages/brands">Brands</a>
          <div class="clutch-home-header__dropdown-menu">
            <a href="/collections/all-products?vendor=Gamma%20%7C%20Style%20Craft" class="clutch-home-header__dropdown-item">Gamma+</a>
            <a href="/collections/all-products?vendor=TPOB" class="clutch-home-header__dropdown-item">TPOB</a>
            <a href="/collections/all-products?vendor=JRL" class="clutch-home-header__dropdown-item">JRL</a>
            <a href="/collections/all-products?vendor=Wahl" class="clutch-home-header__dropdown-item">Wahl</a>
            <a href="/collections/all-products?vendor=Level%203" class="clutch-home-header__dropdown-item">Level 3</a>
            <a href="/collections/all-products?vendor=Babyliss%20Pro" class="clutch-home-header__dropdown-item">BaByliss Pro</a>
            <a href="/collections/all-products?vendor=Andis" class="clutch-home-header__dropdown-item">Andis</a>
            <a href="/collections/all-products?vendor=Cocco%20Hair%20Pro" class="clutch-home-header__dropdown-item">Cocco</a>
            <a href="/collections/all-products?vendor=Supreme" class="clutch-home-header__dropdown-item">Supreme</a>
            <a href="/collections/all-products?vendor=Oster" class="clutch-home-header__dropdown-item">Oster</a>
            <a href="/collections/all-products?vendor=Tomb45" class="clutch-home-header__dropdown-item">Tomb45</a>
            <a href="/collections/all-products?vendor=Vincent" class="clutch-home-header__dropdown-item">Vincent</a>
            <a href="/collections/all-products?vendor=OG%20Walker" class="clutch-home-header__dropdown-item">OG Walker</a>
            <a href="/collections/all-products?vendor=Smash" class="clutch-home-header__dropdown-item">Smash</a>
            <a href="/collections/all-products?vendor=Rolda" class="clutch-home-header__dropdown-item">Rolda</a>
          </div>
        </div>
        
        <div class="clutch-home-header__dropdown">
          <a href="/pages/supplies">Supplies</a>
          <div class="clutch-home-header__dropdown-menu">
            <a href="/collections/all-products?category=clippers" class="clutch-home-header__dropdown-item">Clippers</a>
            <a href="/collections/all-products?category=trimmers" class="clutch-home-header__dropdown-item">Trimmers</a>
            <a href="/collections/all-products?category=shavers" class="clutch-home-header__dropdown-item">Shavers</a>
            <a href="/collections/all-products?category=barber-bags-cases" class="clutch-home-header__dropdown-item">Barber Bags | Cases</a>
            <a href="/collections/all-products?category=lights" class="clutch-home-header__dropdown-item">Lights</a>
            <a href="/collections/all-products?category=accessories" class="clutch-home-header__dropdown-item">Accessories</a>
            <a href="/collections/all-products?category=capes" class="clutch-home-header__dropdown-item">Capes</a>
            <a href="/collections/all-products?category=barber-chairs" class="clutch-home-header__dropdown-item">Barber Chairs</a>
          </div>
        </div>
        
        <a href="/pages/classes">Classes</a>
        <a href="/pages/contact">Contact</a>
        <a href="/pages/faq">FAQ</a>
        <a href="/pages/reviews">Reviews</a>
      </nav>
      
      <a href="{{ routes.cart_url }}" class="clutch-home-header__cart" aria-label="Cart">
        <svg viewBox="0 0 24 24"><path d="M3 5h2l2.1 9.2a1 1 0 0 0 1 .8H18a1 1 0 0 0 1-.8L21 8H7"></path><circle cx="9" cy="19" r="1.5"></circle><circle cx="17" cy="19" r="1.5"></circle></svg>
        {% if cart.item_count > 0 %}
          <span class="cart-badge">{{ cart.item_count }}</span>
        {% else %}
          <span class="cart-badge" style="display: none;">0</span>
        {% endif %}
      </a>
    </div>
  </div>
</header>

<!-- MOBILE NAVIGATION DRAWER -->
<div class="clutch-mobile-nav" id="mobileNav">
  <div class="clutch-mobile-nav__header">
    <button class="clutch-mobile-nav__close" onclick="document.getElementById('mobileNav').classList.remove('active'); document.getElementById('mobileNavOverlay').classList.remove('active');" aria-label="Close menu">
      <svg viewBox="0 0 24 24" width="24" height="24"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" fill="none"/></svg>
    </button>
  </div>
  <nav class="clutch-mobile-nav__links">
    <a href="{{ routes.all_products_collection_url }}">Shop</a>
    <a href="/pages/brands">Brands</a>
    <a href="/pages/supplies">Supplies</a>
    <a href="/pages/classes">Classes</a>
    <a href="/pages/contact">Contact</a>
    <a href="/pages/faq">FAQ</a>
    <a href="/pages/reviews">Reviews</a>
  </nav>
  <div class="clutch-mobile-nav__footer">
    <a href="{{ routes.cart_url }}" class="clutch-mobile-nav__cart">
      <svg viewBox="0 0 24 24" width="20" height="20"><path d="M3 5h2l2.1 9.2a1 1 0 0 0 1 .8H18a1 1 0 0 0 1-.8L21 8H7"></path><circle cx="9" cy="19" r="1.5"></circle><circle cx="17" cy="19" r="1.5"></circle></svg>
      Cart
    </a>
  </div>
</div>
<div class="clutch-mobile-nav__overlay" id="mobileNavOverlay" onclick="document.getElementById('mobileNav').classList.remove('active'); document.getElementById('mobileNavOverlay').classList.remove('active');"></div>

<style>
/* Mobile-only elements - hidden on desktop */
.mobile-search-icon,
.mobile-menu-btn,
.mobile-cart {
  display: none;
}

/* Mobile Header Restructuring - Desktop untouched */
@media (max-width: 1024px) {
  /* Show mobile elements */
  .mobile-search-icon,
  .mobile-menu-btn,
  .mobile-cart {
    display: flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--clutch-border);
    border-radius: 8px;
    color: var(--clutch-paper);
    cursor: pointer;
    position: relative;
  }

  .mobile-menu-btn {
    flex-direction: column;
    gap: 5px;
  }

  .mobile-menu-btn span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--clutch-paper);
    border-radius: 1px;
  }

  /* Header layout: Cart | Logo | Search + Menu */
  .clutch-home-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Left section: Show mobile cart, hide desktop elements */
  .clutch-home-header__left {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
  }

  /* Hide desktop menu button from left */
  .clutch-home-header__left > .clutch-home-header__menu {
    display: none !important;
  }

  /* Hide desktop search form from left */
  .clutch-home-header__left > .clutch-home-header__search {
    display: none;
  }

  /* Center: Logo */
  .clutch-home-header__logo {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  /* Right section: Search + Menu + Desktop cart (hide desktop cart) */
  .clutch-home-header__right {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Hide desktop nav links */
  .clutch-home-header__desktop-nav {
    display: none !important;
  }

  /* Hide desktop cart on right side (mobile cart is on left) */
  .clutch-home-header__right > .clutch-home-header__cart {
    display: none !important;
  }

  /* Mobile Nav - Slide from RIGHT (not left) */
  .clutch-mobile-nav {
    left: auto;
    right: 0;
    transform: translateX(100%);
    border-right: none;
    border-left: 1px solid var(--clutch-border);
    z-index: 3000;
  }

  .clutch-mobile-nav.active {
    transform: translateX(0);
  }

  /* Mobile Nav Header - Just close button, no title */
  .clutch-mobile-nav__header {
    display: flex;
    justify-content: flex-end;
    padding: 1rem;
    border-bottom: 1px solid var(--clutch-border);
  }

  /* Ensure overlay is above everything */
  .clutch-mobile-nav__overlay {
    z-index: 2999;
  }

  /* Ensure header doesn't block the menu */
  .clutch-home-header {
    z-index: 1000;
  }
}
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu (Note: Hardcoded nav shown above)"
    }
  ]
}
{% endschema %}