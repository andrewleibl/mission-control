/* Clutch Barber Supply Theme CSS - Combined from TIGHT-NAV */

:root {
  --clutch-copper: #c9894b;
  --clutch-copper-soft: #e0b07d;
  --clutch-ink: #05070c;
  --clutch-navy: #091018;
  --clutch-navy-2: #0f1a25;
  --clutch-paper: #f5efe3;
  --clutch-muted: #b5aa97;
  --clutch-border: rgba(255, 255, 255, 0.12);
  --clutch-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
  /* Legacy vars */
  --clutch-bg: #05070c;
  --clutch-bg-light: #091018;
  --clutch-bg-lighter: #0d1822;
  --clutch-text: #f5efe3;
  --clutch-text-muted: #d1c7b3;
  --clutch-text-dim: #9ca3af;
  --clutch-accent: #c9894b;
  --clutch-accent-hover: #d89a5c;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
  background: var(--clutch-bg);
  color: var(--clutch-text);
  line-height: 1.5;
}

a { color: inherit; text-decoration: none; }

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* TOP NOTE */
.clutch-top-note {
  position: sticky;
  top: 0;
  z-index: 1200;
  background: var(--clutch-ink);
  color: var(--clutch-paper);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.clutch-top-note__text {
  margin: 0;
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-align: center;
  padding: 0.75rem 1rem;
}

.clutch-top-note__dot {
  color: var(--clutch-copper);
  margin: 0 0.45rem;
}

/* HEADER */
.clutch-home-header {
  position: sticky;
  top: 0;
  z-index: 9999;
  color: var(--clutch-paper);
  background: var(--clutch-navy);
  border-bottom: 1px solid var(--clutch-border);
}

.clutch-home-header__inner {
  width: min(100%, 1400px);
  margin: 0 auto;
  padding: 0.75rem 2rem;
  display: grid;
  grid-template-columns: 280px auto 1fr;
  align-items: center;
  gap: 1.5rem;
}

.clutch-home-header__left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.clutch-home-header__right {
  display: flex;
  align-items: center;
  gap: 1rem;
  justify-content: flex-end;
}

.clutch-home-header__logo {
  justify-self: start;
  padding-left: 1rem;
}

.clutch-home-header__logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clutch-home-header__logo img {
  height: 60px;
  width: auto;
  max-width: 150px;
  object-fit: contain;
}

.clutch-home-header__menu {
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5px;
  width: 44px;
  height: 44px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  cursor: pointer;
}

.clutch-home-header__menu span {
  display: block;
  width: 18px;
  height: 2px;
  background: var(--clutch-paper);
  border-radius: 1px;
}

@media (max-width: 1024px) {
  .clutch-home-header__desktop-nav {
    display: none;
  }
  .clutch-home-header__search {
    display: none;
  }
  .clutch-home-header__menu {
    display: flex;
  }
}

.clutch-home-header__search input {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  padding: 0.625rem 1rem;
  color: var(--clutch-paper);
  font-size: 0.875rem;
  width: 240px;
}

.clutch-home-header__desktop-nav {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.clutch-home-header__desktop-nav a {
  font-size: 0.8125rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--clutch-paper);
  transition: color 0.2s;
}

.clutch-home-header__desktop-nav a:hover {
  color: var(--clutch-copper);
}

.clutch-home-header__dropdown {
  position: relative;
}

.clutch-home-header__dropdown-menu {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  margin-top: 0.75rem;
  background: var(--clutch-navy);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  padding: 0.75rem 0;
  min-width: 200px;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
  z-index: 1000;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
}

.clutch-home-header__dropdown:hover .clutch-home-header__dropdown-menu {
  opacity: 1;
  visibility: visible;
}

.clutch-home-header__dropdown-menu a {
  display: block;
  padding: 0.625rem 1.25rem;
  font-size: 0.875rem;
  color: var(--clutch-paper);
}

.clutch-home-header__dropdown-menu a:hover {
  color: var(--clutch-copper);
  background: rgba(201, 137, 75, 0.125);
}

.clutch-home-header__cart {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  color: var(--clutch-paper);
}

.clutch-home-header__cart svg {
  width: 20px;
  height: 20px;
  stroke: currentColor;
  stroke-width: 2;
  fill: none;
}

/* Cart Badge */
.cart-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--clutch-copper);
  color: var(--clutch-ink);
  font-size: 0.6875rem;
  font-weight: 700;
  border-radius: 10px;
  padding: 0 5px;
}

.clutch-home-header__cart {
  position: relative;
}

/* Mobile Nav */
.clutch-mobile-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 300px;
  height: 100vh;
  background: var(--clutch-navy);
  border-right: 1px solid var(--clutch-border);
  z-index: 2000;
  transform: translateX(-100%);
  transition: transform 0.3s ease;
}

.clutch-mobile-nav.active {
  transform: translateX(0);
}

.clutch-mobile-nav__links a {
  display: block;
  padding: 1rem 1.25rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  color: var(--clutch-paper);
}

.clutch-mobile-nav__overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.clutch-mobile-nav__overlay.active {
  opacity: 1;
  visibility: visible;
}

/* HERO */
.clutch-home-hero {
  position: relative;
  min-height: calc(100vh - 114px);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: linear-gradient(180deg, var(--clutch-ink) 0%, var(--clutch-navy) 100%);
  overflow: hidden;
}

.clutch-home-hero__media {
  position: absolute;
  inset: 0;
}

.clutch-home-hero__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.5;
}

.clutch-home-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(5, 7, 12, 0.2) 0%, rgba(9, 16, 24, 0.1) 100%);
}

.clutch-home-hero__content {
  position: relative;
  z-index: 1;
  max-width: 850px;
  padding: 4rem 1.5rem;
}

.clutch-home-hero__social-proof {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  margin-bottom: 2rem;
  padding: 0.625rem 1.25rem;
  background: rgba(201, 137, 75, 0.125);
  border: 1px solid rgba(201, 137, 75, 0.31);
  border-radius: 50px;
}

.clutch-home-hero__stars {
  display: flex;
  gap: 0.1875rem;
}

.clutch-home-hero__stars svg {
  width: 1.125rem;
  height: 1.125rem;
  fill: var(--clutch-accent);
}

.clutch-home-hero__social-text {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--clutch-text);
}

.clutch-home-hero h1 {
  font-size: clamp(2.25rem, 6vw, 4rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.05;
  margin-bottom: 1.25rem;
}

.clutch-home-hero__subheading {
  font-size: clamp(1.0625rem, 2vw, 1.375rem);
  color: var(--clutch-text-muted);
  margin-bottom: 2.5rem;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.clutch-home-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
  margin-bottom: 3.5rem;
}

.clutch-home-hero__trust {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2rem;
}

.clutch-home-hero__trust-item {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
}

.clutch-home-hero__trust-icon {
  width: 1.5rem;
  height: 1.5rem;
}

.clutch-home-hero__trust-icon svg {
  width: 1.25rem;
  height: 1.25rem;
  stroke: var(--clutch-accent);
}

/* Copper Glow Effects for Hero - INTENSIFIED */
.clutch-home-hero__glow {
  position: absolute;
  pointer-events: none;
  z-index: 0;
}

.clutch-home-hero__glow--top-left {
  top: -250px;
  left: -250px;
  width: 800px;
  height: 800px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.69) 0%, rgba(201, 137, 75, 0.2) 35%, rgba(201, 137, 75, 0.063) 60%, transparent 80%);
  filter: blur(100px);
}

.clutch-home-hero__glow--bottom-right {
  bottom: -200px;
  right: -200px;
  width: 700px;
  height: 700px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.56) 0%, rgba(201, 137, 75, 0.15) 40%, rgba(201, 137, 75, 0.03) 65%, transparent 85%);
  filter: blur(120px);
}

/* BUTTONS */
.clutch-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 1rem 2rem;
  font-size: 0.9375rem;
  font-weight: 600;
  border-radius: 12px;
  transition: all 0.3s;
  letter-spacing: 0.01em;
}

.clutch-button--primary {
  background: linear-gradient(135deg, var(--clutch-accent) 0%, #b87a3e 100%);
  color: var(--clutch-bg);
  box-shadow: 0 4px 14px rgba(201, 137, 75, 0.31);
}

.clutch-button--primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 28px rgba(201, 137, 75, 0.50);
}

.clutch-button--ghost {
  background: rgba(255, 255, 255, 0.05);
  color: var(--clutch-text);
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.clutch-button--ghost:hover {
  border-color: var(--clutch-accent);
  background: rgba(201, 137, 75, 0.125);
  color: var(--clutch-accent);
  transform: translateY(-2px);
}

.clutch-button--copper {
  background: linear-gradient(135deg, var(--clutch-accent) 0%, var(--clutch-accent-hover) 100%);
  color: var(--clutch-bg);
  font-size: 0.8125rem;
  padding: 0.625rem 1rem;
  border-radius: 8px;
  width: 100%;
}

.clutch-button--copper:hover {
  box-shadow: 0 18px 34px rgba(201, 137, 75, 0.375);
}

/* SECTION STYLES */
.clutch-home-section {
  padding: 5rem 0;
  background: linear-gradient(180deg, var(--clutch-bg) 0%, var(--clutch-bg-light) 100%);
}

.clutch-home-section__inner {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.clutch-home-section__header {
  text-align: center;
  margin-bottom: 3rem;
}

.clutch-home-section__eyebrow {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--clutch-accent);
  margin-bottom: 0.75rem;
}

.clutch-home-section__title {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
}

.clutch-home-section__subtitle {
  font-size: 1.0625rem;
  color: var(--clutch-text-muted);
  max-width: 520px;
  margin: 0 auto;
}

/* FEATURED PRODUCTS */
.clutch-home-featured-products {
  background: var(--clutch-bg);
  position: relative;
  overflow: hidden;
}

/* Copper Glow Effects for Featured Products */
.clutch-home-featured-products__glow {
  position: absolute;
  pointer-events: none;
  z-index: 0;
}

.clutch-home-featured-products__glow--left {
  top: 50%;
  left: -200px;
  transform: translateY(-50%);
  width: 400px;
  height: 600px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.125) 45%, transparent 70%);
  filter: blur(100px);
}

.clutch-home-featured-products__glow--right {
  top: 30%;
  right: -150px;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.375) 0%, rgba(201, 137, 75, 0.10) 50%, transparent 70%);
  filter: blur(120px);
}

.clutch-home-products__grid {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 1.5rem;
}

@media (min-width: 640px) {
  .clutch-home-products__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .clutch-home-products__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.clutch-home-products__card {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.35s;
}

.clutch-home-products__card:hover {
  transform: translateY(-6px);
  border-color: rgba(201, 137, 75, 0.50);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
}

.clutch-home-products__image-link {
  display: block;
  aspect-ratio: 1;
  background: rgba(255, 255, 255, 0.05);
  position: relative;
}

.clutch-home-products__image-link img {
  max-width: 80%;
  max-height: 80%;
  object-fit: contain;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.clutch-home-products__image--placeholder {
  display: grid;
  place-items: center;
  height: 100%;
  color: var(--clutch-text-dim);
  font-size: 0.875rem;
}

.clutch-home-products__body {
  padding: 1.25rem;
}

.clutch-home-products__brand {
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--clutch-accent);
  margin-bottom: 0.25rem;
}

.clutch-home-products__name {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.clutch-home-products__name a:hover {
  color: var(--clutch-accent);
}

.clutch-home-products__price {
  font-size: 1.125rem;
  font-weight: 700;
  margin-bottom: 1rem;
}

/* BRANDS GRID */
.clutch-home-brands {
  background: linear-gradient(180deg, var(--clutch-bg-light) 0%, var(--clutch-bg) 100%);
  position: relative;
  overflow: hidden;
}

/* Copper Glow Effects for Brands */
.clutch-home-brands__glow {
  position: absolute;
  pointer-events: none;
  z-index: 0;
}

.clutch-home-brands__glow--top {
  top: -150px;
  left: 50%;
  transform: translateX(-50%);
  width: 1000px;
  height: 500px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.50) 0%, rgba(201, 137, 75, 0.12) 45%, rgba(201, 137, 75, 0.03) 70%, transparent 85%);
  filter: blur(100px);
}

.clutch-home-brands__glow--bottom {
  bottom: -150px;
  right: 10%;
  width: 700px;
  height: 500px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.125) 45%, rgba(201, 137, 75, 0.02) 70%, transparent 90%);
  filter: blur(120px);
}

.clutch-home-brands__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

@media (min-width: 768px) {
  .clutch-home-brands__grid {
    gap: 1.5rem;
  }
}

.clutch-home-brands__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  aspect-ratio: 16/10;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 20px;
  transition: all 0.35s;
  position: relative;
  overflow: hidden;
}

.clutch-home-brands__item:hover {
  border-color: var(--clutch-accent);
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
}

.clutch-home-brands__logo-img {
  max-width: 90%;
  max-height: 65px;
  width: auto;
  height: auto;
  object-fit: contain;
  transition: transform 0.35s ease;
}

.clutch-home-brands__item:hover .clutch-home-brands__logo-img {
  transform: scale(1.05);
}

/* REVIEWS MARQUEE */
.clutch-home-reviews {
  background: linear-gradient(180deg, var(--clutch-bg) 0%, var(--clutch-bg-lighter) 50%, var(--clutch-bg) 100%);
  position: relative;
  overflow: hidden;
}

/* Copper Glow Effects for Reviews */
.clutch-home-reviews__glow {
  position: absolute;
  pointer-events: none;
  z-index: 0;
}

.clutch-home-reviews__glow--top {
  top: -100px;
  left: 20%;
  width: 600px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.50) 0%, rgba(201, 137, 75, 0.12) 45%, transparent 70%);
  filter: blur(100px);
}

.clutch-home-reviews__glow--center {
  top: 40%;
  left: 60%;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.31) 0%, rgba(201, 137, 75, 0.063) 50%, transparent 70%);
  filter: blur(120px);
}

.clutch-home-reviews__marquee {
  overflow: hidden;
  position: relative;
  width: 100%;
  padding: 0.5rem 0;
}

.clutch-home-reviews__track {
  display: flex;
  gap: 1.25rem;
  animation: marquee-scroll 40s linear infinite;
  width: max-content;
}

.clutch-home-reviews__marquee:hover .clutch-home-reviews__track {
  animation-play-state: paused;
}

@keyframes marquee-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.clutch-home-reviews__card-link {
  display: block;
  text-decoration: none;
  color: inherit;
  cursor: pointer;
  transition: transform 0.3s ease;
  flex-shrink: 0;
  width: 350px;
}

@media (min-width: 640px) {
  .clutch-home-reviews__card-link {
    width: 400px;
  }
}

.clutch-home-reviews__card-link:hover {
  transform: translateY(-3px);
}

.clutch-home-reviews__card-link:hover .clutch-home-reviews__card {
  border-color: rgba(201, 137, 75, 0.5);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

.clutch-home-reviews__card {
  padding: 1.75rem;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 20px;
  transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.3s ease;
  height: 100%;
  position: relative;
}

.clutch-home-reviews__card::before {
  content: '"';
  position: absolute;
  top: 1rem;
  right: 1.25rem;
  font-size: 3rem;
  color: rgba(201, 137, 75, 0.15);
  font-family: Georgia, serif;
  line-height: 1;
}

.clutch-home-reviews__stars {
  color: var(--clutch-accent);
  font-size: 0.9375rem;
  letter-spacing: 0.15em;
  margin-bottom: 1rem;
}

.clutch-home-reviews__name {
  font-size: 0.9375rem;
  font-weight: 600;
  margin-bottom: 0.75rem;
}

.clutch-home-reviews__quote {
  font-size: 0.9375rem;
  color: var(--clutch-text-muted);
  line-height: 1.7;
  font-style: italic;
}

.clutch-home-section__hint {
  text-align: center;
  margin-top: 1.5rem;
  font-size: 0.875rem;
  color: var(--clutch-text-dim);
}

/* TRUST BAR */
.clutch-home-trust-bar {
  background: var(--clutch-bg-light);
  border-top: 1px solid var(--clutch-border);
  border-bottom: 1px solid var(--clutch-border);
  padding: 2rem 0;
  position: relative;
  overflow: hidden;
}

/* Copper Glow Effect for Trust Bar */
.clutch-home-trust-bar__glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1200px;
  height: 300px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.2) 0%, rgba(201, 137, 75, 0.063) 50%, transparent 70%);
  filter: blur(80px);
  pointer-events: none;
  z-index: 0;
}

.clutch-home-trust-bar__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .clutch-home-trust-bar__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.clutch-home-trust-bar__item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
}

.clutch-home-trust-bar__icon {
  width: 2.5rem;
  height: 2.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 137, 75, 0.125);
  border-radius: 8px;
}

.clutch-home-trust-bar__icon svg {
  width: 1.25rem;
  height: 1.25rem;
  stroke: var(--clutch-accent);
  stroke-width: 1.5;
  fill: none;
}

.clutch-home-trust-bar__text {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--clutch-text-muted);
}

/* NEWSLETTER */
.clutch-home-email {
  background: linear-gradient(180deg, var(--clutch-bg) 0%, var(--clutch-bg-lighter) 50%, var(--clutch-bg) 100%);
  padding: 5rem 0;
  position: relative;
  overflow: hidden;
}

/* Copper Glow Effects for Newsletter - INTENSIFIED */
.clutch-home-email::before {
  content: '';
  position: absolute;
  top: 10%;
  left: 5%;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.125) 40%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

.clutch-home-email::after {
  content: '';
  position: absolute;
  bottom: 10%;
  right: 5%;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.31) 0%, rgba(201, 137, 75, 0.063) 50%, transparent 70%);
  filter: blur(80px);
  pointer-events: none;
  z-index: 0;
}

.clutch-home-email__content {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
}

.clutch-home-email__title {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 700;
  margin-bottom: 1rem;
}

.clutch-home-email__subtitle {
  font-size: 1.0625rem;
  color: var(--clutch-text-muted);
  margin-bottom: 2rem;
}

.clutch-home-email__input-group {
  display: flex;
  gap: 0.75rem;
  max-width: 500px;
  margin: 0 auto 1rem;
}

.clutch-home-email__input-group input {
  flex: 1;
  padding: 1rem 1.25rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  color: var(--clutch-text);
  font-size: 1rem;
}

.clutch-home-email__input-group input:focus {
  outline: none;
  border-color: var(--clutch-accent);
}

.clutch-home-email__disclaimer {
  font-size: 0.8125rem;
  color: var(--clutch-text-dim);
}

/* COLLECTION PAGE - Shop */
.page-header {
  padding: 3rem 1.5rem 2rem;
  text-align: center;
  background: linear-gradient(180deg, var(--clutch-bg-light) 0%, var(--clutch-bg) 100%);
  border-bottom: 1px solid var(--clutch-border);
}

.page-header h1 {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-bottom: 0.5rem;
}

.breadcrumbs {
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
}

.breadcrumbs a {
  color: var(--clutch-accent);
  transition: opacity 0.2s;
}

.breadcrumbs a:hover {
  opacity: 0.8;
}

.breadcrumbs span {
  margin: 0 0.5rem;
}

/* Collection Layout */
.collection-layout {
  max-width: 1400px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 2rem;
}

@media (max-width: 900px) {
  .collection-layout {
    grid-template-columns: 1fr;
  }
}

/* Sidebar Filters */
.filters-sidebar {
  position: sticky;
  top: 120px;
  height: fit-content;
  background: var(--clutch-bg-light);
  border: 1px solid var(--clutch-border);
  border-radius: 16px;
  padding: 1.5rem;
}

@media (max-width: 900px) {
  .filters-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 300px;
    height: 100vh;
    z-index: 1000;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    border-radius: 0;
  }
  
  .filters-sidebar.mobile-visible {
    transform: translateX(0);
  }
}

.filters-sidebar h3 {
  font-size: 1.125rem;
  font-weight: 600;
  margin-bottom: 1.5rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--clutch-border);
}

.filter-group {
  margin-bottom: 1.5rem;
}

.filter-group h4 {
  font-size: 0.875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.75rem;
  color: var(--clutch-text);
}

.filter-option {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.5rem 0;
  cursor: pointer;
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
  transition: color 0.2s;
}

.filter-option:hover {
  color: var(--clutch-text);
}

.filter-option.active {
  color: var(--clutch-accent);
}

.filter-option input[type="checkbox"] {
  width: 18px;
  height: 18px;
  accent-color: var(--clutch-accent);
  cursor: pointer;
}

.price-range {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.price-range input {
  width: 80px;
  padding: 0.5rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  color: var(--clutch-text);
  font-size: 0.875rem;
}

.price-range input:focus {
  outline: none;
  border-color: var(--clutch-accent);
}

.clear-filters {
  width: 100%;
  padding: 0.75rem;
  background: transparent;
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  color: var(--clutch-text-muted);
  font-size: 0.875rem;
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 1rem;
}

.clear-filters:hover {
  border-color: var(--clutch-accent);
  color: var(--clutch-accent);
}

/* Products Area */
.products-area {
  min-width: 0;
}

.mobile-filter-toggle {
  display: none;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1rem;
  background: var(--clutch-bg-light);
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  color: var(--clutch-text);
  font-size: 0.875rem;
  cursor: pointer;
  margin-bottom: 1rem;
}

@media (max-width: 900px) {
  .mobile-filter-toggle {
    display: inline-flex;
  }
}

/* Active Filters */
.active-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1rem;
  min-height: 32px;
}

.filter-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.375rem 0.75rem;
  background: rgba(201, 137, 75, 0.15);
  border: 1px solid var(--clutch-accent);
  border-radius: 20px;
  font-size: 0.8125rem;
  color: var(--clutch-text);
}

.filter-pill button {
  background: none;
  border: none;
  color: var(--clutch-accent);
  cursor: pointer;
  font-size: 1rem;
  line-height: 1;
  padding: 0;
  margin-left: 0.25rem;
}

/* Sort Bar */
.sort-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--clutch-border);
}

.results-count {
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
}

.sort-select {
  padding: 0.5rem 1rem;
  background: var(--clutch-bg-light);
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  color: var(--clutch-text);
  font-size: 0.875rem;
  cursor: pointer;
}

.sort-select:focus {
  outline: none;
  border-color: var(--clutch-accent);
}

/* Products Grid - 4 Columns */
.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}

@media (max-width: 1200px) {
  .products-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 768px) {
  .products-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
}

@media (max-width: 480px) {
  .products-grid {
    grid-template-columns: 1fr;
  }
}

/* Product Card */
.product-card {
  background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.product-card:hover {
  transform: translateY(-6px);
  border-color: rgba(201, 137, 75, 0.50);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
}

.product-card__image {
  position: relative;
  aspect-ratio: 1;
  background: rgba(255,255,255,0.03);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.product-card__image img {
  max-width: 85%;
  max-height: 85%;
  object-fit: contain;
  transition: transform 0.35s ease;
}

.product-card:hover .product-card__image img {
  transform: scale(1.05);
}

.product-card__quick-add {
  position: absolute;
  bottom: 1rem;
  left: 50%;
  transform: translateX(-50%) translateY(10px);
  padding: 0.625rem 1.25rem;
  background: var(--clutch-accent);
  color: var(--clutch-bg);
  border: none;
  border-radius: 8px;
  font-size: 0.8125rem;
  font-weight: 600;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.3s ease;
  white-space: nowrap;
}

.product-card:hover .product-card__quick-add {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* Quick Add button hover and active states */
.product-card__quick-add:hover {
  background: var(--clutch-accent-hover);
}

.product-card__quick-add:active {
  transform: translateX(-50%) translateY(0) scale(0.95);
}

/* Added to cart success state */
.product-card__quick-add.added-to-cart {
  background: #22c55e !important;
  color: white !important;
  opacity: 1 !important;
}

.product-card__info {
  padding: 1.25rem;
}

.product-card__brand {
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--clutch-accent);
  margin-bottom: 0.375rem;
}

.product-card__name {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.625rem;
  line-height: 1.3;
}

.product-card__name a:hover {
  color: var(--clutch-accent);
}

.product-card__price {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.product-card__price-current {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--clutch-text);
}

.product-card__price-compare {
  font-size: 0.9375rem;
  color: var(--clutch-text-dim);
  text-decoration: line-through;
}

/* Pagination */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.5rem;
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--clutch-border);
}

.pagination__prev,
.pagination__next {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  color: var(--clutch-text);
  transition: all 0.2s;
}

.pagination__prev:hover,
.pagination__next:hover {
  border-color: var(--clutch-accent);
  color: var(--clutch-accent);
}

.pagination__disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.pagination__number {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 40px;
  height: 40px;
  padding: 0 0.75rem;
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
  transition: all 0.2s;
}

.pagination__number:hover {
  border-color: var(--clutch-accent);
  color: var(--clutch-accent);
}

.pagination__current {
  background: var(--clutch-accent);
  border-color: var(--clutch-accent);
  color: var(--clutch-bg);
  font-weight: 600;
}

.pagination__ellipsis {
  color: var(--clutch-text-dim);
  padding: 0 0.5rem;
}

/* COLLECTION PAGE - Shop */
.page-header {
  padding: 3rem 1.5rem 2rem;
  text-align: center;
  background: linear-gradient(180deg, var(--clutch-bg-light) 0%, var(--clutch-bg) 100%);
