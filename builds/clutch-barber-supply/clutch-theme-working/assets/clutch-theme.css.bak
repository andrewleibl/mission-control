}

.product-card__name a:hover {
  color: var(--clutch-accent);
}

.product-card__price {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.product-card__price-current {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--clutch-text);
}

.product-card__price-compare {
  font-size: 0.9375rem;
  color: var(--clutch-text-dim);
  text-decoration: line-through;
}

/* Pagination */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.5rem;
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--clutch-border);
}

.pagination__prev,
.pagination__next {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  color: var(--clutch-text);
  transition: all 0.2s;
}

.pagination__prev:hover,
.pagination__next:hover {
  border-color: var(--clutch-accent);
  color: var(--clutch-accent);
}

.pagination__disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.pagination__number {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 40px;
  height: 40px;
  padding: 0 0.75rem;
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
  transition: all 0.2s;
}

.pagination__number:hover {
  border-color: var(--clutch-accent);
  color: var(--clutch-accent);
}

.pagination__current {
  background: var(--clutch-accent);
  border-color: var(--clutch-accent);
  color: var(--clutch-bg);
  font-weight: 600;
}

.pagination__ellipsis {
  color: var(--clutch-text-dim);
  padding: 0 0.5rem;
}

/* FOOTER */
.clutch-footer {
  background: var(--clutch-bg);
  border-top: 1px solid var(--clutch-border);
  padding: 3rem 0 2rem;
  position: relative;
  overflow: hidden;
}

/* Copper Glow Effect for Footer - INTENSIFIED +25% */
.clutch-footer__glow {
  position: absolute;
  bottom: -200px;
  left: 50%;
  transform: translateX(-50%);
  width: 1000px;
  height: 500px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.13) 45%, rgba(201, 137, 75, 0.03) 70%, transparent 85%);
  filter: blur(140px);
  pointer-events: none;
  z-index: 0;
}

.clutch-footer__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

.clutch-footer__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}

@media (min-width: 768px) {
  .clutch-footer__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 1024px) {
  .clutch-footer__grid {
    grid-template-columns: repeat(6, 1fr);
  }
}

.clutch-footer__column h4 {
  font-size: 0.9375rem;
  font-weight: 600;
  margin-bottom: 1rem;
  text-transform: uppercase;
}

.clutch-footer__links {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.clutch-footer__links a {
  font-size: 0.875rem;
  color: var(--clutch-text-dim);
  transition: color 0.2s;
}

.clutch-footer__links a:hover {
  color: var(--clutch-accent);
}

.clutch-footer__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 2rem;
  border-top: 1px solid var(--clutch-border);
}

.clutch-footer__copyright {
  font-size: 0.8125rem;
  color: var(--clutch-text-dim);
}

.clutch-footer__social {
  display: flex;
  gap: 0.875rem;
}

.clutch-footer__social a {
  width: 2.25rem;
  height: 2.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  color: var(--clutch-text-dim);
}

.clutch-footer__social a:hover {
  border-color: var(--clutch-accent);
  color: var(--clutch-accent);
}

.clutch-footer__payment {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.clutch-footer__payment-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.clutch-footer__payment-icon {
  font-size: 0.625rem;
  font-weight: 700;
  color: var(--clutch-text-dim);
  padding: 0.25rem 0.5rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 4px;
}

/* RESPONSIVE */
@media (max-width: 640px) {
  .clutch-home-hero__trust {
    flex-direction: column;
    gap: 1rem;
  }

  .clutch-home-email__input-group {
    flex-direction: column;
  }

  .clutch-footer__bottom {
    flex-direction: column;
    gap: 1.5rem;
    text-align: center;
  }
}

/* Dual-handle Price Slider */
.price-slider {
  padding: 1rem 0;
}

.price-slider__track {
  position: relative;
  height: 6px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3px;
  cursor: pointer;
}

.price-slider__range {
  position: absolute;
  height: 100%;
  background: var(--clutch-accent);
  border-radius: 3px;
}

.price-slider__handle {
  position: absolute;
  top: 50%;
  width: 18px;
  height: 18px;
  background: var(--clutch-accent);
  border: 2px solid var(--clutch-text);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  cursor: grab;
  transition: transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
}

.price-slider__handle:hover {
  transform: translate(-50%, -50%) scale(1.15);
  box-shadow: 0 4px 12px rgba(201, 137, 75, 0.50);
}

.price-slider__handle:active {
  cursor: grabbing;
  transform: translate(-50%, -50%) scale(1.1);
}

.price-slider__labels {
  display: flex;
  justify-content: space-between;
  margin-top: 0.75rem;
  font-size: 0.8125rem;
  color: var(--clutch-text-muted);
}

/* ============================================================================
   CONVERSION-OPTIMIZED CART PAGE
   Features: Free shipping progress, trust badges, social proof, upsells
   ============================================================================ */

.cart-section {
  padding: 2rem 1rem 4rem;
  background: var(--clutch-bg);
  min-height: 60vh;
}

.cart-container {
  max-width: 1200px;
  margin: 0 auto;
}

/* Cart Header */
.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--clutch-border);
}

.cart-title {
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--clutch-paper);
  margin: 0;
}

.cart-trust-pill {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  background: rgba(34, 197, 94, 0.1);
  border: 1px solid rgba(34, 197, 94, 0.3);
  border-radius: 100px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: #22c55e;
}

.cart-trust-pill svg {
  flex-shrink: 0;
}

/* Free Shipping Progress Bar */
.cart-shipping-bar {
  background: linear-gradient(135deg, var(--clutch-navy-2) 0%, var(--clutch-navy) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  padding: 1.25rem;
  margin-bottom: 1.5rem;
}

.shipping-bar-content {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1rem;
}

.shipping-message {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  color: var(--clutch-paper);
  font-size: 0.9375rem;
}

.shipping-message svg {
  color: var(--clutch-copper);
  flex-shrink: 0;
}

.shipping-message strong {
  color: var(--clutch-copper);
  font-weight: 700;
}

.shipping-unlocked {
  color: #22c55e;
}

.shipping-unlocked svg {
  color: #22c55e;
}

.shipping-progress {
  height: 8px;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}

.shipping-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--clutch-copper) 0%, var(--clutch-copper-soft) 100%);
  border-radius: 4px;
  transition: width 0.5s ease;
}

.shipping-thresholds {
  display: flex;
  justify-content: space-between;
  margin-top: 0.5rem;
  font-size: 0.75rem;
  color: var(--clutch-text-muted);
  position: relative;
}

.threshold-marker {
  position: absolute;
  top: -1.25rem;
  transform: translateX(-50%);
  background: var(--clutch-copper);
  color: var(--clutch-ink);
  font-size: 0.6875rem;
  font-weight: 700;
  padding: 0.125rem 0.5rem;
  border-radius: 4px;
}

/* Cart Layout */
.cart-layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 2rem;
  align-items: start;
}

@media (max-width: 968px) {
  .cart-layout {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
}

/* Cart Items */
.cart-main {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.cart-form {
  display: contents;
}

.cart-items {
  background: var(--clutch-navy);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  overflow: hidden;
}

.cart-item {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 1.25rem;
  padding: 1.25rem;
  border-bottom: 1px solid var(--clutch-border);
}

.cart-item:last-child {
  border-bottom: none;
}

@media (max-width: 640px) {
  .cart-item {
    grid-template-columns: 80px 1fr;
    gap: 1rem;
    padding: 1rem;
  }
}

.cart-item-image {
  width: 100px;
  height: 100px;
  background: var(--clutch-navy-2);
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-item-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 0.5rem;
}

.cart-item-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: var(--clutch-text-muted);
}

@media (max-width: 640px) {
  .cart-item-image {
    width: 80px;
    height: 80px;
  }
}

.cart-item-details {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.cart-item-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.cart-item-title {
  font-size: 1rem;
  font-weight: 600;
  margin: 0;
  line-height: 1.3;
}

.cart-item-title a {
  color: var(--clutch-paper);
  transition: color 0.2s;
}

.cart-item-title a:hover {
  color: var(--clutch-copper);
}

.cart-item-remove {
  color: var(--clutch-text-muted);
  padding: 0.25rem;
  border-radius: 4px;
  transition: all 0.2s;
  flex-shrink: 0;
}

.cart-item-remove:hover {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
}

.cart-item-variant {
  font-size: 0.8125rem;
  color: var(--clutch-text-muted);
  margin: 0;
}

.cart-item-price-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.cart-item-price {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.cart-item-price-original {
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
  text-decoration: line-through;
}

.cart-item-price-final {
  font-size: 1rem;
  font-weight: 600;
  color: var(--clutch-paper);
}

.cart-item-savings {
  font-size: 0.75rem;
  font-weight: 600;
  color: #22c55e;
  background: rgba(34, 197, 94, 0.1);
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
}

.cart-item-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 0.5rem;
}

.cart-quantity {
  display: flex;
  align-items: center;
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  overflow: hidden;
}

.cart-quantity-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--clutch-navy-2);
  color: var(--clutch-paper);
  border: none;
  cursor: pointer;
  transition: all 0.2s;
}

.cart-quantity-btn:hover {
  background: var(--clutch-copper);
  color: var(--clutch-ink);
}

.cart-quantity-input {
  width: 50px;
  height: 36px;
  text-align: center;
  background: transparent;
  border: none;
  color: var(--clutch-paper);
  font-size: 0.9375rem;
  font-weight: 600;
  -moz-appearance: textfield;
}

.cart-quantity-input::-webkit-outer-spin-button,
.cart-quantity-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

.cart-item-line-price {
  font-size: 1rem;
  font-weight: 700;
  color: var(--clutch-paper);
}

/* Trust Bar below items */
.cart-trust-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 1rem;
  background: var(--clutch-navy-2);
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  margin-top: 1rem;
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8125rem;
  color: var(--clutch-text-muted);
}

.trust-item svg {
  color: var(--clutch-copper);
  flex-shrink: 0;
}

@media (max-width: 640px) {
  .cart-trust-bar {
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    text-align: center;
  }
}

/* Continue Shopping Link */
.cart-continue {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--clutch-text-muted);
  font-size: 0.9375rem;
  font-weight: 500;
  margin-top: 1rem;
  transition: color 0.2s;
}

.cart-continue:hover {
  color: var(--clutch-copper);
}

.cart-continue svg {
  transition: transform 0.2s;
}

.cart-continue:hover svg {
  transform: translateX(-3px);
}

/* Upsell Section */
.cart-upsell {
  background: var(--clutch-navy);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  padding: 1.25rem;
}

.upsell-header {
  margin-bottom: 1rem;
}

.upsell-title {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--clutch-paper);
  margin: 0 0 0.25rem;
}

.upsell-subtitle {
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
  margin: 0;
}

.upsell-products {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.upsell-product {
  display: grid;
  grid-template-columns: 60px 1fr auto;
  align-items: center;
  gap: 1rem;
  padding: 0.75rem;
  background: var(--clutch-navy-2);
  border-radius: 8px;
  transition: background 0.2s;
}

.upsell-product:hover {
  background: rgba(255, 255, 255, 0.05);
}

.upsell-image {
  width: 60px;
  height: 60px;
  background: var(--clutch-navy);
  border-radius: 6px;
  overflow: hidden;
}

.upsell-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 0.25rem;
}

.upsell-info {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.upsell-product-title {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--clutch-paper);
  margin: 0;
}

.upsell-product-price {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--clutch-copper);
}

.upsell-add {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--clutch-copper);
  color: var(--clutch-ink);
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
}

.upsell-add:hover {
  background: var(--clutch-copper-soft);
  transform: scale(1.05);
}

/* Cart Add-Ons (Random Products) */
.cart-addons {
  background: var(--clutch-navy);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  padding: 1.5rem;
  margin-top: 2rem;
}

.addons-header {
  margin-bottom: 1rem;
}

.addons-title {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--clutch-paper);
  margin: 0 0 0.25rem;
}

.addons-subtitle {
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
  margin: 0;
}

.addons-products {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.addon-product {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.75rem;
  background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
  border: 1px solid var(--clutch-border);
  border-radius: 10px;
  transition: all 0.2s;
}

.addon-product:hover {
  border-color: rgba(201, 137, 75, 0.4);
}

.addon-image {
  width: 64px;
  height: 64px;
  flex-shrink: 0;
  background: var(--clutch-ink);
  border-radius: 8px;
  overflow: hidden;
}

.addon-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 0.5rem;
}

.addon-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--clutch-text-muted);
}

.addon-info {
  flex: 1;
  min-width: 0;
}

.addon-product-title {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--clutch-paper);
  margin: 0 0 0.25rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.addon-product-price {
  font-size: 0.875rem;
  color: var(--clutch-copper);
  font-weight: 600;
  margin: 0;
}

.addon-add {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--clutch-copper);
  color: var(--clutch-ink);
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  flex-shrink: 0;
}

.addon-add:hover {
  background: var(--clutch-copper-soft);
  transform: scale(1.05);
}

.addon-add svg {
  width: 16px;
  height: 16px;
}

/* Cart Sidebar / Summary */
.cart-sidebar {
  position: sticky;
  top: 100px;
}

@media (max-width: 968px) {
  .cart-sidebar {
    position: static;
  }
}

.cart-summary {
  background: var(--clutch-navy);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  padding: 1.5rem;
}

.summary-title {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--clutch-paper);
  margin: 0 0 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--clutch-border);
}

/* Savings Banner */
.summary-savings-banner {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.875rem;
  background: rgba(34, 197, 94, 0.08);
  border: 1px solid rgba(34, 197, 94, 0.25);
  border-radius: 8px;
  margin-bottom: 1rem;
  font-size: 0.875rem;
  font-weight: 600;
  color: #22c55e;
}

.summary-savings-banner svg {
  flex-shrink: 0;
}

/* Summary Rows */
.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.625rem 0;
  font-size: 0.9375rem;
}

.summary-row span:first-child {
  color: var(--clutch-text-muted);
}

.summary-row span:last-child {
  color: var(--clutch-paper);
  font-weight: 500;
}

.summary-discount span:last-child {
  color: #22c55e;
}

.shipping-free {
  color: #22c55e !important;
  font-weight: 700 !important;
}

.shipping-calculated,
.tax-calculated {
  font-size: 0.8125rem;
  font-style: italic;
}

.summary-divider {
  height: 1px;
  background: var(--clutch-border);
  margin: 0.75rem 0;
}

.summary-total {
  font-size: 1.125rem;
  font-weight: 700;
  padding-top: 0.5rem;
}

.summary-total span:first-child {
  color: var(--clutch-paper);
}

.summary-total-amount {
  font-size: 1.25rem;
  color: var(--clutch-copper) !important;
}

/* Social Proof */
.cart-social-proof {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.75rem;
  background: var(--clutch-navy-2);
  border-radius: 8px;
  margin: 1rem 0;
  font-size: 0.8125rem;
  color: var(--clutch-text-muted);
}

.social-proof-pulse {
  width: 8px;
  height: 8px;
  background: #22c55e;
  border-radius: 50%;
  animation: pulse 2s infinite;
  flex-shrink: 0;
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
  70% { box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
  100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
}

.cart-social-proof strong {
  color: var(--clutch-paper);
}

/* Checkout Buttons */
.cart-checkout {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.checkout-btn {
  width: 100%;
  padding: 1rem 1.5rem;
  border: none;
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}

.checkout-btn-primary {
  background: var(--clutch-copper);
  color: var(--clutch-ink);
}

.checkout-btn-primary:hover {
  background: var(--clutch-copper-soft);
  transform: translateY(-1px);
  box-shadow: 0 8px 24px rgba(201, 137, 75, 0.375);
}

.checkout-divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 0.5rem 0;
  font-size: 0.8125rem;
  color: var(--clutch-text-muted);
}

.checkout-divider::before,
.checkout-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--clutch-border);
}

.checkout-express {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

/* Guarantee Box */
.cart-guarantee {
  display: flex;
  gap: 1rem;
  padding: 1rem;
  background: var(--clutch-navy-2);
  border: 1px solid var(--clutch-border);
  border-radius: 10px;
  margin-top: 1.25rem;
}

.guarantee-icon {
  color: var(--clutch-copper);
  flex-shrink: 0;
}

.guarantee-content h4 {
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--clutch-paper);
  margin: 0 0 0.25rem;
}

.guarantee-content p {
  font-size: 0.8125rem;
  color: var(--clutch-text-muted);
  margin: 0;
  line-height: 1.5;
}

/* Info Accordion */
.cart-info-accordion {
  margin-top: 1rem;
  border-top: 1px solid var(--clutch-border);
  padding-top: 1rem;
}

.info-item {
  border-bottom: 1px solid var(--clutch-border);
}

.info-item summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.875rem 0;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--clutch-paper);
  cursor: pointer;
  list-style: none;
}

.info-item summary::-webkit-details-marker {
  display: none;
}

.info-item summary svg {
  transition: transform 0.2s;
}

.info-item[open] summary svg {
  transform: rotate(180deg);
}

.info-content {
  padding: 0 0 1rem;
  font-size: 0.8125rem;
  color: var(--clutch-text-muted);
  line-height: 1.6;
}

.info-content ul {
  margin: 0;
  padding-left: 1.25rem;
}

.info-content li {
  margin-bottom: 0.375rem;
}

.info-content a {
  color: var(--clutch-copper);
  text-decoration: underline;
}

/* Payment Methods */
.cart-payment-methods {
  margin-top: 1.25rem;
  padding-top: 1rem;
  border-top: 1px solid var(--clutch-border);
}

.cart-payment-methods p {
  font-size: 0.75rem;
  color: var(--clutch-text-muted);
  margin: 0 0 0.5rem;
}

.payment-icons {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.payment-icon {
  font-size: 0.625rem;
  font-weight: 700;
  color: var(--clutch-text-muted);
  padding: 0.375rem 0.625rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 4px;
}

/* Sticky Mobile Checkout */
.cart-sticky-mobile {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--clutch-navy);
  border-top: 1px solid var(--clutch-border);
  padding: 0.75rem 1rem;
  z-index: 1000;
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.3);
}

@media (max-width: 640px) {
  .cart-sticky-mobile {
    display: block;
  }
  
  .cart-section {
    padding-bottom: 6rem;
  }
}

.sticky-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  max-width: 600px;
  margin: 0 auto;
}

.sticky-total {
  display: flex;
  flex-direction: column;
}

.sticky-label {
  font-size: 0.75rem;
  color: var(--clutch-text-muted);
}

.sticky-amount {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--clutch-paper);
}

.sticky-checkout-btn {
  padding: 0.875rem 1.5rem;
  background: var(--clutch-copper);
  color: var(--clutch-ink);
  border: none;
  border-radius: 8px;
  font-size: 0.9375rem;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  white-space: nowrap;
}

/* Empty Cart State */
.cart-empty {
  text-align: center;
  padding: 3rem 1rem;
  max-width: 600px;
  margin: 0 auto;
}

.empty-icon {
  color: var(--clutch-text-muted);
  margin-bottom: 1.5rem;
}

.empty-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--clutch-paper);
  margin: 0 0 0.5rem;
}

.empty-text {
  font-size: 1rem;
  color: var(--clutch-text-muted);
  margin: 0 0 1.5rem;
}

.empty-btn {
  display: inline-flex;
  align-items: center;
  padding: 0.875rem 2rem;
  background: var(--clutch-copper);
  color: var(--clutch-ink);
  border-radius: 10px;
  font-size: 1rem;
  font-weight: 700;
  transition: all 0.2s;
}

.empty-btn:hover {
  background: var(--clutch-copper-soft);
  transform: translateY(-2px);
}

.empty-featured {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--clutch-border);
}

.empty-featured h3 {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--clutch-paper);
  margin: 0 0 1.25rem;
}

.empty-products {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.empty-product-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem;
  background: var(--clutch-navy);
  border: 1px solid var(--clutch-border);
  border-radius: 10px;
  transition: all 0.2s;
}

.empty-product-card:hover {
  border-color: var(--clutch-copper);
}

.empty-product-card img {
  width: 80px;
  height: 80px;
  object-fit: contain;
  margin-bottom: 0.5rem;
}

.empty-product-title {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--clutch-paper);
  text-align: center;
  line-height: 1.3;
}

.empty-product-price {
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--clutch-copper);
}

@media (max-width: 480px) {
  .empty-products {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Cart Page Responsive Adjustments */
@media (max-width: 768px) {
  .cart-title {
    font-size: 1.375rem;
  }

  .cart-trust-pill span {
    display: none;
  }

  .cart-shipping-bar {
    padding: 1rem;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    margin: 0 auto;
  }

  .shipping-bar-content {
    width: 100%;
  }

  .shipping-message {
    font-size: 0.8125rem;
    text-align: center;
    justify-content: center;
  }

  .shipping-progress {
    width: 100%;
  }

  .shipping-thresholds {
    width: 100%;
  }

  .cart-summary {
    padding: 1.25rem;
  }

  .cart-guarantee {
    flex-direction: column;
    text-align: center;
    gap: 0.75rem;
  }

  /* Condense cart sections by 10%, align left */
  .cart-items,
  .cart-trust-bar,
  .cart-reviews,
  .cart-suggestions,
  .cart-sidebar {
    width: 90% !important;
    margin-left: 0 !important;
    margin-right: auto !important;
  }

  .cart-item,
  .cart-review,
  .suggestion-product,
  .cart-summary {
    width: 100% !important;
  }
}

/* Animation for shipping progress */
@keyframes shimmer {
  0% { background-position: -200px 0; }
  100% { background-position: 200px 0; }
}

.shipping-progress-fill {
  background-size: 200px 100%;
  animation: shimmer 2s infinite linear;
}

/* Hover effects for cart items */
.cart-item {
  transition: background 0.2s;
}

.cart-item:hover {
  background: rgba(255, 255, 255, 0.02);
}

/* Focus states for accessibility */
.cart-quantity-btn:focus,
.checkout-btn:focus,
.upsell-add:focus,
.cart-continue:focus,
.info-item summary:focus {
  outline: 2px solid var(--clutch-copper);
  outline-offset: 2px;
}

/* Additional checkout button styling for Shopify */
.cart-checkout .shopify-payment-button__button--branded {
  border-radius: 10px !important;
  min-height: 48px !important;
}

.cart-checkout .shopify-payment-button__button--unbranded {
  background: var(--clutch-copper) !important;
  color: var(--clutch-ink) !important;
  border-radius: 10px !important;
  font-weight: 700 !important;
}

/* End Cart Styles */

/* =====================================================
   COPPER GLOW EFFECTS FOR INTERIOR PAGES
   ===================================================== */

/* Base glow container for all interior pages */
.page-with-glow {
  position: relative;
  overflow: hidden;
}

/* Shop/Collection Page Glow */
.page-with-glow .collection-layout::before {
  content: '';
  position: absolute;
  top: -100px;
  right: -100px;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.125) 40%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

.page-with-glow .collection-layout::after {
  content: '';
  position: absolute;
  bottom: -50px;
  left: -50px;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.31) 0%, rgba(201, 137, 75, 0.063) 50%, transparent 70%);
  filter: blur(120px);
  pointer-events: none;
  z-index: 0;
}

/* Brand Page Glow */
.page-with-glow .brands-page::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 800px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.375) 0%, rgba(201, 137, 75, 0.10) 50%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

/* Supplies Page Glow */
.page-with-glow .categories-grid::before {
  content: '';
  position: absolute;
  top: 20%;
  right: -100px;
  width: 500px;
  height: 600px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.375) 0%, rgba(201, 137, 75, 0.10) 45%, transparent 70%);
  filter: blur(120px);
  pointer-events: none;
  z-index: 0;
}

.page-with-glow .featured-marquee::before {
  content: '';
  position: absolute;
  top: -50px;
  left: -50px;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.31) 0%, rgba(201, 137, 75, 0.063) 50%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

/* Classes Page Glow */
.page-with-glow .classes-template::before {
  content: '';
  position: absolute;
  top: -100px;
  left: 20%;
  width: 600px;
  height: 500px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.125) 45%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

.page-with-glow .classes-template::after {
  content: '';
  position: absolute;
  bottom: -50px;
  right: 10%;
  width: 500px;
  height: 400px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.31) 0%, rgba(201, 137, 75, 0.063) 50%, transparent 70%);
  filter: blur(120px);
  pointer-events: none;
  z-index: 0;
}

/* Contact Page Glow */
.page-with-glow .contact-layout::before {
  content: '';
  position: absolute;
  top: 10%;
  left: -100px;
  width: 500px;
  height: 600px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.125) 40%, transparent 70%);
  filter: blur(120px);
  pointer-events: none;
  z-index: 0;
}

.page-with-glow .contact-layout::after {
  content: '';
  position: absolute;
  bottom: 10%;
  right: -100px;
  width: 400px;
  height: 500px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.375) 0%, rgba(201, 137, 75, 0.10) 45%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

/* FAQ Page Glow */
.page-with-glow .faq-container::before {
  content: '';
  position: absolute;
  top: -50px;
  right: 20%;
  width: 600px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.375) 0%, rgba(201, 137, 75, 0.10) 50%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

/* Reviews Page Glow */
.page-with-glow .reviews-section::before {
  content: '';
  position: absolute;
  top: -100px;
  left: 10%;
  width: 700px;
  height: 500px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.125) 45%, transparent 70%);
  filter: blur(120px);
  pointer-events: none;
  z-index: 0;
}

.page-with-glow .reviews-section::after {
  content: '';
  position: absolute;
  bottom: -50px;
  right: 20%;
  width: 500px;
  height: 400px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.31) 0%, rgba(201, 137, 75, 0.063) 50%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

/* Policy Pages Glow (Shipping, Returns, Privacy, Terms) */
.page-with-glow .policy-section::before {
  content: '';
  position: absolute;
  top: -50px;
  left: 50%;
  transform: translateX(-50%);
  width: 800px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.31) 0%, rgba(201, 137, 75, 0.10) 50%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

/* Cart Page Glow */
.page-with-glow .cart-container::before {
  content: '';
  position: absolute;
  top: -100px;
  right: -100px;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.125) 40%, transparent 70%);
  filter: blur(120px);
  pointer-events: none;
  z-index: 0;
}

.page-with-glow .cart-container::after {
  content: '';
  position: absolute;
  bottom: -50px;
  left: -50px;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.31) 0%, rgba(201, 137, 75, 0.063) 50%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

/* Product Page Glow */
.page-with-glow .product-template::before {
  content: '';
  position: absolute;
  top: -50px;
  right: 20%;
  width: 600px;
  height: 500px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.44) 0%, rgba(201, 137, 75, 0.125) 45%, transparent 70%);
  filter: blur(120px);
  pointer-events: none;
  z-index: 0;
}

.page-with-glow .product-template::after {
  content: '';
  position: absolute;
  bottom: 10%;
  left: -100px;
  width: 400px;
  height: 500px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.375) 0%, rgba(201, 137, 75, 0.10) 50%, transparent 70%);
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
}

/* Page Header Glow Base */
.page-with-glow .page-header {
  position: relative;
  overflow: hidden;
}

.page-with-glow .page-header::before {
  content: '';
  position: absolute;
  top: -30%;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 400px;
  background: radial-gradient(ellipse, rgba(201, 137, 75, 0.375) 0%, rgba(201, 137, 75, 0.10) 60%, transparent 70%);
  filter: blur(80px);
  pointer-events: none;
  z-index: 0;
}

/* Ensure content stays above glow */
.page-with-glow .collection-layout,
.page-with-glow .brands-page,
.page-with-glow .categories-grid,
.page-with-glow .classes-template,
.page-with-glow .contact-layout,
.page-with-glow .faq-container,
.page-with-glow .reviews-section,
.page-with-glow .policy-section,
.page-with-glow .cart-container,
.page-with-glow .product-template {
  position: relative;
  z-index: 1;
}

/* =====================================================
   MOBILE OVERRIDES - These only apply below 768px
   Desktop styles above remain untouched
   ===================================================== */

@media (max-width: 768px) {
  /* Hero Social Proof - Stars on top, text below, centered */
  .clutch-home-hero__social-proof {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 0.5rem !important;
    text-align: center !important;
    padding: 0.75rem 1.5rem !important;
    border-radius: 16px !important;
  }
  
  .clutch-home-hero__stars {
    order: -1 !important;
    display: flex !important;
    justify-content: center !important;
    margin: 0 !important;
  }
  
  .clutch-home-hero__social-text {
    display: block !important;
    text-align: center !important;
    width: 100% !important;
    font-size: 0.8125rem !important;
  }
  
  /* Hero Trust Items - Centered with icons */
  .clutch-home-hero__trust {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    gap: 1rem !important;
    width: 100% !important;
    margin-top: 2rem !important;
  }
  
  .clutch-home-hero__trust-item {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 0.75rem !important;
    width: 100% !important;
    text-align: center !important;
    font-size: 0.875rem !important;
  }
  
  .clutch-home-hero__trust-icon {
    display: flex !important;
    flex-shrink: 0 !important;
    width: 1.5rem !important;
    height: 1.5rem !important;
  }
  
  /* Hero Buttons - Stack vertically, full width */
  .clutch-home-hero__actions {
    display: flex !important;
    flex-direction: column !important;
    gap: 0.75rem !important;
    width: 100% !important;
    margin-bottom: 2rem !important;
  }
  
  .clutch-home-hero__actions .clutch-button {
    width: 100% !important;
    text-align: center !important;
    margin: 0 !important;
  }
}

/* =====================================================
   SHOP PAGE MOBILE OVERRIDES
   ===================================================== */

/* Mobile: Keep 2 products per row (override 480px 1-column) */
@media (max-width: 480px) {
  .products-grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 0.75rem !important;
  }
}

/* Mobile: Filters panel - centered with rounded corners */
@media (max-width: 768px) {
  /* Filter panel - slides from left, 75% width, rounded corners */
  .filters-sidebar {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: auto !important;
    transform: translateX(-100%) !important;
    width: 75% !important;
    max-width: none !important;
    height: 100vh !important;
    max-height: 100vh !important;
    border-radius: 0 16px 16px 0 !important;
    overflow-y: auto !important;
    overflow-x: hidden !important;
    padding: 1.5rem !important;
    z-index: 2000 !important;
    transition: transform 0.3s ease !important;
    box-sizing: border-box !important;
  }

  .filters-sidebar.mobile-visible {
    transform: translateX(0) !important;
  }
  
  /* Scrollable content */
  .filters-sidebar::-webkit-scrollbar {
    width: 6px;
  }
  
  .filters-sidebar::-webkit-scrollbar-track {
    background: rgba(255,255,255,0.05);
    border-radius: 3px;
  }
  
  .filters-sidebar::-webkit-scrollbar-thumb {
    background: var(--clutch-copper);
    border-radius: 3px;
  }
  
  /* Compact filter groups */
  .filters-sidebar .filter-group {
    margin-bottom: 0.75rem !important;
  }
  
  .filters-sidebar h3 {
    font-size: 1.125rem !important;
    margin-bottom: 1rem !important;
    padding-bottom: 0.75rem !important;
    border-bottom: 1px solid var(--clutch-border) !important;
  }
  
  .filters-sidebar h4 {
    font-size: 0.875rem !important;
    margin-bottom: 0.5rem !important;
  }
  
  .filters-sidebar .filter-option {
    font-size: 0.875rem !important;
    padding: 0.375rem 0 !important;
  }
  
  /* Filter overlay */
  .filters-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 1999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s;
  }
  
  .filters-overlay.active {
    opacity: 1;
    visibility: visible;
  }
  
  /* Mobile filter button */
  .mobile-filter-toggle {
    margin-bottom: 1rem !important;
  }
}

/* =====================================================
   DESKTOP PRODUCTS FIX - Ensure visible
   ===================================================== */

.products-grid {
  display: grid !important;
  min-height: 200px;
}

.products-grid .product-card {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}
