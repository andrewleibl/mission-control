{% comment %} Template: page.faq {% endcomment %}

<div class="page-header">
  <h1>Frequently Asked Questions</h1>
  <p>Quick answers to common questions. Can't find what you're looking for? <a href="/pages/contact" style="color: var(--clutch-accent);">Contact us</a>.</p>
</div>

<div class="faq-container">
  
  <!-- Shipping & Delivery -->
  <div class="faq-category">
    <h2>Shipping & Delivery</h2>
    
    <div class="faq-item">
      <button class="faq-item__question">How long does shipping take?</button>
      <div class="faq-item__answer">
        <p>Shipping takes 3-7 days. Orders typically ship within 1-2 business days. Free shipping on orders over $300.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">Do you ship internationally?</button>
      <div class="faq-item__answer">
        <p>Yes! We ship internationally. Contact us for shipping rates to your location.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">Do you offer same-day shipping?</button>
      <div class="faq-item__answer">
        <p>Yes! We offer same-day shipping if your order is placed by 2:00 PM CST.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">How do I track my order?</button>
      <div class="faq-item__answer">
        <p>Tracking numbers are automatically sent to your email once your order ships.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">Can I pick up my order in store?</button>
      <div class="faq-item__answer">
        <p>Yes! Select "In-Store Pickup" at checkout. We'll email you when your order is ready (usually within 24 hours during business hours).</p>
      </div>
    </div>
  </div>
  
  <!-- Ordering -->
  <div class="faq-category">
    <h2>Ordering</h2>
    
    <div class="faq-item">
      <button class="faq-item__question">What payment methods do you accept?</button>
      <div class="faq-item__answer">
        <p>We accept AMEX, Apple Pay, Diners, Discover, Google Pay, Mastercard, PayPal, Shop Pay, UnionPay, and VISA.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">Will I receive an order confirmation?</button>
      <div class="faq-item__answer">
        <p>Yes, you'll receive a confirmation email immediately after placing your order with your order details and receipt.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">Can I modify or cancel my order after placing it?</button>
      <div class="faq-item__answer">
        <p>Contact us immediately at <a href="tel:+12146771059">(214) 677-1059</a>. If your order hasn't shipped yet, we can help make changes or cancel it.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">Can I order by phone?</button>
      <div class="faq-item__answer">
        <p>Yes! You can place orders over the phone. Call us at <a href="tel:+12146771059">(214) 677-1059</a> during business hours and our team will help you place your order.</p>
      </div>
    </div>
  </div>
  
  <!-- Returns & Exchanges -->
  <div class="faq-category">
    <h2>Returns & Exchanges</h2>
    
    <div class="faq-item">
      <button class="faq-item__question">What is your return policy?</button>
      <div class="faq-item__answer">
        <p>Returns only apply for defective products. We have a 30-day policy for defective or damaged items. You have 30 days after receiving your item to request a return for defects. All sales are final for non-defective items.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">Can I return an item if I simply don't like it?</button>
      <div class="faq-item__answer">
        <p>No. We do not accept returns for buyer's remorse or if you simply don't like the item. Please review your cart carefully before purchasing. Customers must look over what items they choose for their online basket.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">What if my item arrives defective or damaged?</button>
      <div class="faq-item__answer">
        <p>If your item arrives defective, damaged, or if you receive the wrong item, contact us within 48 hours of delivery. Include photos of the damage and packaging. We'll replace the item or issue a full refund at no cost to you.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">How do I start a return?</button>
      <div class="faq-item__answer">
        <p>To start a return, email us at <a href="mailto:viceliatinde20@gmail.com">viceliatinde20@gmail.com</a> with your order number and reason for return. Wait for approval — we'll respond within 2 business days. If approved, we'll send you a prepaid return label. Ship the item back using our label within 7 days of approval.</p>
      </div>
    </div>
    
    <div class="faq-item">
      <button class="faq-item__question">Are there items that cannot be returned?</button>
      <div class="faq-item__answer">
        <p>Yes. Final sale products including clippers, trimmers, shavers, and all electrical tools cannot be returned unless defective. Personal care items, sale items, gift cards, and custom orders are also non-returnable.</p>
      </div>
    </div>
  </div>
  
</div>

<div class="faq-cta">
  <h2>Still have questions?</h2>
  <p>Our team is here to help. Reach out and we'll get back to you within 24 hours.</p>
  <a href="/pages/contact" class="btn">Contact Us</a>
</div>

<script>
  document.querySelectorAll('.faq-item__question').forEach(button => {
    button.addEventListener('click', () => {
      const item = button.parentElement;
      item.classList.toggle('active');
    });
  });
</script>

<style>
.faq-container {
  max-width: 800px;
  margin: 0 auto;
  padding: 4rem 1.5rem;
}

.faq-category {
  margin-bottom: 3rem;
}

.faq-category h2 {
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 1.5rem;
  padding-bottom: 0.75rem;
  border-bottom: 2px solid var(--clutch-accent);
  display: inline-block;
}

.faq-item {
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  margin-bottom: 1rem;
  overflow: hidden;
}

.faq-item__question {
  width: 100%;
  padding: 1.25rem;
  background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
  border: none;
  color: var(--clutch-text);
  font-size: 1rem;
  font-weight: 600;
  text-align: left;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.2s;
}

.faq-item__question:hover {
  background: rgba(201, 137, 75, 0.05);
}

.faq-item__question::after {
  content: '+';
  font-size: 1.5rem;
  color: var(--clutch-accent);
  transition: transform 0.3s;
  flex-shrink: 0;
  margin-left: 1rem;
}

.faq-item.active .faq-item__question::after {
  content: '−';
}

.faq-item__answer {
  padding: 0 1.25rem;
  max-height: 0;
  overflow: hidden;
  transition: all 0.3s ease;
}

.faq-item.active .faq-item__answer {
  padding: 0 1.25rem 1.25rem;
  max-height: 500px;
}

.faq-item__answer p {
  color: var(--clutch-text-muted);
  line-height: 1.7;
}

.faq-item__answer a {
  color: var(--clutch-accent);
  text-decoration: none;
}

.faq-item__answer a:hover {
  text-decoration: underline;
}

.faq-cta {
  text-align: center;
  padding: 4rem 1.5rem;
  background: linear-gradient(180deg, var(--clutch-bg) 0%, var(--clutch-bg-lighter) 100%);
  border-top: 1px solid var(--clutch-border);
}

.faq-cta h2 {
  font-size: 1.75rem;
  font-weight: 700;
  margin-bottom: 1rem;
}

.faq-cta p {
  color: var(--clutch-text-muted);
  margin-bottom: 1.5rem;
}

.faq-cta .btn {
  display: inline-block;
  padding: 1rem 2rem;
  background: var(--clutch-accent);
  color: var(--clutch-bg);
  border-radius: 12px;
  font-weight: 600;
  transition: all 0.3s;
}

.faq-cta .btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 28px rgba(201, 137, 75, 0.4);
}
</style>