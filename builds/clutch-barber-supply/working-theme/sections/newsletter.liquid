<section class="clutch-home-email">
  <div class="clutch-home-section__inner">
    <div class="clutch-home-email__content">
      <h2 class="clutch-home-email__title">{{ section.settings.title }}</h2>
      <p class="clutch-home-email__subtitle">{{ section.settings.subtitle }}</p>
      
      {% form 'customer', class: 'clutch-home-email__input-group' %}
        {% if form.posted_successfully? %}
          <p class="success-message">{{ section.settings.success_message }}</p>
        {% else %}
          <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required>
          <button type="submit" class="clutch-button clutch-button--primary">{{ section.settings.button_text }}</button>
        {% endif %}
      {% endform %}
      
      <p class="clutch-home-email__disclaimer">{{ section.settings.disclaimer }}</p>
    </div>
  </div>
</section>

<style>
.clutch-home-email {
  background: linear-gradient(180deg, var(--clutch-bg) 0%, var(--clutch-bg-lighter) 50%, var(--clutch-bg) 100%);
  padding: 5rem 0;
  position: relative;
  overflow: hidden;
}
.clutch-home-email::before {
  content: '';
  position: absolute;
  top: 20%;
  left: 10%;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.15) 0%, transparent 60%);
  filter: blur(80px);
  pointer-events: none;
}
.clutch-home-email::after {
  content: '';
  position: absolute;
  bottom: 20%;
  right: 10%;
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, rgba(201, 137, 75, 0.1) 0%, transparent 50%);
  filter: blur(60px);
  pointer-events: none;
}
.clutch-home-email__content {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
  position: relative;
  z-index: 1;
}
.clutch-home-email__title {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
}
.clutch-home-email__subtitle {
  font-size: 1.0625rem;
  color: var(--clutch-text-muted);
  margin-bottom: 2rem;
  line-height: 1.6;
}
.clutch-home-email__input-group {
  display: flex;
  gap: 0.75rem;
  max-width: 500px;
  margin: 0 auto 1rem;
}
.clutch-home-email__input-group input {
  flex: 1;
  padding: 1rem 1.25rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  color: var(--clutch-text);
  font-size: 1rem;
}
.clutch-home-email__input-group input:focus {
  outline: none;
  border-color: var(--clutch-accent);
}
.clutch-home-email__input-group input::placeholder {
  color: var(--clutch-text-dim);
}
.clutch-home-email__disclaimer {
  font-size: 0.8125rem;
  color: var(--clutch-text-dim);
}
.success-message {
  color: #22c55e;
  font-weight: 600;
}
@media (max-width: 640px) {
  .clutch-home-email__input-group {
    flex-direction: column;
  }
}
</style>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Join the Clutch Crew",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "default": "Get 10% off your first order + exclusive drops and barber tips delivered to your inbox.",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "placeholder",
      "default": "Enter your email",
      "label": "Placeholder Text"
    },
    {
      "type": "text",
      "id": "button_text",
      "default": "Get 10% Off",
      "label": "Button Text"
    },
    {
      "type": "text",
      "id": "success_message",
      "default": "Thanks for subscribing! Check your email for your discount.",
      "label": "Success Message"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "default": "No spam, unsubscribe anytime.",
      "label": "Disclaimer"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}