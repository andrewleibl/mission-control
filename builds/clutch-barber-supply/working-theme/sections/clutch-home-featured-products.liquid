<section class="clutch-home-section clutch-home-featured-products" aria-labelledby="clutch-home-featured-products-heading">
  <div class="clutch-home-featured-products__glow clutch-home-featured-products__glow--left" aria-hidden="true"></div>
  <div class="clutch-home-featured-products__glow clutch-home-featured-products__glow--right" aria-hidden="true"></div>
  <div class="clutch-home-section__inner">
    <header class="clutch-home-section__header">
      <p class="clutch-home-section__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="clutch-home-section__title" id="clutch-home-featured-products-heading">{{ section.settings.heading | escape }}</h2>
    </header>

    <div class="clutch-home-products__grid">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: section.settings.products_limit -%}
          <article class="clutch-home-products__card">
            <a href="{{ product.url }}" class="clutch-home-products__image-link" aria-label="{{ product.title | escape }}">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag: class: 'clutch-home-products__image', loading: 'lazy', widths: '400, 800', sizes: '(min-width: 768px) 25vw, 100vw', alt: product.title }}
              {%- else -%}
                <div class="clutch-home-products__image clutch-home-products__image--placeholder" aria-hidden="true">
                  <span>{{ product.vendor | escape }}</span>
                </div>
              {%- endif -%}
            </a>
            <div class="clutch-home-products__body">
              <p class="clutch-home-products__brand">{{ product.vendor | escape }}</p>
              <h3 class="clutch-home-products__name">
                <a href="{{ product.url }}">{{ product.title | escape }}</a>
              </h3>
              <p class="clutch-home-products__price">{{ product.price | money }}</p>
              <form method="post" action="/cart/add" class="clutch-home-products__form" accept-charset="UTF-8">
                <input type="hidden" name="form_type" value="product">
                <input type="hidden" name="utf8" value="✓">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <button type="submit" class="clutch-button clutch-button--copper" {% unless product.available %}disabled{% endunless %}>
                  {%- if product.available -%}Quick Add{%- else -%}Out of Stock{%- endif -%}
                </button>
              </form>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        <p class="clutch-home-products__empty" style="text-align: center; color: var(--clutch-muted);">No products found. Select a collection in theme settings.</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Top Barbers Picks"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top Trending Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
