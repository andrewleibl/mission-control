<form id="collection-filters-form" method="get" action="{{ collection.url }}">
  <!-- Filter: By Brand -->
  <div class="filter-group">
    <h4 class="filter-group-title">Brand</h4>
    {%- assign brands = 'Andis,Wahl,JRL,Babyliss Pro,Gamma+,StyleCraft,Tomb45,Level 3,Vincent,Cocco,Morono' | split: ',' -%}
    {%- for brand in brands -%}
      <label class="filter-option">
        <input
          type="checkbox"
          name="filter.p.vendor"
          value="{{ brand | escape }}"
          {% if current_tags contains brand %}checked{% endif %}
          aria-label="Filter by {{ brand }}"
          class="filter-input"
        >
        {{ brand }}
      </label>
    {%- endfor -%}
  </div>

  <!-- Filter: Price Range -->
  <div class="filter-group">
    <h4 class="filter-group-title">Price Range</h4>
    <label class="filter-option">
      <input type="radio" name="filter.v.price" value="" {% unless request.query_string contains 'filter.v.price' %}checked{% endunless %} class="filter-input" aria-label="All prices"> All Prices
    </label>
    <label class="filter-option">
      <input type="radio" name="filter.v.price" value="0-50" {% if request.query_string contains 'filter.v.price=0-50' %}checked{% endif %} class="filter-input" aria-label="Under $50"> Under $50
    </label>
    <label class="filter-option">
      <input type="radio" name="filter.v.price" value="50-100" {% if request.query_string contains 'filter.v.price=50-100' %}checked{% endif %} class="filter-input" aria-label="$50 – $100"> $50 – $100
    </label>
    <label class="filter-option">
      <input type="radio" name="filter.v.price" value="100-200" {% if request.query_string contains 'filter.v.price=100-200' %}checked{% endif %} class="filter-input" aria-label="$100 – $200"> $100 – $200
    </label>
    <label class="filter-option">
      <input type="radio" name="filter.v.price" value="200-" {% if request.query_string contains 'filter.v.price=200-' %}checked{% endif %} class="filter-input" aria-label="Over $200"> Over $200
    </label>
  </div>

  <!-- Filter: Availability -->
  <div class="filter-group">
    <h4 class="filter-group-title">Availability</h4>
    <label class="filter-option">
      <input type="checkbox" name="filter.v.availability" value="1" {% if request.query_string contains 'filter.v.availability' %}checked{% endif %} class="filter-input" aria-label="In stock only"> In Stock
    </label>
  </div>

  <div class="filter-actions" style="margin-top: 1.5rem; display: flex; gap: 0.75rem;">
    <button type="submit" class="btn btn-primary btn-full">Apply Filters</button>
    <a href="{{ collection.url }}" class="btn btn-secondary btn-full" style="text-align: center;">Clear All</a>
  </div>
</form>
