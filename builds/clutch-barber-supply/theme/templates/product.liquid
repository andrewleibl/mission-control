<div class="product-page">
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep" aria-hidden="true">/</span>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
      {%- endif -%}
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <!-- Product Layout -->
    <div class="product-layout">

      <!-- Left: Image Gallery (60%) -->
      <div class="product-gallery">
        <div class="product-main-image" id="product-main-image">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 900 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              width="900"
              height="900"
              loading="eager"
              id="main-product-img"
              itemprop="image"
            >
          {%- else -%}
            <div class="product-card-image-placeholder" style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--color-text-dim);font-size:0.9rem;">
              No image available
            </div>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-thumbnails" role="list" aria-label="Product images">
            {%- for image in product.images -%}
              <button
                class="product-thumb{% if forloop.first %} is-active{% endif %}"
                onclick="switchImage('{{ image | image_url: width: 900 }}', this)"
                aria-label="View image {{ forloop.index }}"
                role="listitem"
              >
                <img
                  src="{{ image | image_url: width: 144 }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  width="72"
                  height="72"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Right: Product Info (40%) -->
      <div class="product-info" itemscope itemtype="https://schema.org/Product">
        <meta itemprop="name" content="{{ product.title | escape }}">
        <meta itemprop="brand" content="{{ product.vendor | escape }}">

        <!-- Brand badge -->
        <span class="product-vendor-badge" itemprop="brand">{{ product.vendor }}</span>

        <!-- Title -->
        <h1 class="product-title" itemprop="name">{{ product.title }}</h1>

        <!-- Rating -->
        <div class="product-rating" aria-label="4.8 out of 5 stars, 24 reviews">
          <span class="stars" aria-hidden="true">★★★★★</span>
          <span class="product-rating-text">(4.8) · 24 reviews</span>
        </div>

        <!-- Price -->
        <div class="product-price-row" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <span class="product-price-current" itemprop="price" content="{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}">
            {{ product.selected_or_first_available_variant.price | money }}
          </span>
          {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
            <span class="product-price-compare" aria-label="Original price {{ product.selected_or_first_available_variant.compare_at_price | money }}">
              {{ product.selected_or_first_available_variant.compare_at_price | money }}
            </span>
            {%- assign savings = product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price -%}
            <span class="product-savings" aria-label="You save {{ savings | money }}">
              Save {{ savings | money }}
            </span>
          {%- endif -%}
          <meta itemprop="priceCurrency" content="USD">
          <link itemprop="availability" href="https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}">
        </div>

        <!-- Free Shipping Note -->
        <p class="product-shipping-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Free shipping on orders $300+
        </p>

        <!-- In Stock -->
        <div class="product-stock-badge">
          <span class="stock-dot" aria-hidden="true"></span>
          {%- if product.available -%}
            In Stock — Ready to Ship
          {%- else -%}
            Out of Stock
          {%- endif -%}
        </div>

        <!-- Variant Selector -->
        {%- if product.has_only_default_variant == false -%}
          {%- for option in product.options_with_values -%}
            <div class="product-variants">
              <p class="variant-label">{{ option.name }}: <strong>{{ option.selected_value }}</strong></p>
              <div class="variant-options" role="radiogroup" aria-label="{{ option.name }} options">
                {%- for value in option.values -%}
                  <button
                    class="variant-option{% if option.selected_value == value %} is-selected{% endif %}"
                    data-option-name="{{ option.name }}"
                    data-option-value="{{ value }}"
                    aria-pressed="{{ option.selected_value == value }}"
                    aria-label="Select {{ option.name }}: {{ value }}"
                  >
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}

        <!-- Add to Cart Form -->
        {%- form 'product', product, id: 'product-form', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" id="product-variant-id" value="{{ product.selected_or_first_available_variant.id }}">

          <div class="product-form-row">
            <!-- Quantity Selector -->
            <div class="qty-selector" aria-label="Quantity selector">
              <button
                type="button"
                class="qty-btn"
                id="qty-decrease"
                aria-label="Decrease quantity"
                onclick="updateQty(-1)"
              >−</button>
              <input
                type="number"
                name="quantity"
                id="product-qty"
                value="1"
                min="1"
                max="99"
                class="qty-input"
                aria-label="Quantity"
              >
              <button
                type="button"
                class="qty-btn"
                id="qty-increase"
                aria-label="Increase quantity"
                onclick="updateQty(1)"
              >+</button>
            </div>

            <!-- Add to Cart Button -->
            <button
              type="submit"
              name="add"
              class="btn-atc"
              id="add-to-cart-btn"
              {%- unless product.available -%}disabled{%- endunless -%}
              aria-label="Add {{ product.title }} to cart"
            >
              {%- if product.available -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                Add to Cart
              {%- else -%}
                Sold Out
              {%- endif -%}
            </button>
          </div>

        {%- endform -%}

        <!-- Authorized Retailer Badge -->
        <div class="authorized-badge" aria-label="Authorized Retailer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
          Authorized Retailer — Genuine product, full warranty
        </div>

        <!-- Accordion Tabs -->
        <div class="accordion" role="list">

          <!-- Description -->
          <div class="accordion-item" role="listitem">
            <details id="tab-description">
              <summary class="accordion-trigger" aria-label="Product description">
                Description
                <span class="accordion-icon" aria-hidden="true">+</span>
              </summary>
              <div class="accordion-content" itemprop="description">
                {%- if product.description != blank -%}
                  {{ product.description }}
                {%- else -%}
                  <p>{{ product.title }} — available at Clutch Barber Supply. Shop with confidence from an authorized retailer with 15+ years of experience serving barbers in Grand Prairie, TX and beyond.</p>
                {%- endif -%}
              </div>
            </details>
          </div>

          <!-- Specs & Details -->
          <div class="accordion-item" role="listitem">
            <details id="tab-specs">
              <summary class="accordion-trigger" aria-label="Specs and details">
                Specs &amp; Details
                <span class="accordion-icon" aria-hidden="true">+</span>
              </summary>
              <div class="accordion-content">
                <ul style="list-style:disc;padding-left:1.25rem;display:flex;flex-direction:column;gap:0.35rem;">
                  <li>Brand: {{ product.vendor }}</li>
                  <li>SKU: {{ product.selected_or_first_available_variant.sku | default: 'Available upon request' }}</li>
                  {%- for tag in product.tags -%}
                    {%- if tag contains 'spec:' -%}
                      <li>{{ tag | remove: 'spec:' | strip }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                  <li>Sold by: Clutch Barber Supply — 113 South Center, Grand Prairie, TX</li>
                </ul>
              </div>
            </details>
          </div>

          <!-- Shipping & Returns -->
          <div class="accordion-item" role="listitem">
            <details id="tab-shipping">
              <summary class="accordion-trigger" aria-label="Shipping and returns policy">
                Shipping &amp; Returns
                <span class="accordion-icon" aria-hidden="true">+</span>
              </summary>
              <div class="accordion-content">
                <p style="margin-bottom:0.6rem;"><strong>Shipping</strong></p>
                <ul style="list-style:disc;padding-left:1.25rem;display:flex;flex-direction:column;gap:0.35rem;margin-bottom:1rem;">
                  <li>Free shipping on orders $300+</li>
                  <li>Standard shipping: $7.99 (orders under $300)</li>
                  <li>Ships within 1–2 business days</li>
                  <li>Estimated delivery: 3–7 business days</li>
                </ul>
                <p style="margin-bottom:0.6rem;"><strong>Returns</strong></p>
                <ul style="list-style:disc;padding-left:1.25rem;display:flex;flex-direction:column;gap:0.35rem;">
                  <li>30-day returns on unopened, unused items</li>
                  <li>Item must be in original packaging</li>
                  <li>Contact us at (214) 677-1059 to initiate a return</li>
                  <li>Defective items covered by manufacturer warranty</li>
                </ul>
              </div>
            </details>
          </div>

        </div><!-- .accordion -->

      </div><!-- .product-info -->
    </div><!-- .product-layout -->

    <!-- What Barbers Are Saying -->
    <section class="reviews-section" aria-labelledby="reviews-heading">
      <h2 class="reviews-heading" id="reviews-heading">What Barbers Are Saying</h2>
      <div class="reviews-grid">

        <div class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">★★★★★</div>
          <p class="testimonial-text">"Exactly what I needed. Legit product, fast shipping, and Clutch actually answered when I called with a question. Rare these days."</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">TJ</div>
            <div>
              <p class="testimonial-name">Terrell J.</p>
              <p class="testimonial-role">Barber · Arlington, TX</p>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">★★★★★</div>
          <p class="testimonial-text">"Been buying from Clutch for 3 years. They've never steered me wrong on gear. The staff knows barber equipment — they're not just reselling, they're actually using this stuff."</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">MA</div>
            <div>
              <p class="testimonial-name">Marcus A.</p>
              <p class="testimonial-role">Shop Owner · Irving, TX</p>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars" aria-label="5 out of 5 stars">★★★★★</div>
          <p class="testimonial-text">"Perfect condition, came with all original accessories. I'll always check Clutch first before shopping anywhere else online."</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" aria-hidden="true">JB</div>
            <div>
              <p class="testimonial-name">Janae B.</p>
              <p class="testimonial-role">Barber · Dallas, TX</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- You May Also Like -->
    <section class="also-like-section" aria-labelledby="also-like-heading">
      <h2 class="also-like-heading" id="also-like-heading">You May Also Like</h2>
      <div class="also-like-grid">

        {%- assign related_products = collections.all.products | where: 'vendor', product.vendor -%}
        {%- assign shown_count = 0 -%}
        {%- for related in related_products -%}
          {%- if related.id != product.id and shown_count < 4 -%}
            <article class="product-card">
              <a href="{{ related.url }}" class="product-card-image-wrap" aria-label="{{ related.title }}">
                {%- if related.compare_at_price > related.price -%}
                  <span class="badge-sale" aria-label="On sale">SALE</span>
                {%- endif -%}
                {%- if related.featured_image -%}
                  <img src="{{ related.featured_image | image_url: width: 400 }}" alt="{{ related.title | escape }}" width="400" height="400" loading="lazy">
                {%- else -%}
                  <div class="product-card-image-placeholder" style="display:flex;align-items:center;justify-content:center;aspect-ratio:1;background:var(--color-bg-4);"><span style="color:var(--color-text-dim);font-size:0.8rem;">{{ related.vendor }}</span></div>
                {%- endif -%}
              </a>
              <div class="product-card-body">
                <p class="product-card-vendor">{{ related.vendor }}</p>
                <h3 class="product-card-title"><a href="{{ related.url }}">{{ related.title }}</a></h3>
                <div class="product-card-price">
                  <span class="price-current">{{ related.price | money }}</span>
                  {%- if related.compare_at_price > related.price -%}
                    <span class="price-compare">{{ related.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
                <div class="product-card-actions">
                  {%- form 'product', related -%}
                    <input type="hidden" name="id" value="{{ related.selected_or_first_available_variant.id }}">
                    <button type="submit" name="add" class="btn-add-to-cart" aria-label="Add {{ related.title }} to cart">Add to Cart</button>
                  {%- endform -%}
                </div>
              </div>
            </article>
            {%- assign shown_count = shown_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}

        {%- comment %} Fallback hardcoded if no related products found {%- endcomment %}
        {%- if shown_count == 0 -%}
          <article class="product-card">
            <a href="/products/wahl-senior-clipper" class="product-card-image-wrap" aria-label="Wahl Senior Clipper">
              <div class="product-card-image-placeholder" style="display:flex;align-items:center;justify-content:center;aspect-ratio:1;background:var(--color-bg-4);"><span style="color:var(--color-text-dim);font-size:0.8rem;">Wahl</span></div>
            </a>
            <div class="product-card-body">
              <p class="product-card-vendor">Wahl</p>
              <h3 class="product-card-title"><a href="/products/wahl-senior-clipper">Wahl Senior Clipper</a></h3>
              <div class="product-card-price"><span class="price-current">$89.99</span></div>
              <div class="product-card-actions"><button class="btn-add-to-cart">Add to Cart</button></div>
            </div>
          </article>
          <article class="product-card">
            <a href="/products/babyliss-fx870-trimmer" class="product-card-image-wrap" aria-label="Babyliss FX870 Trimmer">
              <div class="product-card-image-placeholder" style="display:flex;align-items:center;justify-content:center;aspect-ratio:1;background:var(--color-bg-4);"><span style="color:var(--color-text-dim);font-size:0.8rem;">Babyliss Pro</span></div>
            </a>
            <div class="product-card-body">
              <p class="product-card-vendor">Babyliss Pro</p>
              <h3 class="product-card-title"><a href="/products/babyliss-fx870-trimmer">Babyliss FX870 Skeleton Trimmer</a></h3>
              <div class="product-card-price"><span class="price-current">$149.99</span></div>
              <div class="product-card-actions"><button class="btn-add-to-cart">Add to Cart</button></div>
            </div>
          </article>
          <article class="product-card">
            <a href="/products/tomb45-power-clip-oil" class="product-card-image-wrap" aria-label="Tomb45 Power Clip Oil">
              <div class="product-card-image-placeholder" style="display:flex;align-items:center;justify-content:center;aspect-ratio:1;background:var(--color-bg-4);"><span style="color:var(--color-text-dim);font-size:0.8rem;">Tomb45</span></div>
            </a>
            <div class="product-card-body">
              <p class="product-card-vendor">Tomb45</p>
              <h3 class="product-card-title"><a href="/products/tomb45-power-clip-oil">Tomb45 Power Clip Oil</a></h3>
              <div class="product-card-price"><span class="price-current">$24.99</span></div>
              <div class="product-card-actions"><button class="btn-add-to-cart">Add to Cart</button></div>
            </div>
          </article>
          <article class="product-card">
            <a href="/products/gamma-plus-absolute-hitter" class="product-card-image-wrap" aria-label="Gamma+ Absolute Hitter">
              <div class="product-card-image-placeholder" style="display:flex;align-items:center;justify-content:center;aspect-ratio:1;background:var(--color-bg-4);"><span style="color:var(--color-text-dim);font-size:0.8rem;">Gamma+</span></div>
            </a>
            <div class="product-card-body">
              <p class="product-card-vendor">Gamma+</p>
              <h3 class="product-card-title"><a href="/products/gamma-plus-absolute-hitter">Gamma+ Absolute Hitter Trimmer</a></h3>
              <div class="product-card-price"><span class="price-current">$159.99</span></div>
              <div class="product-card-actions"><button class="btn-add-to-cart">Add to Cart</button></div>
            </div>
          </article>
        {%- endif -%}

      </div>
    </section>

  </div><!-- .container -->
</div><!-- .product-page -->

<!-- Mobile Sticky ATC Bar -->
<div class="mobile-sticky-atc" id="mobile-sticky-atc" aria-label="Quick add to cart">
  <div class="mobile-sticky-product-info">
    <p class="mobile-sticky-title">{{ product.title | truncate: 40 }}</p>
    <p class="mobile-sticky-price">{{ product.price | money }}</p>
  </div>
  <button
    class="mobile-sticky-btn btn"
    id="mobile-atc-btn"
    onclick="document.getElementById('add-to-cart-btn').click()"
    {%- unless product.available -%}disabled{%- endunless -%}
    aria-label="Add {{ product.title }} to cart"
  >
    {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
  </button>
</div>

<script>
  // Thumbnail switcher
  function switchImage(src, btn) {
    const mainImg = document.getElementById('main-product-img');
    if (mainImg) mainImg.src = src;
    document.querySelectorAll('.product-thumb').forEach(t => t.classList.remove('is-active'));
    btn.classList.add('is-active');
  }

  // Quantity stepper
  function updateQty(delta) {
    const input = document.getElementById('product-qty');
    if (!input) return;
    let val = parseInt(input.value, 10) || 1;
    val = Math.max(1, Math.min(99, val + delta));
    input.value = val;
  }

  // Mobile sticky ATC — show after scrolling past product info
  const mobileATC = document.getElementById('mobile-sticky-atc');
  const addToCartBtn = document.getElementById('add-to-cart-btn');

  if (mobileATC && addToCartBtn) {
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) {
          mobileATC.classList.add('is-visible');
        } else {
          mobileATC.classList.remove('is-visible');
        }
      });
    }, { threshold: 0.5 });

    observer.observe(addToCartBtn);
  }

  // Variant selection
  document.querySelectorAll('.variant-option').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const optionName = this.dataset.optionName;
      const optionValue = this.dataset.optionValue;

      // Update button states
      document.querySelectorAll(`.variant-option[data-option-name="${optionName}"]`).forEach(function(b) {
        b.classList.remove('is-selected');
        b.setAttribute('aria-pressed', 'false');
      });
      this.classList.add('is-selected');
      this.setAttribute('aria-pressed', 'true');
    });
  });
</script>
