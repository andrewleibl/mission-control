<section class="brands-section" aria-labelledby="brands-grid-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-eyebrow">{{ section.settings.eyebrow | default: 'We Carry' }}</span>
      <h2 class="section-title" id="brands-grid-heading">{{ section.settings.heading | default: 'Shop by Brand' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    <div class="brands-grid">
      <a href="/collections/andis" class="brand-pill" aria-label="Shop Andis products">Andis</a>
      <a href="/collections/wahl" class="brand-pill" aria-label="Shop Wahl products">Wahl</a>
      <a href="/collections/jrl" class="brand-pill" aria-label="Shop JRL products">JRL</a>
      <a href="/collections/babyliss-pro" class="brand-pill" aria-label="Shop Babyliss Pro products">Babyliss Pro</a>
      <a href="/collections/gamma-stylecraft" class="brand-pill" aria-label="Shop Gamma products">Gamma+</a>
      <a href="/collections/gamma-stylecraft" class="brand-pill" aria-label="Shop StyleCraft products">StyleCraft</a>
      <a href="/collections/tomb45" class="brand-pill" aria-label="Shop Tomb45 products">Tomb45</a>
      <a href="/collections/level-3" class="brand-pill" aria-label="Shop Level 3 products">Level 3</a>
      <a href="/collections/vincent" class="brand-pill" aria-label="Shop Vincent products">Vincent</a>
      <a href="/collections/cocco" class="brand-pill" aria-label="Shop Cocco products">Cocco</a>
      <a href="/collections/morono" class="brand-pill" aria-label="Shop Morono products">Morono</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brands Grid",
  "tag": "section",
  "class": "brands-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "We Carry"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by Brand"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section subheading",
      "info": "Optional"
    }
  ],
  "presets": [
    {
      "name": "Brands Grid",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
