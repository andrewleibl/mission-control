<section class="clutch-home-section clutch-home-email" aria-labelledby="clutch-home-email-heading">
  <div class="clutch-home-section__inner">
    <div class="clutch-home-email__content">
      <h2 class="clutch-home-email__title" id="clutch-home-email-heading">{{ section.settings.heading | escape }}</h2>
      <p class="clutch-home-email__subtitle">{{ section.settings.subheading | escape }}</p>
      
      {%- form 'customer', id: 'clutch-email-signup', class: 'clutch-home-email__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="clutch-home-email__input-group">
          <label class="visually-hidden" for="clutch-email-input-{{ section.id }}">{{ section.settings.email_placeholder | escape }}</label>
          <input
            type="email"
            id="clutch-email-input-{{ section.id }}"
            name="contact[email]"
            placeholder="{{ section.settings.email_placeholder | escape }}"
            required
            autocorrect="off"
            autocapitalize="off"
          >
          <button type="submit" class="clutch-button clutch-button--primary">
            {{ section.settings.button_label | escape }}
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="clutch-home-email__success">{{ section.settings.success_message | escape }}</p>
        {%- endif -%}
      {%- endform -%}
      
      <p class="clutch-home-email__disclaimer">{{ section.settings.disclaimer | escape }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Clutch Home Email Signup",
  "tag": "section",
  "class": "section-clutch-home-email",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Clutch Crew"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get 10% off your first order + exclusive drops and barber tips delivered to your inbox."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get 10% Off"
    },
    {
      "type": "textarea",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in! Check your inbox for your 10% off code."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "No spam, unsubscribe anytime."
    }
  ],
  "presets": [
    {
      "name": "Clutch Home Email Signup"
    }
  ]
}
{% endschema %}
