<section class="clutch-home-section clutch-home-brands" id="brands" aria-labelledby="clutch-home-brands-heading">
  <div class="clutch-home-section__inner">
    <header class="clutch-home-section__header">
      <p class="clutch-home-section__eyebrow">{{ section.settings.eyebrow | default: 'Shop by brand' | escape }}</p>
      <h2 class="clutch-home-section__title" id="clutch-home-brands-heading">{{ section.settings.heading | default: 'Shop the Big Brands' | escape }}</h2>
      <p class="clutch-home-section__subtitle">{{ section.settings.subheading | default: 'The brands barbers swear by, ready for pickup today' | escape }}</p>
    </header>

    <div class="clutch-home-brands__grid">
      <a href="/collections/gamma-stylecraft" class="clutch-home-brands__item">
        <img src="{{ 'gamma-logo.png' | asset_url }}" alt="Gamma" class="clutch-home-brands__logo-img">
      </a>
      <a href="/collections/jrl" class="clutch-home-brands__item">
        <img src="{{ 'jrl-logo.png' | asset_url }}" alt="JRL" class="clutch-home-brands__logo-img">
      </a>
      <a href="/collections/wahl" class="clutch-home-brands__item">
        <img src="{{ 'wahl-logo.png' | asset_url }}" alt="Wahl" class="clutch-home-brands__logo-img">
      </a>
      <a href="/collections/babyliss-pro" class="clutch-home-brands__item">
        <img src="{{ 'brand-logo.png' | asset_url }}" alt="BaByliss Pro" class="clutch-home-brands__logo-img">
      </a>
      <a href="/collections/level-3" class="clutch-home-brands__item">
        <img src="{{ 'level3-logo.png' | asset_url }}" alt="Level 3" class="clutch-home-brands__logo-img">
      </a>
      <a href="/collections/andis" class="clutch-home-brands__item">
        <img src="{{ 'andis-logo.png' | asset_url }}" alt="Andis" class="clutch-home-brands__logo-img">
      </a>
      <a href="/collections/oster" class="clutch-home-brands__item">
        <img src="{{ 'oster-logo.png' | asset_url }}" alt="Oster" class="clutch-home-brands__logo-img">
      </a>
      <a href="/collections/cocco" class="clutch-home-brands__item">
        <img src="{{ 'cocco-logo.png' | asset_url }}" alt="Cocco" class="clutch-home-brands__logo-img">
      </a>
      <a href="/collections/tomb45" class="clutch-home-brands__item">
        <img src="{{ 'tomb45-logo.png' | asset_url }}" alt="Tomb45" class="clutch-home-brands__logo-img">
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Clutch Home Brands",
  "tag": "section",
  "class": "section-clutch-home-brands",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by brand"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Big Brands"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "The brands barbers swear by, ready for pickup today"
    }
  ],
  "presets": [
    {
      "name": "Clutch Home Brands"
    }
  ]
}
{% endschema %}
