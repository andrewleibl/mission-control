<section class="classes-section" aria-labelledby="classes-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-eyebrow">Education</span>
      <h2 class="section-title" id="classes-heading">
        {%- if section.settings.heading != blank -%}
          {{ section.settings.heading }}
        {%- else -%}
          Clutch Academy — Level Up Your Craft
        {%- endif -%}
      </h2>
      <p class="section-subtitle">
        {%- if section.settings.subheading != blank -%}
          {{ section.settings.subheading }}
        {%- else -%}
          Hands-on education for working barbers. TDLR approved. Real gear. Real skills.
        {%- endif -%}
      </p>
    </header>

    <div class="classes-grid">

      <!-- Class Card 1: TDLR CE Shear Class -->
      <article class="class-card" itemscope itemtype="https://schema.org/Event">
        <div class="class-card-image">
          <a href="/products/tdlr-ce-shear-class-march-29" aria-label="TDLR CE Shear Class — March 29th">
            <img
              src="https://cdn.shopify.com/s/files/1/0569/2791/2099/files/IMG-8965.png?v=1772809676"
              alt="TDLR CE Shear Class — hands-on shear training"
              width="800"
              height="450"
              loading="lazy"
              itemprop="image"
            >
          </a>
        </div>
        <div class="class-card-body">
          <div class="class-meta">
            <span class="class-badge">TDLR Approved</span>
            <span class="class-date" itemprop="startDate" content="2025-03-29">📅 March 29th, 2025</span>
          </div>
          <h3 class="class-title" itemprop="name">TDLR CE Shear Class</h3>
          <p class="class-description" itemprop="description">
            Get your CE hours while learning advanced shear techniques from industry pros. Perfect for licensed barbers looking to expand their skillset and stay compliant with Texas TDLR requirements.
          </p>
          <p class="class-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
            <span itemprop="price" content="140.00">$140.00</span>
            <meta itemprop="priceCurrency" content="USD">
          </p>
          <a href="/products/tdlr-ce-shear-class-march-29" class="btn btn-primary">
            Register Now →
          </a>
        </div>
      </article>

      <!-- Class Card 2: Stylecraft Master Class -->
      <article class="class-card" itemscope itemtype="https://schema.org/Event">
        <div class="class-card-image">
          <a href="/products/stylecraft-master-class" aria-label="Stylecraft Master Class">
            <img
              src="https://cdn.shopify.com/s/files/1/0569/2791/2099/files/E9783826-6CA5-4DCF-8C50-DD96BC534A72.jpg?v=1772033402"
              alt="Stylecraft Master Class — includes Rebel 2.0 Clipper and Flex Trimmer"
              width="800"
              height="450"
              loading="lazy"
              itemprop="image"
            >
          </a>
        </div>
        <div class="class-card-body">
          <div class="class-meta">
            <span class="class-badge">Includes Gear</span>
            <span class="class-date">🎓 Certificate of Completion</span>
          </div>
          <h3 class="class-title" itemprop="name">Stylecraft Master Class</h3>
          <p class="class-description" itemprop="description">
            Includes 1 Rebel 2.0 Clipper, 1 Flex Trimmer &amp; Certificate of Completion. Learn to cut with the best tools in the game. Taught by working professionals — no fluff, just real technique.
          </p>
          <p class="class-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
            <span itemprop="price" content="199.00">$199.00</span>
            <meta itemprop="priceCurrency" content="USD">
          </p>
          <a href="/products/stylecraft-master-class" class="btn btn-primary">
            Reserve Your Spot →
          </a>
        </div>
      </article>

    </div>

    <div class="classes-cta">
      <a href="/collections/classes-events" class="btn btn-outline">View All Classes →</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Classes & Events",
  "tag": "section",
  "class": "classes-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Clutch Academy — Level Up Your Craft"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section subheading",
      "default": "Hands-on education for working barbers. TDLR approved. Real gear. Real skills."
    }
  ],
  "presets": [
    {
      "name": "Classes & Events",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
