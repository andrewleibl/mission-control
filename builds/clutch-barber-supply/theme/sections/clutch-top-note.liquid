<section
  class="clutch-top-note-section"
  style="
    --top-note-bg: {{ section.settings.background_color }};
    --top-note-text: {{ section.settings.text_color }};
    --top-note-accent: {{ section.settings.accent_color }};
  "
  data-top-note-section
>
  <div class="clutch-top-note" role="complementary" aria-label="Store announcement" data-top-note>
    <div class="clutch-top-note__inner">
      <p class="clutch-top-note__text">
        {{ section.settings.message_left | escape }}
        <span class="clutch-top-note__dot" aria-hidden="true">{{ section.settings.separator }}</span>
        {{ section.settings.message_center | escape }}
        <span class="clutch-top-note__dot" aria-hidden="true">{{ section.settings.separator }}</span>
        {{ section.settings.message_right | escape }}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Clutch Top Note",
  "tag": "section",
  "class": "section-clutch-top-note",
  "settings": [
    {
      "type": "text",
      "id": "message_left",
      "label": "Left message",
      "default": "Free Shipping On Orders Over $300"
    },
    {
      "type": "text",
      "id": "message_center",
      "label": "Center message",
      "default": "Free 30 day return for all faulty products"
    },
    {
      "type": "text",
      "id": "message_right",
      "label": "Right message",
      "default": "Same day In Store Pickups"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "•"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#05070c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f5efe3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#c9894b"
    }
  ],
  "presets": [
    {
      "name": "Clutch Top Note"
    }
  ]
}
{% endschema %}
