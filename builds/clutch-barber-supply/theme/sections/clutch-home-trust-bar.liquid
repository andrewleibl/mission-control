<section class="clutch-home-section clutch-home-trust-bar" aria-label="Trust and guarantees">
  <div class="clutch-home-section__inner">
    <div class="clutch-home-trust-bar__grid">
      {%- for block in section.blocks -%}
        <div class="clutch-home-trust-bar__item" {{ block.shopify_attributes }}>
          <span class="clutch-home-trust-bar__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M3 7h11v8H3z"></path>
                  <path d="M14 10h3l4 3v2h-7z"></path>
                  <path d="M7 18a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm10 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"></path>
                </svg>
              {%- when 'warehouse' -%}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M3 9l9-6 9 6v11H3V9z"></path>
                  <path d="M9 22V12h6v10"></path>
                  <path d="M12 9v1"></path>
                </svg>
              {%- when 'refresh' -%}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
                  <path d="M21 3v5h-5"></path>
                  <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
                  <path d="M8 16H3v5"></path>
                </svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path>
                  <path d="m9 12 2 2 4-4"></path>
                </svg>
            {%- endcase -%}
          </span>
          <span class="clutch-home-trust-bar__text">{{ block.settings.text | escape }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Clutch Home Trust Bar",
  "tag": "section",
  "class": "section-clutch-home-trust-bar",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "warehouse", "label": "Warehouse (Local)" },
            { "value": "refresh", "label": "Refresh (Returns)" },
            { "value": "shield", "label": "Shield (Secure)" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping Over $300"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clutch Home Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "truck", "text": "Free Shipping On Orders Over $300" } },
        { "type": "trust_item", "settings": { "icon": "warehouse", "text": "Ships From Texas" } },
        { "type": "trust_item", "settings": { "icon": "refresh", "text": "30-Day Returns" } },
        { "type": "trust_item", "settings": { "icon": "shield", "text": "Secure Checkout" } }
      ]
    }
  ]
}
{% endschema %}
