<section
  class="clutch-home-header-section"
  style="
    --clutch-header-bg: {{ section.settings.background_color }};
    --clutch-header-border: {{ section.settings.border_color }};
    --clutch-header-text: {{ section.settings.text_color }};
    --clutch-header-accent: {{ section.settings.accent_color }};
  "
>
  <header class="clutch-home-header" id="clutch-home-header" data-clutch-header>
    <div class="clutch-home-header__bar">
      <div class="clutch-home-header__inner">
        <div class="clutch-home-header__left">
          <button
            type="button"
            class="clutch-home-header__icon clutch-home-header__menu"
            aria-label="Open navigation"
            aria-expanded="false"
            aria-controls="clutch-mobile-nav"
            data-clutch-nav-toggle
          >
            <span></span>
            <span></span>
            <span></span>
          </button>

          <div class="clutch-home-header__search" data-clutch-search>
            <button
              type="button"
              class="clutch-home-header__icon clutch-home-header__search-toggle"
              aria-label="Open search"
              aria-expanded="false"
              aria-controls="clutch-header-search"
              data-clutch-search-toggle
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <circle cx="11" cy="11" r="6.5"></circle>
                <path d="M16 16 21 21"></path>
              </svg>
            </button>
            <form action="{{ routes.search_url }}" method="get" role="search" class="clutch-home-header__search-panel" id="clutch-header-search">
              <label class="visually-hidden" for="clutch-header-search-input-{{ section.id }}">Search</label>
              <input
                id="clutch-header-search-input-{{ section.id }}"
                type="search"
                name="q"
                value="{{ search.terms | escape }}"
                placeholder="Search Products"
              >
            </form>
          </div>
        </div>

        <a href="{{ routes.root_url }}" class="clutch-home-header__logo" aria-label="{{ shop.name | default: 'Clutch Barber Supply' }}">
          <img
            src="{{ 'clutch-logo.png' | asset_url }}"
            alt="{{ shop.name | default: 'Clutch Barber Supply' }}"
            loading="eager"
            width="190"
            height="76"
          >
        </a>

        <div class="clutch-home-header__right">
          <nav class="clutch-home-header__desktop-nav" aria-label="Primary">
            <a href="{{ section.settings.link_one_url | default: '/collections/all' }}">{{ section.settings.link_one_label | escape }}</a>
            <a href="{{ section.settings.link_two_url | default: '#brands' }}">{{ section.settings.link_two_label | escape }}</a>
            <a href="{{ section.settings.link_three_url | default: '/pages/about' }}">{{ section.settings.link_three_label | escape }}</a>
            <a href="{{ section.settings.link_four_url | default: '/pages/contact' }}">{{ section.settings.link_four_label | escape }}</a>
            <a href="{{ section.settings.link_five_url | default: '/pages/faq' }}">{{ section.settings.link_five_label | escape }}</a>
          </nav>
          <a href="{{ routes.cart_url }}" class="clutch-home-header__icon clutch-home-header__cart" aria-label="View cart">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M3 5h2l2.1 9.2a1 1 0 0 0 1 .8H18a1 1 0 0 0 1-.8L21 8H7"></path>
              <circle cx="9" cy="19" r="1.5"></circle>
              <circle cx="17" cy="19" r="1.5"></circle>
            </svg>
            <span class="clutch-home-header__badge">{{ cart.item_count }}</span>
          </a>
        </div>
      </div>
    </div>

    <div class="clutch-home-header__overlay" data-clutch-nav-overlay hidden></div>
    <nav class="clutch-home-header__drawer" id="clutch-mobile-nav" aria-label="Mobile navigation" aria-hidden="true">
      <div class="clutch-home-header__drawer-top">
        <a href="{{ routes.root_url }}" class="clutch-home-header__drawer-logo" aria-label="{{ shop.name | default: 'Clutch Barber Supply' }}">
          <img
            src="{{ 'clutch-logo.png' | asset_url }}"
            alt="{{ shop.name | default: 'Clutch Barber Supply' }}"
            loading="lazy"
            width="160"
            height="64"
          >
        </a>
        <button type="button" class="clutch-home-header__icon" aria-label="Close navigation" data-clutch-nav-close>
          <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false">
            <path d="M5.5 5.5 14.5 14.5M14.5 5.5 5.5 14.5" />
          </svg>
        </button>
      </div>
      <div class="clutch-home-header__drawer-links">
        <a href="{{ section.settings.link_one_url | default: '/collections/all' }}">{{ section.settings.link_one_label | escape }}</a>
        <a href="{{ section.settings.link_two_url | default: '#brands' }}">{{ section.settings.link_two_label | escape }}</a>
        <a href="{{ section.settings.link_three_url | default: '/pages/about' }}">{{ section.settings.link_three_label | escape }}</a>
        <a href="{{ section.settings.link_four_url | default: '/pages/contact' }}">{{ section.settings.link_four_label | escape }}</a>
        <a href="{{ section.settings.link_five_url | default: '/pages/faq' }}">{{ section.settings.link_five_label | escape }}</a>
      </div>
    </nav>
  </header>
</section>

{% schema %}
{
  "name": "Clutch Home Header",
  "tag": "section",
  "class": "section-clutch-home-header",
  "settings": [
    {
      "type": "text",
      "id": "link_one_label",
      "label": "Link 1 label",
      "default": "Shop By Category"
    },
    {
      "type": "url",
      "id": "link_one_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "link_two_label",
      "label": "Link 2 label",
      "default": "Shop by Brand"
    },
    {
      "type": "url",
      "id": "link_two_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "link_three_label",
      "label": "Link 3 label",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "link_three_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "link_four_label",
      "label": "Link 4 label",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "link_four_url",
      "label": "Link 4 URL"
    },
    {
      "type": "text",
      "id": "link_five_label",
      "label": "Link 5 label",
      "default": "FAQ"
    },
    {
      "type": "url",
      "id": "link_five_url",
      "label": "Link 5 URL"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#091018"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#253242"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#f5efe3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#c9894b"
    }
  ],
  "presets": [
    {
      "name": "Clutch Home Header"
    }
  ]
}
{% endschema %}
