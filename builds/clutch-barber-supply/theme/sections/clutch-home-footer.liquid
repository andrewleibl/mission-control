<footer class="clutch-home-footer" aria-label="Site footer">
  <div class="clutch-home-footer__inner">
    <div class="clutch-home-footer__grid">
      
      {%- for block in section.blocks -%}
        <div class="clutch-home-footer__column" {{ block.shopify_attributes }}>
          <h3 class="clutch-home-footer__heading">{{ block.settings.title | escape }}</h3>
          <nav class="clutch-home-footer__links" aria-label="{{ block.settings.title | escape }}">
            {%- if block.settings.link_1_label != blank -%}
              <a href="{{ block.settings.link_1_url | default: '#' }}">{{ block.settings.link_1_label | escape }}</a>
            {%- endif -%}
            {%- if block.settings.link_2_label != blank -%}
              <a href="{{ block.settings.link_2_url | default: '#' }}">{{ block.settings.link_2_label | escape }}</a>
            {%- endif -%}
            {%- if block.settings.link_3_label != blank -%}
              <a href="{{ block.settings.link_3_url | default: '#' }}">{{ block.settings.link_3_label | escape }}</a>
            {%- endif -%}
            {%- if block.settings.link_4_label != blank -%}
              <a href="{{ block.settings.link_4_url | default: '#' }}">{{ block.settings.link_4_label | escape }}</a>
            {%- endif -%}
            {%- if block.settings.link_5_label != blank -%}
              <a href="{{ block.settings.link_5_url | default: '#' }}">{{ block.settings.link_5_label | escape }}</a>
            {%- endif -%}
          </nav>
        </div>
      {%- endfor -%}
      
    </div>
    
    <div class="clutch-home-footer__bottom">
      <div class="clutch-home-footer__social" aria-label="Social media">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" focusable="false">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.tiktok_url != blank -%}
          <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
            </svg>
          </a>
        {%- endif -%}
      </div>
      
      <p class="clutch-home-footer__copyright">{{ section.settings.copyright_text | escape }}</p>
      
      {%- if section.settings.show_payment_icons -%}
        <div class="clutch-home-footer__payment" aria-label="Accepted payment methods">
          <span class="clutch-home-footer__payment-icon" aria-label="Visa">VISA</span>
          <span class="clutch-home-footer__payment-icon" aria-label="Mastercard">MC</span>
          <span class="clutch-home-footer__payment-icon" aria-label="American Express">AMEX</span>
          <span class="clutch-home-footer__payment-icon" aria-label="PayPal">PayPal</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Clutch Home Footer",
  "tag": "section",
  "class": "section-clutch-home-footer",
  "settings": [
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© 2026 Clutch Barber Supply. All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Shop"
        },
        {
          "type": "text",
          "id": "link_1_label",
          "label": "Link 1 label",
          "default": "Clippers & Trimmers"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "Link 1 URL"
        },
        {
          "type": "text",
          "id": "link_2_label",
          "label": "Link 2 label",
          "default": "Shears & Razors"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "Link 2 URL"
        },
        {
          "type": "text",
          "id": "link_3_label",
          "label": "Link 3 label",
          "default": "Grooming Products"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Link 3 URL"
        },
        {
          "type": "text",
          "id": "link_4_label",
          "label": "Link 4 label",
          "default": "Barber Tools"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        },
        {
          "type": "text",
          "id": "link_5_label",
          "label": "Link 5 label",
          "default": "Accessories"
        },
        {
          "type": "url",
          "id": "link_5_url",
          "label": "Link 5 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clutch Home Footer",
      "blocks": [
        {
          "type": "link_column",
          "settings": {
            "title": "Shop",
            "link_1_label": "Clippers & Trimmers",
            "link_2_label": "Shears & Razors",
            "link_3_label": "Grooming Products",
            "link_4_label": "Barber Tools",
            "link_5_label": "Accessories"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "title": "Support",
            "link_1_label": "Contact Us",
            "link_2_label": "Shipping Info",
            "link_3_label": "Returns & Exchanges",
            "link_4_label": "FAQ",
            "link_5_label": "Size Guides"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "title": "Company",
            "link_1_label": "About Us",
            "link_2_label": "Our Story",
            "link_3_label": "Store Location",
            "link_4_label": "Wholesale",
            "link_5_label": "Careers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
