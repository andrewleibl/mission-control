{%- paginate collection.products by 24 -%}
<div class="collection-page">
  <div class="container">

    <!-- Collection Header -->
    <header class="collection-header">
      <h1 class="collection-title">{{ collection.title }}</h1>
      <p class="collection-count">
        {%- if collection.products_count == 1 -%}
          {{ 'collections.products_count_one' | t: count: collection.products_count }}
        {%- else -%}
          {{ 'collections.products_count' | t: count: collection.products_count }}
        {%- endif -%}
      </p>
    </header>

    <!-- Mobile Filter Drawer Overlay -->
    <div class="filter-drawer-overlay" id="filter-drawer-overlay" aria-hidden="true"></div>

    <!-- Mobile Filter Drawer (bottom sheet) -->
    <div class="filter-drawer" id="filter-drawer" role="dialog" aria-label="{{ 'collections.filter_by' | t }}" aria-hidden="true">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
        <h3 style="font-size:1rem;font-weight:700;">{{ 'collections.filter_by' | t }}</h3>
        <button id="filter-drawer-close" style="min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;color:var(--color-text-muted);" aria-label="{{ 'general.close' | t }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      {%- render 'collection-filters' -%}
      <button class="btn btn-primary btn-full mt-3" id="filter-apply-btn">
        {{ 'collections.apply_filters' | t }}
      </button>
    </div>

    <div class="collection-layout">

      <!-- Filter Sidebar (Desktop) -->
      <aside class="filter-sidebar" aria-label="{{ 'accessibility.open_filters' | t }}">
        {%- render 'collection-filters' -%}
      </aside>

      <!-- Products Main Area -->
      <div class="collection-main">

        <!-- Toolbar -->
        <div class="collection-toolbar">
          <button
            class="filter-toggle-mobile"
            id="filter-toggle-btn"
            aria-label="{{ 'accessibility.open_filters' | t }}"
            aria-expanded="false"
            aria-controls="filter-drawer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="4" y1="6" x2="20" y2="6"/>
              <line x1="4" y1="12" x2="14" y2="12"/>
              <line x1="4" y1="18" x2="10" y2="18"/>
            </svg>
            {{ 'collections.filter' | t }}
          </button>

          <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
            <label for="sort-select" class="visually-hidden">{{ 'collections.sort_by' | t }}</label>
            <select
              name="sort_by"
              id="sort-select"
              class="sort-select"
              aria-label="{{ 'collections.sort_by' | t }}"
            >
              <option value="manual"{% if collection.sort_by == 'manual' %} selected{% endif %}>{{ 'collections.sort_featured' | t }}</option>
              <option value="best-selling"{% if collection.sort_by == 'best-selling' %} selected{% endif %}>{{ 'collections.sort_best_selling' | t }}</option>
              <option value="price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>{{ 'collections.sort_price_asc' | t }}</option>
              <option value="price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>{{ 'collections.sort_price_desc' | t }}</option>
              <option value="created-descending"{% if collection.sort_by == 'created-descending' %} selected{% endif %}>{{ 'collections.sort_newest' | t }}</option>
            </select>
          </div>
        </div>

        <!-- Product Grid -->
        {%- if collection.products.size > 0 -%}
          <div class="collection-grid" role="list" aria-label="{{ collection.title }}">
            {%- for product in collection.products -%}
              <div role="listitem">
                {%- render 'product-card', product: product, show_rating: true, lazy_load: true -%}
              </div>
            {%- endfor -%}
          </div>

        {%- else -%}
          <div class="collection-empty" style="text-align:center;padding:4rem 0;">
            <p style="font-size:1.1rem;color:var(--color-text-muted);margin-bottom:1.5rem;">
              {{ 'collections.no_products' | t }}
            </p>
            <p style="font-size:0.9rem;color:var(--color-text-dim);margin-bottom:2rem;">
              {{ 'collections.no_products_description' | t }}
            </p>
            <a href="/collections/all" class="btn btn-primary">
              {{ 'products.view_all' | t }}
            </a>
          </div>
        {%- endif -%}

        <!-- Pagination -->
        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="{{ 'accessibility.pagination_label' | t }}">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="pagination-btn" aria-label="{{ 'collections.pagination_previous' | t }}">&laquo;</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination-btn" aria-label="{{ 'collections.page' | t: page: part.title }}">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="pagination-btn is-current" aria-current="page" aria-label="{{ 'accessibility.current_page' | t: page: part.title }}">{{ part.title }}</span>
              {%- else -%}
                <span class="pagination-btn" aria-hidden="true">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="pagination-btn" aria-label="{{ 'collections.pagination_next' | t }}">&raquo;</a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      </div><!-- /.collection-main -->
    </div><!-- /.collection-layout -->
  </div><!-- /.container -->
</div><!-- /.collection-page -->
{%- endpaginate -%}
