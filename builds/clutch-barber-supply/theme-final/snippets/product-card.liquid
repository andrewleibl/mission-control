{%- comment -%}
  Reusable product card snippet.
  Usage: {% render 'product-card', product: product %}
  Parameters:
    - product (required): Shopify product object
    - show_rating: boolean, default true
    - lazy_load: boolean, default true
{%- endcomment -%}

{%- liquid
  assign show_rating = show_rating | default: true
  assign lazy_load = lazy_load | default: true
  assign loading_attr = 'lazy'
  unless lazy_load
    assign loading_attr = 'eager'
  endunless
  assign product_url = product.url | within: collection
  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif
-%}

<article class="product-card" itemscope itemtype="https://schema.org/Product">
  {%- comment %} Image wrap — links to product page {%- endcomment %}
  <a href="{{ product_url }}" class="product-card-image-wrap" aria-label="{{ product.title | escape }}">
    {%- if on_sale -%}
      <span class="badge-sale" aria-label="{{ 'products.sale' | t }}">{{ 'products.sale' | t }}</span>
    {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
      <span class="badge-new" aria-label="{{ 'products.new' | t }}">{{ 'products.new' | t }}</span>
    {%- endif -%}

    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="600"
        height="600"
        loading="{{ loading_attr }}"
        itemprop="image"
      >
    {%- else -%}
      <div class="product-card-image-placeholder" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </div>
    {%- endif -%}
  </a>

  {%- comment %} Card body {%- endcomment %}
  <div class="product-card-body">
    {%- if product.vendor != blank -%}
      <p class="product-card-vendor" itemprop="brand">{{ product.vendor }}</p>
    {%- endif -%}

    <h3 class="product-card-title" itemprop="name">
      <a href="{{ product_url }}">{{ product.title }}</a>
    </h3>

    {%- if show_rating -%}
      <div class="product-card-rating" aria-label="4.8 out of 5 stars">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <span class="rating-count">(4.8)</span>
      </div>
    {%- endif -%}

    <div class="product-card-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">

      {%- if product.price_varies -%}
        <span class="price-current" itemprop="price" content="{{ product.price_min | divided_by: 100.0 }}">
          {{ 'products.from' | t }} {{ product.price_min | money }}
        </span>
      {%- else -%}
        <span class="price-current" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">
          {{ product.price | money }}
        </span>
      {%- endif -%}

      {%- if on_sale -%}
        <span class="price-compare" aria-label="{{ 'products.original_price' | t }}: {{ product.compare_at_price | money }}">
          {{ product.compare_at_price | money }}
        </span>
      {%- endif -%}
    </div>

    <div class="product-card-actions">
      {%- if product.available -%}
        {%- form 'product', product -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <button
            type="submit"
            name="add"
            class="btn-add-to-cart"
            aria-label="{{ 'products.add_to_cart' | t }}: {{ product.title | escape }}"
          >
            {{ 'products.add_to_cart' | t }}
          </button>
        {%- endform -%}
      {%- else -%}
        <button class="btn-add-to-cart" disabled aria-label="{{ 'products.sold_out' | t }}">
          {{ 'products.sold_out' | t }}
        </button>
      {%- endif -%}
      <a href="{{ product_url }}" class="product-card-view-link">
        {{ 'products.view_details' | t }} →
      </a>
    </div>
  </div>
</article>
