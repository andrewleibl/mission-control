{%- comment -%}
  Hamburger menu icon SVG snippet.
  Usage: {% render 'icon-hamburger' %}
  Parameters:
    - is_active: boolean — if true, renders an X/close icon instead
{%- endcomment -%}
{%- if is_active -%}
<svg
  width="{{ width | default: 22 }}"
  height="{{ height | default: 22 }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  <line x1="18" y1="6" x2="6" y2="18"></line>
  <line x1="6" y1="6" x2="18" y2="18"></line>
</svg>
{%- else -%}
<svg
  width="{{ width | default: 22 }}"
  height="{{ height | default: 22 }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  <line x1="3" y1="6" x2="21" y2="6"></line>
  <line x1="3" y1="12" x2="21" y2="12"></line>
  <line x1="3" y1="18" x2="21" y2="18"></line>
</svg>
{%- endif -%}
