<section class="trust-bar" aria-label="Trust indicators">
  <div class="trust-bar-inner">
    <div class="trust-item">
      <span class="trust-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M3 7h11v8H3z"></path>
          <path d="M14 10h3l3 3v2h-6z"></path>
          <circle cx="8" cy="18" r="2"></circle>
          <circle cx="18" cy="18" r="2"></circle>
        </svg>
      </span>
      <span>{{ section.settings.item_1_text | escape }}</span>
    </div>
    <div class="trust-item">
      <span class="trust-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 21s6-5.2 6-11a6 6 0 1 0-12 0c0 5.8 6 11 6 11Z"></path>
          <circle cx="12" cy="10" r="2.5"></circle>
        </svg>
      </span>
      <span>{{ section.settings.item_2_text | escape }}</span>
    </div>
    <div class="trust-item">
      <span class="trust-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 3 5 6v6c0 4.6 3.1 7.8 7 9 3.9-1.2 7-4.4 7-9V6l-7-3Z"></path>
          <path d="m9.5 12 1.8 1.8 3.7-4"></path>
        </svg>
      </span>
      <span>{{ section.settings.item_3_text | escape }}</span>
    </div>
    <div class="trust-item">
      <span class="trust-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M6.6 4.8h3.1l1.4 3.6-2 1.7a16 16 0 0 0 4.8 4.8l1.7-2 3.6 1.4v3.1c0 .8-.7 1.5-1.5 1.5A15.5 15.5 0 0 1 5.1 6.3c0-.8.7-1.5 1.5-1.5Z"></path>
        </svg>
      </span>
      <span><a href="tel:2146771059">{{ section.settings.item_4_text | escape }}</a></span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "trust-bar-section",
  "settings": [
    {
      "type": "header",
      "content": "Trust Bar Items",
      "info": "Edit the store's trust signals displayed to customers."
    },
    {
      "type": "text",
      "id": "item_1_text",
      "label": "Item 1",
      "default": "Free Shipping $300+"
    },
    {
      "type": "text",
      "id": "item_2_text",
      "label": "Item 2",
      "default": "Grand Prairie, TX — Real Store"
    },
    {
      "type": "text",
      "id": "item_3_text",
      "label": "Item 3",
      "default": "Authorized Retailer for 10+ Brands"
    },
    {
      "type": "text",
      "id": "item_4_text",
      "label": "Item 4",
      "default": "Call Us: (214) 677-1059"
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
