{%- comment -%}
  Brands Page Header Section
  1:1 conversion from preview-brands.html
{%- endcomment -%}

<div
  class="page-header"
  style="
    --brands-header-bg-start: {{ section.settings.bg_gradient_start }};
    --brands-header-bg-end: {{ section.settings.bg_gradient_end }};
    --brands-header-accent: {{ section.settings.accent_color }};
  "
>
  <h1>{{ section.settings.title | escape }}</h1>
  <p>{{ section.settings.subtitle | escape }}</p>
</div>

<style>
  .page-header {
    padding: 4rem 1.5rem;
    text-align: center;
    background: linear-gradient(180deg, var(--brands-header-bg-start) 0%, var(--brands-header-bg-end) 100%);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(201, 137, 75, 0.2) 0%, transparent 60%);
    filter: blur(80px);
    pointer-events: none;
  }
  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    color: #f5efe3;
  }
  .page-header p {
    color: #d1c7b3;
    position: relative;
    z-index: 1;
    font-size: 1.125rem;
  }
</style>

{% schema %}
{
  "name": "Brands Page Header",
  "tag": "section",
  "class": "section-brands-page-header",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "Shopping Brands"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The brands barbers trust. All in one place."
    },
    {
      "type": "color",
      "id": "bg_gradient_start",
      "label": "Background Gradient Start",
      "default": "#091018"
    },
    {
      "type": "color",
      "id": "bg_gradient_end",
      "label": "Background Gradient End",
      "default": "#05070c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#c9894b"
    }
  ],
  "presets": [
    {
      "name": "Brands Page Header"
    }
  ]
}
{% endschema %}
