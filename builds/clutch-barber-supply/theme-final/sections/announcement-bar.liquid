{%- if section.settings.enable_announcement_bar -%}
  <div class="announcement-bar" role="complementary" aria-label="Announcement">
    {%- if section.settings.announcement_text != blank -%}
      {{ section.settings.announcement_text }}
    {%- else -%}
      🚚 Free shipping on orders $300+&nbsp;&nbsp;|&nbsp;&nbsp;📍 Grand Prairie, TX&nbsp;&nbsp;|&nbsp;&nbsp;📞 <a href="tel:2146771059">(214) 677-1059</a>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_announcement_bar",
      "label": "Enable announcement bar",
      "default": true
    },
    {
      "type": "richtext",
      "id": "announcement_text",
      "label": "Announcement text",
      "info": "Leave blank to use the default store info. You can add links.",
      "default": "<p>🚚 Free shipping on orders $300+&nbsp;&nbsp;|&nbsp;&nbsp;📍 Grand Prairie, TX&nbsp;&nbsp;|&nbsp;&nbsp;📞 (214) 677-1059</p>"
    },
    {
      "type": "color",
      "id": "bar_bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bar_text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "category": "Header"
    }
  ]
}
{% endschema %}
