            </div>
          </div>
        </article>

        <!-- Product 3: Andis Master Cordless -->
        <article class="product-card">
          <a href="/products/andis-master-cordless" class="product-card-image-wrap" aria-label="Andis Master Cordless Clipper">
            <div class="product-card-image-placeholder" style="background: linear-gradient(135deg, #1a1a1a, #2a2a2a); display:flex; align-items:center; justify-content:center; aspect-ratio:1; color:#555; font-size:0.8rem; flex-direction:column; gap:0.5rem;">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="3"/></svg>
              <span>Andis</span>
