        <!-- Product 5: Babyliss FX870 -->
        <article class="product-card">
          <a href="/products/babyliss-fx870-trimmer" class="product-card-image-wrap" aria-label="Babyliss FX870 Skeleton Trimmer">
            <div class="product-card-image-placeholder" style="background: linear-gradient(135deg, #1a1a1a, #2a2a2a); display:flex; align-items:center; justify-content:center; aspect-ratio:1; color:#555; font-size:0.8rem; flex-direction:column; gap:0.5rem;">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="3"/></svg>
              <span>Babyliss Pro</span>
            </div>
          </a>
          <div class="product-card-body">
            <p class="product-card-vendor">Babyliss Pro</p>
            <h3 class="product-card-title"><a href="/products/babyliss-fx870-trimmer">Babyliss FX870 Skeleton Trimmer</a></h3>
            <div class="product-card-rating" aria-label="4.7 out of 5 stars">
              <span class="stars" aria-hidden="true">★★★★★</span>
