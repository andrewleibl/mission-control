<section class="products-section" aria-labelledby="featured-products-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-eyebrow">{{ section.settings.eyebrow | default: 'Top Picks' }}</span>
      <h2 class="section-title" id="featured-products-heading">{{ section.settings.heading | default: 'Best Sellers' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- assign product_list = section.settings.product_list -%}

    {%- if product_list.count > 0 -%}
      {%- comment %} Live Shopify — use actual product objects {%- endcomment %}
      <div class="products-grid">
        {%- for product in product_list limit: section.settings.products_to_show -%}
          <article class="product-card" itemscope itemtype="https://schema.org/Product">
            <a href="{{ product.url }}" class="product-card-image-wrap" aria-label="{{ product.title }}">
              {%- if product.compare_at_price > product.price -%}
                <span class="badge-sale" aria-label="On sale">SALE</span>
              {%- endif -%}
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="600"
                  height="600"
                  loading="lazy"
                  itemprop="image"
                >
              {%- else -%}
                <div class="product-card-image-placeholder">No image</div>
              {%- endif -%}
            </a>
            <div class="product-card-body">
              <p class="product-card-vendor" itemprop="brand">{{ product.vendor }}</p>
              <h3 class="product-card-title" itemprop="name">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <div class="product-card-rating" aria-label="4.8 out of 5 stars">
                <span class="stars" aria-hidden="true">★★★★★</span>
                <span class="rating-count">(4.8) · 24 reviews</span>
              </div>
              <div class="product-card-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                <span class="price-current" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">
                  {{ product.price | money }}
                </span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="price-compare" aria-label="Original price {{ product.compare_at_price | money }}">
                    {{ product.compare_at_price | money }}
                  </span>
                {%- endif -%}
              </div>
              <div class="product-card-actions">
                {%- form 'product', product -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" name="add" class="btn-add-to-cart" aria-label="Add {{ product.title }} to cart">
                    Add to Cart
                  </button>
                {%- endform -%}
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- comment %} Static preview with real product data {%- endcomment %}
      <div class="products-grid">

        <!-- Product 1: Morono Razor Handle (SALE) -->
        <article class="product-card">
          <a href="/products/morono-razor-handle" class="product-card-image-wrap" aria-label="Morono Razor Handle">
            <span class="badge-sale" aria-label="On sale">SALE</span>
            <img
              src="https://cdn.shopify.com/s/files/1/0569/2791/2099/files/626849F3-0852-4E77-AE1D-18EA97D7B738.jpg?v=1772930127"
              alt="Morono Razor Handle — professional straight razor handle"
              width="600"
              height="600"
              loading="lazy"
            >
          </a>
          <div class="product-card-body">
