<div class="popup-backdrop" id="email-popup" role="dialog" aria-modal="true" aria-labelledby="popup-heading" aria-describedby="popup-subheading">
  <div id="popup-overlay" style="position:absolute;inset:0;" aria-hidden="true"></div>
  <div class="popup-modal" role="document">
    <button class="popup-close" id="popup-close-btn" aria-label="Close popup">×</button>

    <div class="popup-badge" aria-hidden="true">🔥</div>

    <h2 class="popup-heading" id="popup-heading">
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- else -%}
        Get 10% Off Your First Order
      {%- endif -%}
    </h2>

    <p class="popup-subheading" id="popup-subheading">
      {%- if section.settings.subheading != blank -%}
        {{ section.settings.subheading }}
      {%- else -%}
        Join 1,000+ barbers shopping at Clutch. Pro gear at shop prices.
      {%- endif -%}
    </p>

    <form class="popup-form" id="popup-form" novalidate>
      <input
        type="email"
        name="email"
        class="popup-input"
        placeholder="your@email.com"
        required
        aria-label="Email address"
        autocomplete="email"
      >
      <button type="submit" class="popup-submit">
        {{ section.settings.button_text | default: 'Claim My 10% Off' }}
      </button>
      <p class="popup-disclaimer">No spam. Unsubscribe anytime.</p>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Email Popup",
  "tag": "section",
  "class": "email-popup-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_popup",
      "label": "Enable email popup",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Popup heading",
      "default": "Get 10% Off Your First Order"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Popup subheading",
      "default": "Join 1,000+ barbers shopping at Clutch. Pro gear at shop prices."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Claim My 10% Off"
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "label": "Delay before showing (seconds)",
      "min": 5,
      "max": 120,
      "step": 5,
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Email Popup",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
