{%- comment -%}
  Brands Featured Marquee Section
  Horizontal scrolling featured brands
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
<section class="featured-marquee">
  <div class="featured-marquee__track">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.brand_url }}" class="featured-marquee__item" {{ block.shopify_attributes }}>
        <span class="featured-marquee__badge">{{ block.settings.badge_text | escape }}</span>
        <span class="featured-marquee__brand">{{ block.settings.brand_name | escape }}</span>
        <div class="featured-marquee__products">
          {%- if block.settings.show_icon_1 -%}
            <span class="featured-marquee__product-tag" title="{{ block.settings.icon_1_label }}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="6" r="2.5"/><circle cx="16" cy="6" r="2.5"/><line x1="8" y1="6" x2="14" y2="18"/><line x1="16" y1="6" x2="10" y2="18"/></svg>
            </span>
          {%- endif -%}
          {%- if block.settings.show_icon_2 -%}
            <span class="featured-marquee__product-tag" title="{{ block.settings.icon_2_label }}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="6" y1="4" x2="18" y2="4"/><line x1="9" y1="4" x2="9" y2="8"/><line x1="15" y1="4" x2="15" y2="8"/><rect x="10" y="8" width="4" height="10" rx="1"/><line x1="12" y1="18" x2="12" y2="21"/></svg>
            </span>
          {%- endif -%}
          {%- if block.settings.show_icon_3 -%}
            <span class="featured-marquee__product-tag" title="{{ block.settings.icon_3_label }}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="6" y="4" width="12" height="5" rx="2"/><rect x="9" y="9" width="6" height="10" rx="1"/><line x1="9" y1="6" x2="15" y2="6"/></svg>
            </span>
          {%- endif -%}
        </div>
        <span class="featured-marquee__price">{{ block.settings.price_range | escape }}</span>
        <span class="featured-marquee__desc">{{ block.settings.description | escape }}</span>
      </a>
    {%- endfor -%}
    {%- comment -%}Duplicate for seamless loop{%- endcomment -%}
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.brand_url }}" class="featured-marquee__item" aria-hidden="true">
        <span class="featured-marquee__badge">{{ block.settings.badge_text | escape }}</span>
        <span class="featured-marquee__brand">{{ block.settings.brand_name | escape }}</span>
        <div class="featured-marquee__products">
          {%- if block.settings.show_icon_1 -%}<span class="featured-marquee__product-tag"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="6" r="2.5"/><circle cx="16" cy="6" r="2.5"/><line x1="8" y1="6" x2="14" y2="18"/><line x1="16" y1="6" x2="10" y2="18"/></svg></span>{%- endif -%}
          {%- if block.settings.show_icon_2 -%}<span class="featured-marquee__product-tag"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="6" y1="4" x2="18" y2="4"/><line x1="9" y1="4" x2="9" y2="8"/><line x1="15" y1="4" x2="15" y2="8"/><rect x="10" y="8" width="4" height="10" rx="1"/><line x1="12" y1="18" x2="12" y2="21"/></svg></span>{%- endif -%}
          {%- if block.settings.show_icon_3 -%}<span class="featured-marquee__product-tag"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="6" y="4" width="12" height="5" rx="2"/><rect x="9" y="9" width="6" height="10" rx="1"/><line x1="9" y1="6" x2="15" y2="6"/></svg></span>{%- endif -%}
        </div>
        <span class="featured-marquee__price">{{ block.settings.price_range | escape }}</span>
        <span class="featured-marquee__desc">{{ block.settings.description | escape }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

<style>
  .featured-marquee {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    overflow: hidden;
  }
  .featured-marquee__track {
    display: flex;
    gap: 1.5rem;
    animation: marquee-scroll 20s linear infinite;
    width: max-content;
  }
  .featured-marquee:hover .featured-marquee__track {
    animation-play-state: paused;
  }
  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .featured-marquee__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 2.5rem;
    background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
    border: 1px solid #253242;
    border-radius: 16px;
    min-width: 240px;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
  }
  .featured-marquee__item:hover {
    border-color: rgba(201, 137, 75, 0.5);
    box-shadow: 0 16px 32px rgba(0,0,0,0.3);
    transform: translateY(-4px);
  }
  .featured-marquee__badge {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #c9894b;
    margin-bottom: 0.5rem;
  }
  .featured-marquee__brand {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: #f5efe3;
  }
  .featured-marquee__products {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .featured-marquee__product-tag {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(255,255,255,0.08);
    border: 1px solid #253242;
    border-radius: 6px;
    color: #9ca3af;
    transition: all 0.2s;
  }
  .featured-marquee__product-tag:hover {
    border-color: #c9894b;
    color: #c9894b;
  }
  .featured-marquee__price {
    font-size: 0.75rem;
    font-weight: 600;
    color: #c9894b;
    padding: 0.375rem 0.75rem;
    background: rgba(201, 137, 75, 0.1);
    border: 1px solid rgba(201, 137, 75, 0.3);
    border-radius: 50px;
    margin-bottom: 0.75rem;
  }
  .featured-marquee__desc {
    font-size: 0.875rem;
    color: #d1c7b3;
    line-height: 1.5;
  }
</style>

{% schema %}
{
  "name": "Brands Featured Marquee",
  "tag": "section",
  "class": "section-brands-marquee",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "featured_brand",
      "name": "Featured Brand",
      "settings": [
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "default": "Top Seller"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "default": "Andis"
        },
        {
          "type": "url",
          "id": "brand_url",
          "label": "Brand URL"
        },
        {
          "type": "text",
          "id": "price_range",
          "label": "Price Range",
          "default": "Mid-Range • $100-$200"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "#1 in barbershops nationwide"
        },
        {
          "type": "checkbox",
          "id": "show_icon_1",
          "label": "Show Clippers Icon",
          "default": true
        },
        {
          "type": "text",
          "id": "icon_1_label",
          "label": "Icon 1 Label",
          "default": "Clippers"
        },
        {
          "type": "checkbox",
          "id": "show_icon_2",
          "label": "Show Trimmers Icon",
          "default": true
        },
        {
          "type": "text",
          "id": "icon_2_label",
          "label": "Icon 2 Label",
          "default": "Trimmers"
        },
        {
          "type": "checkbox",
          "id": "show_icon_3",
          "label": "Show Shavers Icon",
          "default": true
        },
        {
          "type": "text",
          "id": "icon_3_label",
          "label": "Icon 3 Label",
          "default": "Shavers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brands Featured Marquee",
      "blocks": [
        { "type": "featured_brand" },
        { "type": "featured_brand" },
        { "type": "featured_brand" },
        { "type": "featured_brand" },
        { "type": "featured_brand" }
      ]
    }
  ]
}
{% endschema %}
