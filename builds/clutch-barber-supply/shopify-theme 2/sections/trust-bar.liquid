<section class="clutch-home-trust-bar">
  <div class="clutch-home-section__inner">
    <div class="clutch-home-trust-bar__grid">
      {% for block in section.blocks %}
        <div class="clutch-home-trust-bar__item" {{ block.shopify_attributes }}>
          <span class="clutch-home-trust-bar__icon">
            {% if block.settings.icon == 'shipping' %}
              <svg viewBox="0 0 24 24"><path d="M3 7h11v8H3z"/><path d="M14 10h3l4 3v2h-7z"/><path d="M7 18a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm10 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"/></svg>
            {% elsif block.settings.icon == 'location' %}
              <svg viewBox="0 0 24 24"><path d="M3 9l9-6 9 6v11H3V9z"/><path d="M9 22V12h6v10"/></svg>
            {% elsif block.settings.icon == 'returns' %}
              <svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
            {% elsif block.settings.icon == 'secure' %}
              <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
            {% else %}
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
            {% endif %}
          </span>
          <span class="clutch-home-trust-bar__text">{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.clutch-home-trust-bar {
  background: var(--clutch-bg-light);
  border-top: 1px solid var(--clutch-border);
  border-bottom: 1px solid var(--clutch-border);
  padding: 2rem 0;
}
.clutch-home-trust-bar__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}
@media (min-width: 768px) {
  .clutch-home-trust-bar__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
.clutch-home-trust-bar__item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  background: rgba(255,255,255,0.02);
  border: 1px solid var(--clutch-border);
  border-radius: 12px;
  transition: all 0.2s;
}
.clutch-home-trust-bar__item:hover {
  border-color: rgba(201, 137, 75, 0.4);
}
.clutch-home-trust-bar__icon {
  width: 2.5rem;
  height: 2.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 137, 75, 0.1);
  border-radius: 8px;
}
.clutch-home-trust-bar__icon svg {
  width: 1.25rem;
  height: 1.25rem;
  stroke: var(--clutch-accent);
  stroke-width: 1.5;
  fill: none;
}
.clutch-home-trust-bar__text {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--clutch-text-muted);
}
</style>

{% schema %}
{
  "name": "Trust Bar",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "location", "label": "Location" },
            { "value": "returns", "label": "Returns" },
            { "value": "secure", "label": "Secure" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping On Orders Over $300"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "trust_item",
        "settings": {
          "icon": "shipping",
          "text": "Free Shipping On Orders Over $300"
        }
      },
      {
        "type": "trust_item",
        "settings": {
          "icon": "location",
          "text": "Ships From Texas"
        }
      },
      {
        "type": "trust_item",
        "settings": {
          "icon": "returns",
          "text": "30-Day Returns"
        }
      },
      {
        "type": "trust_item",
        "settings": {
          "icon": "secure",
          "text": "Secure Checkout"
        }
      }
    ]
  },
  "presets": [
    {
      "name": "Trust Bar"
    }
  ]
}
{% endschema %}