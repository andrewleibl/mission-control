<header class="clutch-header" data-section-id="{{ section.id }}" data-section-type="header">
  <div class="clutch-header__inner">
    <a href="{{ routes.root_url }}" class="clutch-header__logo">
      {% if settings.logo != blank %}
        <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="200" height="80" loading="eager">
      {% else %}
        <span class="h2">{{ shop.name }}</span>
      {% endif %}
    </a>
    
    <div style="display: flex; align-items: center; gap: 1.5rem;">
      <nav class="clutch-header__nav">
        {% for link in section.settings.menu.links %}
          {% if link.title == 'Supplies' %}
            <div class="clutch-header__dropdown">
              <a href="{{ link.url }}">{{ link.title }}</a>
              <div class="clutch-header__dropdown-menu">
                {% for childlink in link.links %}
                  <a href="/collections/all?category={{ childlink.title | handleize }}" class="clutch-header__dropdown-item">{{ childlink.title }}</a>
                {% endfor %}
              </div>
            </div>
          {% elsif link.title == 'Brands' %}
            <div class="clutch-header__dropdown">
              <a href="{{ link.url }}">{{ link.title }}</a>
              <div class="clutch-header__dropdown-menu">
                {% for childlink in link.links %}
                  <a href="/collections/all?vendor={{ childlink.title | url_encode }}" class="clutch-header__dropdown-item">{{ childlink.title }}</a>
                {% endfor %}
              </div>
            </div>
          {% elsif link.title == 'About' %}
            <!-- About page hidden for now -->
          {% elsif link.title == 'Classes' %}
            <a href="{{ link.url }}" {% if link.active %}class="active"{% endif %}>{{ link.title }}</a>
          {% else %}
            <a href="{{ link.url }}" {% if link.active %}class="active"{% endif %}>{{ link.title }}</a>
          {% endif %}
        {% endfor %}
      </nav>
      
      <form action="{{ routes.search_url }}" method="get" class="clutch-header__search" role="search">
        <input type="search" name="q" placeholder="Search products..." value="{{ search.terms | escape }}" aria-label="Search">
        <button type="submit" aria-label="Submit search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </button>
      </form>

      <a href="{{ routes.cart_url }}" class="clutch-header__cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 5h2l2.1 9.2a1 1 0 0 0 1 .8H18a1 1 0 0 0 1-.8L21 8H7"/>
          <circle cx="9" cy="19" r="1.5"/><circle cx="17" cy="19" r="1.5"/>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="clutch-header__badge">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}
