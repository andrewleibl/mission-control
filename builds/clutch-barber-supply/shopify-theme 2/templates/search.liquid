{% paginate search.results by 24 %}

<div class="page-header">
  <h1>Search Results</h1>
  {% if search.terms != blank %}
    <p class="breadcrumbs">{{ search.results_count }} results for "{{ search.terms }}"</p>
  {% endif %}
</div>

<div class="collection-layout">
  <aside class="filters-sidebar">
    <h3>Filter by Type</h3>
    <div class="filter-group">
      <label class="filter-option">
        <input type="checkbox" checked disabled> Products
      </label>
      <label class="filter-option">
        <input type="checkbox" disabled> Collections
      </label>
      <label class="filter-option">
        <input type="checkbox" disabled> Pages
      </label>
    </div>
  </aside>

  <div class="products-area">
    {% if search.results_count == 0 and search.terms != blank %}
      <div style="text-align: center; padding: 3rem;">
        <h2 style="margin-bottom: 1rem;">No results found</h2>
        <p style="color: var(--clutch-text-muted);">Try searching for something else or check your spelling.</p>
      </div>
    {% else %}
      <div class="products-grid">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            <div class="product-card">
              <div class="product-card__image">
                {% if item.featured_image %}
                  <a href="{{ item.url }}">
                    <img src="{{ item.featured_image | image_url: width: 400 }}" alt="{{ item.featured_image.alt | escape }}" loading="lazy">
                  </a>
                {% endif %}
                <form action="/cart/add" method="post" class="product-card__quick-add">
                  <input type="hidden" name="id" value="{{ item.selected_or_first_available_variant.id }}">
                  <button type="submit" {% unless item.available %}disabled{% endunless %}>
                    {% if item.available %}Quick Add{% else %}Sold Out{% endif %}
                  </button>
                </form>
              </div>
              <div class="product-card__info">
                <p class="product-card__brand">{{ item.vendor }}</p>
                <h3 class="product-card__name">
                  <a href="{{ item.url }}">{{ item.title }}</a>
                </h3>
                <div class="product-card__price">
                  <span class="product-card__price-current">{{ item.price | money }}</span>
                  {% if item.compare_at_price > item.price %}
                    <span class="product-card__price-compare">{{ item.compare_at_price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}">←</a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {% else %}
              <span>{{ part.title }}</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}">→</a>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

{% endpaginate %}
