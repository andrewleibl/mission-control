<script>
function changeImage(src, thumb) {
  document.getElementById('mainImage').src = src;
  document.querySelectorAll('.product-gallery__thumb').forEach(t => t.classList.remove('active'));
  thumb.classList.add('active');
}

function updateQuantity(change) {
  const input = document.getElementById('quantityInput');
  const newValue = parseInt(input.value) + change;
  if (newValue >= 1) input.value = newValue;
}

function selectVariant(id, price, comparePrice, available) {
  document.getElementById('variantId').value = id;
  
  // Update UI
  document.querySelectorAll('.product-option').forEach(btn => btn.classList.remove('selected'));
  document.querySelector(`[data-variant-id="${id}"]`).classList.add('selected');
  
  // Update price display
  const priceDisplay = document.querySelector('.product-info__price-current');
  const compareDisplay = document.querySelector('.product-info__price-compare');
  
  priceDisplay.textContent = formatMoney(price);
  if (comparePrice > price) {
    compareDisplay.textContent = formatMoney(comparePrice);
    compareDisplay.style.display = '';
  } else {
    compareDisplay.style.display = 'none';
  }
  
  // Update add to cart button
  const btn = document.getElementById('addToCartBtn');
  if (available) {
    btn.disabled = false;
    btn.textContent = `Add to Cart - ${formatMoney(price)}`;
  } else {
    btn.disabled = true;
    btn.textContent = 'Sold Out';
  }
}

function formatMoney(cents) {
  return '$' + (cents / 100).toFixed(2);
}

// Viewer counter - changes every 10 seconds between 2-5
function updateViewerCount() {
  const min = 2;
  const max = 5;
  const count = Math.floor(Math.random() * (max - min + 1)) + min;
  const viewerElement = document.getElementById('viewerCount');
  if (viewerElement) {
    viewerElement.textContent = count;
  }
}

// Update every 10 seconds
setInterval(updateViewerCount, 10000);

// Initial update
updateViewerCount();
</script>

<style>
/* Product Page Layout - Optimized */
.product-page {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1rem;
}

.product-page--optimized {
  grid-template-columns: 45% 55%;
}

@media (max-width: 900px) {
  .product-page {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  
  .product-page--optimized {
    grid-template-columns: 1fr;
  }
}

/* Left Side - Images */
.product-left {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.product-gallery {
  background: var(--clutch-navy);
  border: 1px solid var(--clutch-border);
  border-radius: 16px;
  overflow: hidden;
}

.product-gallery__main {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.03);
  padding: 1.5rem;
  max-height: 495px;
}

.product-gallery__main img {
  max-height: 100%;
  max-width: 100%;
  object-fit: contain;
}

.product-gallery__main img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.product-gallery__thumbs {
  display: flex;
  gap: 0.75rem;
  padding: 1rem;
  border-top: 1px solid var(--clutch-border);
  overflow-x: auto;
}

.product-gallery__thumb {
  width: 64px;
  height: 64px;
  flex-shrink: 0;
  background: rgba(255,255,255,0.03);
  border: 2px solid transparent;
  border-radius: 8px;
  overflow: hidden;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.375rem;
}

.product-gallery__thumb.active {
  border-color: var(--clutch-copper);
}

.product-gallery__thumb img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

/* Description */
.product-description {
  font-size: 0.9375rem;
  line-height: 1.7;
  color: var(--clutch-text-muted);
}

/* Right Side - Info */
.product-right {
  display: flex;
  flex-direction: column;
}

.product-info__brand {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--clutch-copper);
  margin-bottom: 0.5rem;
}

.product-info__title {
  font-size: 1.75rem;
  font-weight: 700;
  margin: 0 0 1rem;
  line-height: 1.2;
}

/* Viewing Now Counter */
.viewing-now {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.75rem;
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 8px;
  margin-bottom: 1rem;
  font-size: 0.8125rem;
  color: var(--clutch-text-muted);
  width: fit-content;
}

.viewing-dot {
  width: 8px;
  height: 8px;
  background: #ef4444;
  border-radius: 50%;
  animation: pulse-red 2s ease-in-out infinite;
}

@keyframes pulse-red {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.2); }
}

.viewing-text strong {
  color: #ef4444;
  font-weight: 700;
}

/* Price */
.product-info__price {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.25rem;
}

.product-info__price-current {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--clutch-copper);
}

.product-info__price-compare {
  font-size: 1rem;
  text-decoration: line-through;
  color: var(--clutch-text-dim);
}

.product-info__savings {
  padding: 0.25rem 0.5rem;
  background: rgba(34, 197, 94, 0.1);
  border: 1px solid rgba(34, 197, 94, 0.3);
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 600;
  color: #22c55e;
}

/* Trust Bar */
.product-trust-bar {
  display: flex;
  gap: 1.5rem;
  padding: 0.75rem 0;
  margin-bottom: 1.25rem;
  border-top: 1px solid var(--clutch-border);
  border-bottom: 1px solid var(--clutch-border);
}

.product-trust-bar .trust-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8125rem;
  color: var(--clutch-text-muted);
}

.product-trust-bar .trust-item svg {
  stroke: var(--clutch-copper);
  flex-shrink: 0;
}

/* Info Accordion */
.product-info-accordion {
  margin-bottom: 1.5rem;
}

.product-info-accordion .info-item {
  border-bottom: 1px solid var(--clutch-border);
}

.product-info-accordion .info-item summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 0;
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--clutch-paper);
  cursor: pointer;
  list-style: none;
}

.product-info-accordion .info-item summary::-webkit-details-marker {
  display: none;
}

.product-info-accordion .info-item summary svg {
  transition: transform 0.2s ease;
  flex-shrink: 0;
}

.product-info-accordion .info-item[open] summary svg {
  transform: rotate(180deg);
}

.product-info-accordion .info-content {
  padding: 0 0 1rem;
  font-size: 0.875rem;
  color: var(--clutch-text-muted);
}

.product-info-accordion .info-content ul {
  margin: 0;
  padding-left: 1.25rem;
}

.product-info-accordion .info-content li {
  margin-bottom: 0.5rem;
}

.product-info-accordion .info-content a {
  color: var(--clutch-copper);
  text-decoration: none;
}

/* Product Options */
.product-options {
  margin-bottom: 1rem;
}

.product-options__label {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: var(--clutch-paper);
}

.product-options__values {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.product-option {
  padding: 0.5rem 1rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  color: var(--clutch-paper);
  font-size: 0.875rem;
  cursor: pointer;
  transition: all 0.2s;
}

.product-option:hover:not(.disabled) {
  border-color: var(--clutch-copper);
}

.product-option.selected {
  background: var(--clutch-copper);
  border-color: var(--clutch-copper);
  color: var(--clutch-ink);
}

.product-option.disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Quantity Selector */
.quantity-selector {
  margin-bottom: 1rem;
}

.quantity-selector__label {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: var(--clutch-paper);
}

.quantity-selector__control {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  border: 1px solid var(--clutch-border);
  border-radius: 8px;
  padding: 0.25rem;
}

.quantity-selector__control button {
  width: 40px;
  height: 40px;
  background: transparent;
  border: none;
  color: var(--clutch-paper);
  font-size: 1.25rem;
  cursor: pointer;
}

.quantity-selector__control input {
  width: 50px;
  text-align: center;
  background: transparent;
  border: none;
  color: var(--clutch-paper);
  font-size: 1rem;
  font-weight: 600;
}

/* Add to Cart */
.add-to-cart {
  width: 100%;
  padding: 1rem;
  background: var(--clutch-copper);
  color: var(--clutch-ink);
  border: none;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  margin-bottom: 1rem;
}

.add-to-cart:hover:not(:disabled) {
  background: var(--clutch-copper-soft);
  transform: translateY(-2px);
}

.add-to-cart:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Payment Methods */
.product-payment-methods {
  margin: 1rem 0;
  padding: 1rem 0;
  border-top: 1px solid var(--clutch-border);
}

.product-payment-methods p {
  margin: 0 0 0.5rem;
  font-size: 0.75rem;
  color: var(--clutch-text-muted);
}

.product-payment-methods .payment-icons {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.product-payment-methods .payment-icon {
  padding: 0.25rem 0.5rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 4px;
  font-size: 0.625rem;
  font-weight: 600;
  color: var(--clutch-text-muted);
}

/* Product Meta */
.product-meta {
  display: flex;
  gap: 2rem;
  padding-top: 1rem;
  border-top: 1px solid var(--clutch-border);
  font-size: 0.8125rem;
}

.product-meta__label {
  color: var(--clutch-text-dim);
}

.product-meta__value {
  color: var(--clutch-paper);
}

/* Mobile adjustments - MINIMAL */
@media (max-width: 768px) {
  .product-trust-bar {
    flex-wrap: wrap;
    gap: 1rem;
  }

  .product-info__title {
    font-size: 1.25rem;
  }

  /* Container at 90% width */
  .product-left {
    width: 90% !important;
    margin: 0 auto !important;
    padding: 0 !important;
  }

  /* Gallery container */
  .product-gallery {
    width: 100% !important;
    max-width: 100% !important;
    overflow: hidden !important;
  }

  /* CRITICAL: Remove aspect-ratio square prison */
  .product-gallery__main {
    aspect-ratio: auto !important;
    max-height: none !important;
    height: auto !important;
