{% comment %}
  Product Template - Reorganized Layout
  Left: Image gallery + description
  Right: Info, pricing, trust, dropdowns, CTA
{% endcomment %}

<div class="page-with-glow">

<div class="product-page product-page--optimized">
  {% comment %} LEFT SIDE: Image Gallery + Description {% endcomment %}
  <div class="product-left">
    <div class="product-gallery">
      <div class="product-gallery__main">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | escape }}" id="mainImage">
        {% else %}
          <span style="color: var(--clutch-text-dim);">Product Image</span>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="product-gallery__thumbs">
          {% for image in product.images %}
            <div class="product-gallery__thumb {% if forloop.first %}active{% endif %}" onclick="changeImage('{{ image | image_url: width: 800 }}', this)">
              <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}" loading="lazy">
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    
    {% comment %} Description below images {% endcomment %}
    <div class="product-description">
      {{ product.description }}
    </div>
  </div>

  {% comment %} RIGHT SIDE: Product Info {% endcomment %}
  <div class="product-right">
    <div class="product-info">
      <div class="product-info__brand">{{ product.vendor }}</div>
      <h1 class="product-info__title">{{ product.title }}</h1>
      
      {% comment %} Live Viewer Count {% endcomment %}
      <div class="viewing-now">
        <span class="viewing-dot"></span>
        <span class="viewing-text"><strong id="viewerCount">3</strong> people are viewing this product right now</span>
      </div>
      
      <div class="product-info__price">
        <span class="product-info__price-current">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="product-info__price-compare">{{ product.compare_at_price | money }}</span>
          <span class="product-info__savings">Save {{ product.compare_at_price | minus: product.price | money }}</span>
        {% endif %}
      </div>
      
      {% comment %} Trust Bar {% endcomment %}
      <div class="product-trust-bar">
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5"/></svg>
          <span>Secure Checkout</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 14l2 2 6-6" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/></svg>
          <span>30-Day Returns</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L4 13h6l-1 9 9-11h-6l1-9z" stroke="currentColor" stroke-width="1.5"/></svg>
          <span>Fast Shipping</span>
        </div>
      </div>
      
      {% comment %} Info Accordion {% endcomment %}
      <div class="product-info-accordion">
        <details class="info-item">
          <summary>
            <span>Shipping Information</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5"/></svg>
          </summary>
          <div class="info-content">
            <ul>
              <li><strong>Free Shipping</strong> on orders over $300 (Continental US only)</li>
              <li>We process orders within 1-2 business days. Same-day shipping for orders placed before 2:00 PM CST</li>
              <li>In-Store Pickup available — select at checkout. We'll email when ready (usually within 24 hours)</li>
            </ul>
          </div>
        </details>

        <details class="info-item">
          <summary>
            <span>Returns & Refunds</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5"/></svg>
          </summary>
          <div class="info-content">
            <ul>
              <li><strong>30-day return policy</strong> — must contact us first. Items must be unworn/unused with original packaging and receipt</li>
              <li>Customers pay for return shipping (we'll provide the label). Defective items get free return shipping</li>
              <li>All sales final on clippers, trimmers and other products unless defective or non-operational</li>
            </ul>
          </div>
        </details>

        <details class="info-item">
          <summary>
            <span>Contact Us</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5"/></svg>
          </summary>
          <div class="info-content">
            <ul>
              <li><strong>Email:</strong> <a href="mailto:viceliatinde20@gmail.com">viceliatinde20@gmail.com</a> — We reply within 24 hours</li>
              <li><strong>Phone:</strong> <a href="tel:+12146771059">(214) 677-1059</a> — Mon–Fri 9am–6pm, Sat 9am–12pm CST</li>
              <li><strong>Store:</strong> 113 South Center, Grand Prairie, TX 75050 — Visit our <a href="/pages/contact">contact page</a> for details</li>
            </ul>
          </div>
        </details>
      </div>
      
      {% form 'product', product %}
        {% if product.variants.size > 1 %}
          <div class="product-options">
            <label class="product-options__label">Select Option</label>
            <div class="product-options__values">
              {% for variant in product.variants %}
                <button type="button" class="product-option {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}" 
                        onclick="selectVariant('{{ variant.id }}', {{ variant.price }}, {{ variant.compare_at_price | default: 0 }}, {{ variant.available | json }})" 
                        data-variant-id="{{ variant.id }}">
                  {{ variant.title }}
                </button>
              {% endfor %}
            </div>
          </div>
        {% endif %}
        
        <input type="hidden" name="id" id="variantId" value="{{ product.selected_or_first_available_variant.id }}">
        
        <div class="quantity-selector">
          <span class="quantity-selector__label">Quantity</span>
          <div class="quantity-selector__control">
            <button type="button" onclick="updateQuantity(-1)">−</button>
            <input type="number" name="quantity" value="1" min="1" id="quantityInput">
            <button type="button" onclick="updateQuantity(1)">+</button>
          </div>
        </div>
        
        <button type="submit" class="add-to-cart" id="addToCartBtn" {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}Add to Cart - {{ product.price | money }}{% else %}Sold Out{% endif %}
        </button>
      {% endform %}
      
      {% comment %} Payment Methods {% endcomment %}
      <div class="product-payment-methods">
        <p>We accept:</p>
        <div class="payment-icons">
          <span class="payment-icon">AMEX</span>
          <span class="payment-icon">MC</span>
          <span class="payment-icon">VISA</span>
          <span class="payment-icon">PayPal</span>
          <span class="payment-icon">Apple Pay</span>
          <span class="payment-icon">Shop Pay</span>
        </div>
      </div>
      
      <div class="product-meta">
        <div class="product-meta__item">
          <span class="product-meta__label">SKU:</span>
          <span class="product-meta__value" id="sku">{{ product.selected_or_first_available_variant.sku }}</span>
        </div>
        <div class="product-meta__item">
          <span class="product-meta__label">Availability:</span>
          <span class="product-meta__value" id="availability">{% if product.available %}In Stock{% else %}Out of Stock{% endif %}</span>
        </div>
      </div>
    </div>
  </div>
</div>

